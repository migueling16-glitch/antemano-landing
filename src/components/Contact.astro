---
---

<section id="contacto" class="py-24 lg:py-32 bg-offwhite">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Form -->
      <div>
        <p class="text-gray-400 text-sm font-semibold tracking-widest uppercase mb-3 reveal">
          Contacto
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-charcoal mb-3 reveal reveal-delay-1">
          ¿Listo para que tu contenido trabaje por ti?
        </h2>
        <p class="text-gray-500 mb-10 reveal reveal-delay-2">
          Cuéntanos qué necesitas y <strong class="kw">abrimos la conversación por WhatsApp</strong>. Te respondemos en menos de 24 horas.
        </p>

        <form
          class="space-y-5 reveal reveal-delay-2"
          novalidate
          id="contact-form"
        >
          <div>
            <label for="nombre" class="block text-sm font-semibold text-charcoal mb-1.5">
              Nombre <span class="text-gray-400" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              autocomplete="name"
              placeholder="Tu nombre"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-charcoal text-sm focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 placeholder:text-gray-300"
            />
          </div>

          <div>
            <label for="negocio" class="block text-sm font-semibold text-charcoal mb-1.5">
              Nombre del negocio
            </label>
            <input
              type="text"
              id="negocio"
              name="negocio"
              autocomplete="organization"
              placeholder="Tu marca, tienda o proyecto"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-charcoal text-sm focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 placeholder:text-gray-300"
            />
          </div>

          <div>
            <label for="servicio" class="block text-sm font-semibold text-charcoal mb-1.5">
              ¿Qué necesitas? <span class="text-gray-400" aria-hidden="true">*</span>
            </label>
            <select
              id="servicio"
              name="servicio"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-charcoal text-sm focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200"
            >
              <option value="">Selecciona una opción</option>
              <option value="Manejo de redes sociales">Manejo de redes sociales</option>
              <option value="Producción de video">Producción de video</option>
              <option value="Fotografía">Fotografía</option>
              <option value="Estrategia y publicidad">Estrategia y publicidad</option>
              <option value="Propuesta completa">Todo lo anterior — propuesta completa</option>
              <option value="Otra cosa">Otra cosa / quiero platicarlo</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-semibold text-charcoal mb-1.5">
              Cuéntanos un poco más
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              placeholder="¿Qué objetivos tienes? ¿Algún presupuesto o fecha en mente?"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-charcoal text-sm focus:outline-none focus:border-charcoal focus:ring-1 focus:ring-charcoal transition-colors duration-200 placeholder:text-gray-300 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-charcoal text-white font-bold rounded-full text-sm tracking-wide hover:bg-gray-700 transition-all duration-200 hover:-translate-y-0.5"
          >
            Enviar
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </button>
          <p class="text-xs text-gray-400 text-center sm:text-left mt-3">
            Al enviar, se abre WhatsApp con tu mensaje listo. Sin contratos de permanencia. Sin letras chiquitas.
          </p>
        </form>
      </div>

      <!-- Contact info -->
      <div class="flex flex-col gap-8 lg:pt-20">
        <div class="reveal">
          <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-4">
            Datos de contacto
          </h3>
          <div class="space-y-4">
            <!-- Email (click-to-copy + mailto) -->
            <div class="flex items-center gap-4 group">
              <a
                href="mailto:antemanotallercreativo@gmail.com"
                class="w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 group-hover:border-charcoal transition-colors"
                aria-label="Enviar email a antemanotallercreativo@gmail.com"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-charcoal">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </a>
              <button
                type="button"
                class="copy-btn text-charcoal text-sm font-medium hover:text-gray-400 transition-colors inline-flex items-center gap-2"
                data-copy="antemanotallercreativo@gmail.com"
                data-toast="Email copiado"
                aria-label="Copiar antemanotallercreativo@gmail.com"
              >
                antemanotallercreativo@gmail.com
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-3.5 h-3.5 opacity-40 transition-opacity">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25" />
                </svg>
              </button>
            </div>

            <!-- Phone (click-to-copy + tel) -->
            <div class="flex items-center gap-4 group">
              <a
                href="tel:+526181539643"
                class="w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center flex-shrink-0 group-hover:border-charcoal transition-colors"
                aria-label="Llamar al +52 618 153 9643"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-charcoal">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </a>
              <button
                type="button"
                class="copy-btn text-charcoal text-sm font-medium hover:text-gray-400 transition-colors inline-flex items-center gap-2"
                data-copy="+526181539643"
                data-toast="Teléfono copiado"
                aria-label="Copiar teléfono"
              >
                +52 618 153 9643
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-3.5 h-3.5 opacity-40 transition-opacity">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25" />
                </svg>
              </button>
            </div>

            <!-- Location -->
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-charcoal">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <span class="text-charcoal text-sm font-medium">
                Durango, Dgo., México
              </span>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="reveal reveal-delay-1">
          <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-4">
            Redes Sociales
          </h3>
          <div class="flex gap-3">
            <!-- Instagram -->
            <a
              href="https://www.instagram.com/antemanomx/"
              target="_blank"
              class="social-link w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center hover:border-charcoal hover:text-gray-400 text-charcoal"
              aria-label="Instagram de Antemano Taller Creativo"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Contact form polish */
  #contact-form input,
  #contact-form textarea {
    transition:
      border-color 0.25s var(--ease-out-quart),
      box-shadow 0.25s var(--ease-out-quart),
      background 0.25s;
  }
  #contact-form input:hover,
  #contact-form textarea:hover {
    border-color: #bdbdbd;
  }
  #contact-form input:focus,
  #contact-form textarea:focus {
    box-shadow: 0 0 0 3px rgba(26,26,26,0.08);
  }

  /* Submit button shine on hover */
  #contact-form button[type="submit"] {
    position: relative;
    overflow: hidden;
    transition:
      transform 0.25s var(--ease-out-quart),
      background 0.25s;
  }
  #contact-form button[type="submit"]::after {
    content: '';
    position: absolute;
    top: 0;
    left: -60%;
    width: 40%;
    height: 100%;
    background: linear-gradient(100deg, transparent 0%, rgba(255,255,255,0.18) 50%, transparent 100%);
    transform: skewX(-20deg);
    transition: left 0.6s var(--ease-out-quart);
  }
  #contact-form button[type="submit"]:hover { transform: translateY(-2px); }
  #contact-form button[type="submit"]:hover::after { left: 120%; }

  /* Copy button icon reveal */
  .copy-btn:hover svg { opacity: 0.9 !important; }
  .copy-btn.copied { color: #1a1a1a !important; }

  /* Social links lift */
  .social-link { transition: transform 0.25s var(--ease-out-quart), border-color 0.2s, color 0.2s; }
  .social-link:hover { transform: translateY(-3px); }
</style>

<script>
  // ─── Copy to clipboard on contact rows ───────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy || '';
      const toast = btn.dataset.toast || 'Copiado';
      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1400);
        (window as any).showToast?.(`${toast} ✓`);
      } catch {
        (window as any).showToast?.('No se pudo copiar');
      }
    });
  });

  // ─── Form → WhatsApp ─────────────────────────────────────────────────
  const WHATSAPP_NUMBER = '526181539643';
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  // Clear the red border as user types again
  form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[required]').forEach((el) => {
    el.addEventListener('input', () => { el.style.borderColor = ''; });
    el.addEventListener('change', () => { el.style.borderColor = ''; });
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form) return;

    const nombreEl = document.getElementById('nombre') as HTMLInputElement | null;
    const negocioEl = document.getElementById('negocio') as HTMLInputElement | null;
    const servicioEl = document.getElementById('servicio') as HTMLSelectElement | null;
    const mensajeEl = document.getElementById('mensaje') as HTMLTextAreaElement | null;

    const nombre = nombreEl?.value.trim() || '';
    const negocio = negocioEl?.value.trim() || '';
    const servicio = servicioEl?.value.trim() || '';
    const mensaje = mensajeEl?.value.trim() || '';

    // Basic validation on required fields
    let valid = true;
    if (!nombre && nombreEl) { valid = false; nombreEl.style.borderColor = '#c94a4a'; }
    if (!servicio && servicioEl) { valid = false; servicioEl.style.borderColor = '#c94a4a'; }
    if (!valid) {
      (window as any).showToast?.('Completa los campos requeridos');
      return;
    }

    // Build the WhatsApp message
    const intro = negocio
      ? `Hola Antemano, soy ${nombre} de ${negocio}.`
      : `Hola Antemano, soy ${nombre}.`;
    const servicioLine = `Me interesa: ${servicio}.`;
    const mensajeBlock = mensaje ? `\n\n${mensaje}` : '';
    const fullMessage = `${intro}\n${servicioLine}${mensajeBlock}`;

    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(fullMessage)}`;

    // Button feedback
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (btn) {
      const original = btn.innerHTML;
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = original;
      }, 2000);
    }

    (window as any).showToast?.('Abriendo WhatsApp…');
    window.open(url, '_blank', 'noopener,noreferrer');
  });
</script>

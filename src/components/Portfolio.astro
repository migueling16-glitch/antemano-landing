---

<section id="portafolio" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
      <div class="max-w-xl">
        <p class="text-gray-400 text-sm font-semibold tracking-widest uppercase mb-3 reveal">
          Nuestro Trabajo
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-charcoal reveal reveal-delay-1">
          Trabajos que hablan por sí solos
        </h2>
      </div>

      <!-- Filter buttons -->
      <div
        class="flex flex-wrap gap-2 reveal reveal-delay-2"
        id="filter-buttons"
        role="group"
        aria-label="Filtrar proyectos"
      >
        {['Todos', 'Video', 'Fotografía', 'Redes Sociales'].map((label) => (
          <button
            data-filter={
              label === 'Todos' ? 'all'
              : label === 'Video' ? 'video'
              : label === 'Fotografía' ? 'foto'
              : 'redes'
            }
            class="filter-btn px-4 py-2 rounded-full text-sm font-semibold border border-gray-200 text-gray-500 hover:border-charcoal hover:text-charcoal transition-all duration-200"
          >
            {label}
          </button>
        ))}
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolio-grid">
      {projects.map((project, i) => (
        <article
          class={`reveal-up reveal-delay-${(i % 3) + 1} portfolio-item group relative overflow-hidden rounded-2xl cursor-pointer`}
          data-tag={project.tag}
          data-project={JSON.stringify({
            title: project.title,
            client: project.client,
            handle: project.handle,
            category: project.category,
            description: project.description,
            gallery: project.gallery,
          })}
          role="button"
          tabindex="0"
          aria-label={`Ver proyecto: ${project.title} — ${project.client}`}
        >
          <!-- Thumbnail -->
          {project.image ? (
            <div
              class="w-full aspect-video overflow-hidden"
              aria-hidden="true"
            >
              <img
                src={project.image}
                alt={`${project.title} — ${project.client}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          ) : (
            <div
              class="w-full aspect-video flex items-center justify-center"
              style={`background-color: ${project.color};`}
              aria-hidden="true"
            >
              <span class="text-white/20 text-xs font-medium tracking-widest uppercase">
                {project.category}
              </span>
            </div>
          )}

          <!-- Card info -->
          <div class="p-5 bg-white border border-gray-100 border-t-0 rounded-b-2xl">
            <span class="inline-block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">
              {project.category}
            </span>
            <h3 class="font-bold text-charcoal text-base leading-snug">{project.title}</h3>
            <p class="text-gray-500 text-sm mt-0.5 font-medium">{project.client}</p>
            <p class="text-gray-300 text-xs mt-0.5">{project.handle}</p>
          </div>

          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-charcoal/80 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex items-center justify-center rounded-2xl pointer-events-none">
            <span class="overlay-cta inline-flex items-center gap-2 px-5 py-2.5 border border-white text-white text-sm font-semibold rounded-full">
              {project.gallery.length > 0 ? 'Ver galería' : 'Ver proyecto'}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Modal -->
<PortfolioModal />

<style>
  /* 3D tilt preparation */
  .portfolio-item {
    transform-style: preserve-3d;
    transition:
      transform 0.5s var(--ease-out-quart),
      box-shadow 0.5s var(--ease-out-quart);
    will-change: transform;
  }
  .portfolio-item:hover {
    box-shadow: 0 28px 56px -18px rgba(0,0,0,0.22);
  }

  /* Inner wrapper (image) — subtle zoom */
  .portfolio-item .group-hover\:scale-105 {
    transition: transform 0.7s var(--ease-out-expo);
  }

  /* Overlay caption */
  .portfolio-item .overlay-cta {
    transform: translateY(8px);
    opacity: 0;
    transition:
      transform 0.35s var(--ease-out-quart),
      opacity 0.35s var(--ease-out-quart);
  }
  .portfolio-item:hover .overlay-cta {
    transform: translateY(0);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-item { transform: none !important; }
  }
</style>

<script>
  // ─── 3D tilt on cards (desktop only) ─────────────────────────────────────
  const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canHover && !reducedMotion) {
    document.querySelectorAll<HTMLElement>('.portfolio-item').forEach((card) => {
      let rafId = 0;
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(() => {
          card.style.transform = `perspective(900px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg) translateY(-4px)`;
        });
      });
      card.addEventListener('mouseleave', () => {
        cancelAnimationFrame(rafId);
        card.style.transform = '';
      });
    });
  }

  // ─── Filter ───────────────────────────────────────────────────────────────
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.portfolio-item');

  function setActiveFilter(btn: HTMLButtonElement) {
    filterBtns.forEach((b) => {
      b.classList.remove('bg-charcoal', 'text-white', 'border-charcoal');
      b.classList.add('border-gray-200', 'text-gray-500');
    });
    btn.classList.add('bg-charcoal', 'text-white', 'border-charcoal');
    btn.classList.remove('border-gray-200', 'text-gray-500');
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      setActiveFilter(btn);
      items.forEach((item) => {
        const match = filter === 'all' || item.dataset.tag === filter;
        item.style.display = match ? '' : 'none';
      });
    });
  });

  const defaultBtn = document.querySelector<HTMLButtonElement>('[data-filter="all"]');
  if (defaultBtn) setActiveFilter(defaultBtn);

  // ─── Modal ────────────────────────────────────────────────────────────────
  const modal     = document.getElementById('portfolio-modal')!;
  const overlay   = document.getElementById('pmodal-overlay')!;
  const closeBtn  = document.getElementById('pmodal-close')!;
  const mainImg   = document.getElementById('pmodal-main-img') as HTMLImageElement;
  const thumbs    = document.getElementById('pmodal-thumbs')!;
  const prevBtn   = document.getElementById('pmodal-prev')!;
  const nextBtn   = document.getElementById('pmodal-next')!;
  const noImages  = document.getElementById('pmodal-no-images')!;
  const counter   = document.getElementById('pmodal-counter')!;

  let gallery: string[] = [];
  let current = 0;

  // Focus trap helpers
  function getFocusable() {
    return Array.from(
      modal.querySelectorAll<HTMLElement>(
        'button, [href], input, [tabindex]:not([tabindex="-1"])'
      )
    ).filter((el) => !el.hasAttribute('disabled'));
  }

  function trapFocus(e: KeyboardEvent) {
    const focusable = getFocusable();
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.key === 'Tab') {
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
  }

  function openModal(project: Record<string, any>) {
    // Populate header
    (document.getElementById('pmodal-title')!).textContent = project.title ?? '';
    (document.getElementById('pmodal-category')!).textContent = project.category ?? '';
    (document.getElementById('pmodal-client')!).textContent =
      `${project.client ?? ''}  ·  ${project.handle ?? ''}`;
    (document.getElementById('pmodal-description')!).textContent = project.description ?? '';

    gallery = Array.isArray(project.gallery) ? project.gallery : [];
    current = 0;

    // Build thumbnails
    thumbs.innerHTML = '';
    if (gallery.length > 0) {
      noImages.classList.add('hidden');
      mainImg.classList.remove('hidden');
      prevBtn.classList.remove('hidden');
      nextBtn.classList.remove('hidden');
      counter.classList.remove('hidden');

      gallery.forEach((src, idx) => {
        const btn = document.createElement('button');
        btn.setAttribute('role', 'listitem');
        btn.setAttribute('aria-label', `Ver imagen ${idx + 1}`);
        btn.className =
          'flex-shrink-0 w-16 h-16 rounded-lg overflow-hidden border-2 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-charcoal';
        btn.classList.add(idx === 0 ? 'border-charcoal' : 'border-transparent');
        btn.innerHTML = `<img src="${src}" alt="Miniatura ${idx + 1}" class="w-full h-full object-cover" loading="lazy" />`;
        btn.addEventListener('click', () => goTo(idx));
        thumbs.appendChild(btn);
      });

      goTo(0, /* instant */ true);
    } else {
      noImages.classList.remove('hidden');
      mainImg.classList.add('hidden');
      prevBtn.classList.add('hidden');
      nextBtn.classList.add('hidden');
      counter.classList.add('hidden');
    }

    // Show
    modal.classList.remove('hidden');
    requestAnimationFrame(() => modal.classList.add('modal-open'));
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', handleKey);
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('modal-open');
    document.body.style.overflow = '';
    document.removeEventListener('keydown', handleKey);
    setTimeout(() => modal.classList.add('hidden'), 200);
  }

  function goTo(idx: number, instant = false) {
    current = idx;

    if (instant) {
      mainImg.src = gallery[idx];
      mainImg.alt = `Imagen ${idx + 1} de ${gallery.length}`;
      mainImg.style.opacity = '1';
    } else {
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = gallery[idx];
        mainImg.alt = `Imagen ${idx + 1} de ${gallery.length}`;
        mainImg.style.opacity = '1';
      }, 160);
    }

    // Update counter
    counter.textContent = `${idx + 1} / ${gallery.length}`;

    // Update thumb borders
    thumbs.querySelectorAll<HTMLButtonElement>('button').forEach((btn, i) => {
      btn.classList.toggle('border-charcoal', i === idx);
      btn.classList.toggle('border-transparent', i !== idx);
    });

    // Scroll active thumb into view
    const activeThumb = thumbs.querySelectorAll<HTMLElement>('button')[idx];
    activeThumb?.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
  }

  function handleKey(e: KeyboardEvent) {
    if (e.key === 'Escape') { closeModal(); return; }
    if (e.key === 'ArrowLeft' && gallery.length > 0)  goTo((current - 1 + gallery.length) % gallery.length);
    if (e.key === 'ArrowRight' && gallery.length > 0) goTo((current + 1) % gallery.length);
    trapFocus(e);
  }

  // Open on card click / Enter / Space
  items.forEach((item) => {
    const open = () => {
      try {
        const project = JSON.parse(item.dataset.project || '{}');
        openModal(project);
      } catch {}
    };
    item.addEventListener('click', open);
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
    });
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);

  prevBtn.addEventListener('click', () => {
    if (gallery.length) goTo((current - 1 + gallery.length) % gallery.length);
  });
  nextBtn.addEventListener('click', () => {
    if (gallery.length) goTo((current + 1) % gallery.length);
  });

  // Touch swipe on main image
  let touchX = 0;
  const imgWrap = document.getElementById('pmodal-img-wrap')!;
  imgWrap.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
  imgWrap.addEventListener('touchend', (e) => {
    const diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 48 && gallery.length) {
      diff > 0
        ? goTo((current + 1) % gallery.length)
        : goTo((current - 1 + gallery.length) % gallery.length);
    }
  }, { passive: true });
</script>

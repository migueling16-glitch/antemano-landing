---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-charcoal"
>
  <!-- Background -->
  <div class="absolute inset-0 bg-charcoal" aria-hidden="true">
    <!-- Subtle animated gradient -->
    <div class="hero-gradient absolute inset-0"></div>

    <!-- Giant "a" brand mark (parallax wrapper keeps the float animation intact) -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="hero-brand-px" id="hero-brand-px">
        <img src="/logo-a.png" alt="" class="hero-brand-logo select-none" />
      </div>
    </div>

    <!-- Vignette overlay -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(26,26,26,0) 0%, rgba(26,26,26,0.6) 80%, rgba(26,26,26,0.92) 100%);"></div>
  </div>

  <!-- Content -->
  <div
    id="hero-content"
    class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center text-white"
  >
    <p class="hero-eyebrow text-gray-400 text-sm font-semibold tracking-widest uppercase mb-6">
      Durango, México
    </p>

    <!-- Masked line-by-line reveal -->
    <h1 class="hero-title text-4xl sm:text-5xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
      <span class="hmask"><span class="hrise" style="--l:0">Tu competencia ya está <em class="serif-it">publicando.</em></span></span>
      <span class="hmask"><span class="hrise" style="--l:1">Y se está quedando</span></span>
      <span class="hmask"><span class="hrise" style="--l:2">con tus <em class="serif-it">clientes.</em></span></span>
    </h1>

    <p class="hero-sub text-lg sm:text-xl text-white/70 font-medium max-w-2xl mx-auto mb-10">
      Producimos el contenido. Diseñamos la estrategia. Tú recibes los clientes.
    </p>
    <div class="hero-cta flex flex-col sm:flex-row gap-4 justify-center">
      <span class="magnetic inline-block" data-magnetic="0.3">
        <a
          href="#resultados"
          class="hero-btn hero-btn-primary inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-charcoal font-bold rounded-full text-sm tracking-wide"
        >
          <span>Ver resultados</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.4" stroke="currentColor" class="w-4 h-4 hero-btn-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </span>
      <span class="magnetic inline-block" data-magnetic="0.3">
        <a
          href="#contacto"
          class="hero-btn hero-btn-ghost inline-flex items-center justify-center px-8 py-4 border border-white/40 text-white font-bold rounded-full text-sm tracking-wide"
        >
          Quiero una propuesta
        </a>
      </span>
    </div>
  </div>

  <!-- Kinetic type strip — giant, half-cropped at the hero's bottom edge -->
  <div class="hero-kinetic" aria-hidden="true">
    <div class="hk-track">
      <span class="hk-seq">producción <i>/</i> estrategia <i>/</i> contenido <i>/</i> <em>resultados</em> <i>/</i>&nbsp;</span>
      <span class="hk-seq">producción <i>/</i> estrategia <i>/</i> contenido <i>/</i> <em>resultados</em> <i>/</i>&nbsp;</span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#servicios"
    class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 hover:text-white/80 transition-colors"
    aria-label="Scroll hacia abajo"
  >
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full bg-white/80" style="animation: scrollLine 2s var(--ease-in-out-quart, ease) infinite;"></div>
    </div>
  </a>
</section>

<style>
  /* ── Giant "a" brand mark ── */
  .hero-brand-px {
    position: absolute;
    inset: 0;
    will-change: transform;
  }
  .hero-brand-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(115vh, 100vw);
    height: auto;
    transform: translate(-50%, -50%);
    opacity: 0.08;
    filter: brightness(0) invert(1);
    animation: brandFloat 16s ease-in-out infinite alternate, brandIn 2.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes brandFloat {
    0%   { transform: translate(-50%, -50%) scale(1) rotate(-0.5deg); }
    100% { transform: translate(-50%, -53%) scale(1.03) rotate(0.5deg); }
  }
  @keyframes brandIn {
    from { opacity: 0; transform: translate(-50%, -47%) scale(0.9); }
    to   { opacity: 0.08; }
  }

  /* ── Animated gradient BG (very subtle) ── */
  .hero-gradient {
    background:
      radial-gradient(circle at 20% 20%, rgba(255,255,255,0.04), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.03), transparent 50%);
    animation: heroPulse 8s ease-in-out infinite alternate;
  }
  @keyframes heroPulse {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.1) translate(2%, -1%); }
  }

  /* ── Scroll line ── */
  @keyframes scrollLine {
    0%, 100% { height: 0; top: 0; }
    50% { height: 100%; top: 0; }
    100% { height: 0; top: 100%; }
  }

  /* ── Scroll indicator breathing ── */
  .scroll-indicator {
    animation: scrollBreathe 3s ease-in-out infinite;
  }
  @keyframes scrollBreathe {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 6px); }
  }

  /* ── H1 masked line reveal (gated until intro finishes) ── */
  .hmask {
    display: block;
    overflow: hidden;
    padding-bottom: 0.04em;
  }
  .hrise {
    display: block;
    transform: translateY(112%);
    opacity: 0;
    animation: hRise 1s var(--ease-out-expo) both;
    animation-play-state: paused;
    animation-delay: calc(0.15s + var(--l, 0) * 0.12s);
  }
  html.intro-done .hrise { animation-play-state: running; }
  @keyframes hRise {
    0%   { transform: translateY(112%); opacity: 0; }
    32%  { opacity: 1; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* ── Kinetic type strip (Blu-style cropped giant type) ── */
  .hero-kinetic {
    position: absolute;
    bottom: -0.16em;
    left: 0;
    right: 0;
    overflow: hidden;
    pointer-events: none;
    line-height: 1;
    z-index: 1;
  }
  .hk-track {
    display: flex;
    width: max-content;
    animation: hkDrift 80s linear infinite;
    will-change: transform;
  }
  .hk-seq {
    display: inline-block;
    font-size: clamp(4.5rem, 11vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.045em;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.055);
  }
  .hk-seq em {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.075);
  }
  .hk-seq i {
    font-style: normal;
    color: rgba(255, 255, 255, 0.035);
    padding: 0 0.12em;
  }
  @keyframes hkDrift {
    to { transform: translateX(-50%); }
  }

  /* ── Eyebrow / sub / CTA entrance (gated) ── */
  .hero-eyebrow,
  .hero-sub,
  .hero-cta {
    opacity: 0;
    transform: translateY(22px);
    animation: heroFade 0.9s var(--ease-out-expo) both;
    animation-play-state: paused;
  }
  .hero-eyebrow { animation-delay: 0.1s; }
  .hero-sub     { animation-delay: 0.62s; }
  .hero-cta     { animation-delay: 0.78s; }
  html.intro-done .hero-eyebrow,
  html.intro-done .hero-sub,
  html.intro-done .hero-cta { animation-play-state: running; }
  @keyframes heroFade { to { opacity: 1; transform: translateY(0); } }

  /* ── Buttons ── */
  .hero-btn {
    transition:
      background 0.25s var(--ease-out-quart),
      color 0.25s var(--ease-out-quart),
      border-color 0.25s,
      transform 0.2s var(--ease-out-quart);
    position: relative;
  }
  @media (hover: hover) {
    .hero-btn:hover { transform: scale(1.025); }
  }
  .hero-btn-arrow {
    transition: transform 0.25s var(--ease-out-quart);
  }
  .hero-btn-primary:hover .hero-btn-arrow {
    transform: translateX(4px);
  }
  .hero-btn-primary:hover {
    background: #f4f4f4;
  }
  .hero-btn-ghost:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.8);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gradient, .scroll-indicator { animation: none !important; }
    .hrise { opacity: 1; transform: none; animation: none; }
    .hero-eyebrow, .hero-sub, .hero-cta { opacity: 1; transform: none; animation: none; }
    .hero-brand-px { transform: none !important; }
    .hk-track { animation: none; }
    .hmask { transform: none !important; opacity: 1 !important; }
  }
</style>

<script>
  // ─── Hero mouse parallax (desktop, non-reduced) ──────────────────────
  const section = document.getElementById('inicio');
  const brand = document.getElementById('hero-brand-px');
  const content = document.getElementById('hero-content');
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (section && brand && fine && !reduced) {
    let tx = 0, ty = 0, cx = 0, cy = 0, raf = 0, active = false;

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    function loop() {
      cx = lerp(cx, tx, 0.07);
      cy = lerp(cy, ty, 0.07);
      brand!.style.transform = `translate(${cx * 0.022}px, ${cy * 0.022}px)`;
      if (content) content.style.transform = `translate(${cx * 0.008}px, ${cy * 0.008}px)`;
      if (active || Math.abs(cx - tx) > 0.5 || Math.abs(cy - ty) > 0.5) {
        raf = requestAnimationFrame(loop);
      } else {
        raf = 0;
      }
    }

    section.addEventListener('mousemove', (e: MouseEvent) => {
      const r = section.getBoundingClientRect();
      tx = e.clientX - r.left - r.width / 2;
      ty = e.clientY - r.top - r.height / 2;
      active = true;
      if (!raf) raf = requestAnimationFrame(loop);
    }, { passive: true });

    section.addEventListener('mouseleave', () => {
      tx = 0; ty = 0; active = false;
      if (!raf) raf = requestAnimationFrame(loop);
    });
  }

  // ─── Scroll-scrubbed hero exit: lines split apart as you leave ───────
  // Fade is applied to #hero-content (no CSS animation there, so inline
  // styles win); the line masks slide horizontally for the split effect.
  if (section && content && !reduced) {
    const masks = Array.from(section.querySelectorAll<HTMLElement>('.hmask'));
    const indicator = section.querySelector<HTMLElement>('.scroll-indicator');
    let exRaf = 0;
    let lastP = -1;

    function heroExit() {
      exRaf = 0;
      const vh = window.innerHeight;
      const p = Math.min(Math.max(window.scrollY / (vh * 0.85), 0), 1);
      if (p === lastP) return;
      lastP = p;
      const e = p * p; // ease-in: starts gentle, accelerates away

      masks.forEach((m, i) => {
        const dir = i === 0 ? -1 : i === 2 ? 1 : 0;
        m.style.transform = `translateX(${(dir * e * 110).toFixed(1)}px)`;
      });
      content!.style.opacity = String(1 - e * 0.95);
      if (indicator) indicator.style.opacity = String(Math.max(0, 1 - p * 2.5));
    }

    window.addEventListener('scroll', () => {
      if (!exRaf) exRaf = requestAnimationFrame(heroExit);
    }, { passive: true });
  }
</script>

---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-charcoal"
>
  <!-- Video placeholder background -->
  <div
    class="absolute inset-0 bg-charcoal"
    aria-hidden="true"
  >
    <!-- Placeholder reel — replace with <video> tag when reel is ready -->
    <div class="w-full h-full flex items-center justify-center opacity-10">
      <div class="border-2 border-white/30 rounded-lg px-8 py-6 text-white text-sm font-medium tracking-widest uppercase">
        Video Reel — próximamente
      </div>
    </div>
    <!-- Overlay -->
    <div class="absolute inset-0 bg-charcoal/60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center text-white">
    <p class="text-gray-400 text-sm font-semibold tracking-widest uppercase mb-6">
      Durango, México
    </p>
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
      Producimos lo que<br class="hidden sm:block" />
      tu marca necesita<br class="hidden sm:block" />
      contar
    </h1>
    <p class="text-lg sm:text-xl text-white/70 font-medium max-w-xl mx-auto mb-10">
      Producción audiovisual y estrategia digital en Durango.
      Creamos contenido que conecta, convence y convierte.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#portafolio"
        class="px-8 py-4 bg-charcoal text-white font-bold rounded-full text-sm tracking-wide hover:bg-gray-800 transition-all duration-200 hover:-translate-y-0.5"
      >
        Ver nuestro trabajo
      </a>
      <a
        href="#contacto"
        class="px-8 py-4 border border-white/40 text-white font-bold rounded-full text-sm tracking-wide hover:bg-white/10 transition-all duration-200"
      >
        Hablemos
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40"
    aria-hidden="true"
  >
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-white/20 relative overflow-hidden">
      <div
        class="absolute top-0 left-0 w-full bg-charcoal"
        style="animation: scrollLine 2s ease-in-out infinite;"
      ></div>
    </div>
  </div>
</section>

<style>
  @keyframes scrollLine {
    0% { height: 0; top: 0; }
    50% { height: 100%; top: 0; }
    100% { height: 0; top: 100%; }
  }
</style>

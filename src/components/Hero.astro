---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-charcoal"
>
  <!-- Background -->
  <div class="absolute inset-0 bg-charcoal" aria-hidden="true">
    <!-- Subtle animated gradient -->
    <div class="hero-gradient absolute inset-0"></div>

    <!-- Giant logo brand mark -->
    <div class="absolute inset-0 flex items-center justify-center overflow-hidden pointer-events-none">
      <img
        src="/logo.png"
        alt=""
        aria-hidden="true"
        class="hero-brand-logo select-none"
      />
    </div>

    <!-- Vignette overlay -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(26,26,26,0) 0%, rgba(26,26,26,0.55) 75%, rgba(26,26,26,0.9) 100%);"></div>
  </div>

  <!-- Antemano wordmark (top) -->
  <div class="absolute top-6 left-1/2 -translate-x-1/2 z-20 hero-wordmark">
    <p class="text-white/60 text-[11px] font-semibold tracking-[0.4em] uppercase">Antemano</p>
  </div>

  <!-- Content -->
  <div
    id="hero-content"
    class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 text-center text-white"
  >
    <p class="hero-line text-gray-400 text-sm font-semibold tracking-widest uppercase mb-6" style="--i: 0;">
      Durango, México
    </p>
    <h1 class="hero-line text-4xl sm:text-5xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6" style="--i: 1;">
      Tu competencia ya está publicando.<br class="hidden sm:block" />
      Y se está quedando<br class="hidden sm:block" />
      con tus clientes.
    </h1>
    <p class="hero-line text-lg sm:text-xl text-white/70 font-medium max-w-2xl mx-auto mb-10" style="--i: 2;">
      Producimos el contenido. Diseñamos la estrategia. Tú recibes los clientes.
    </p>
    <div class="hero-line flex flex-col sm:flex-row gap-4 justify-center" style="--i: 3;">
      <span class="magnetic inline-block" data-magnetic="0.3">
        <a
          href="#resultados"
          class="hero-btn hero-btn-primary inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-charcoal font-bold rounded-full text-sm tracking-wide"
        >
          <span>Ver resultados</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.4" stroke="currentColor" class="w-4 h-4 hero-btn-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </span>
      <span class="magnetic inline-block" data-magnetic="0.3">
        <a
          href="#contacto"
          class="hero-btn hero-btn-ghost inline-flex items-center justify-center px-8 py-4 border border-white/40 text-white font-bold rounded-full text-sm tracking-wide"
        >
          Quiero una propuesta
        </a>
      </span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#servicios"
    class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 hover:text-white/80 transition-colors"
    aria-label="Scroll hacia abajo"
  >
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full bg-white/80" style="animation: scrollLine 2s var(--ease-in-out-quart, ease) infinite;"></div>
    </div>
  </a>
</section>

<style>
  /* ── Giant logo brand mark ── */
  .hero-brand-logo {
    width: clamp(28rem, 75vw, 62rem);
    height: auto;
    opacity: 0.08;
    filter: brightness(10) saturate(0);
    transform: translateY(4%);
    animation: brandFloat 12s ease-in-out infinite alternate, brandIn 1.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes brandFloat {
    0%   { transform: translateY(4%) scale(1); }
    100% { transform: translateY(2%) scale(1.03); }
  }
  @keyframes brandIn {
    from { opacity: 0; transform: translateY(10%) scale(0.94); }
    to   { opacity: 0.08; }
  }

  .hero-wordmark {
    animation: heroIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  /* ── Animated gradient BG (very subtle) ── */
  .hero-gradient {
    background:
      radial-gradient(circle at 20% 20%, rgba(255,255,255,0.04), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.03), transparent 50%);
    animation: heroPulse 8s ease-in-out infinite alternate;
  }
  @keyframes heroPulse {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.1) translate(2%, -1%); }
  }

  /* ── Scroll line ── */
  @keyframes scrollLine {
    0%, 100% { height: 0; top: 0; }
    50% { height: 100%; top: 0; }
    100% { height: 0; top: 100%; }
  }

  /* ── Scroll indicator breathing ── */
  .scroll-indicator {
    animation: scrollBreathe 3s ease-in-out infinite;
  }
  @keyframes scrollBreathe {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 6px); }
  }

  /* ── Hero text stagger entry ── */
  .hero-line {
    opacity: 0;
    transform: translateY(24px);
    animation: heroIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.2s + var(--i, 0) * 0.12s);
  }
  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Buttons ── */
  .hero-btn {
    transition: background 0.25s var(--ease-out-quart), color 0.25s var(--ease-out-quart), border-color 0.25s;
    position: relative;
  }
  .hero-btn-arrow {
    transition: transform 0.25s var(--ease-out-quart);
  }
  .hero-btn-primary:hover .hero-btn-arrow {
    transform: translateX(4px);
  }
  .hero-btn-primary:hover {
    background: #f4f4f4;
  }
  .hero-btn-ghost:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.8);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gradient, .scroll-indicator { animation: none !important; }
    .hero-line { opacity: 1; transform: none; animation: none; }
  }
</style>

---
const lines = [
  { html: 'Publicas <strong class="kw">cuando te acuerdas.</strong>', emphasis: false },
  { html: 'Tus fotos las toma <strong class="kw">alguien del equipo con el celular.</strong>', emphasis: false },
  { html: 'Tu competidor ya está <strong class="kw">en la mente de tus clientes.</strong> Tú todavía no.', emphasis: false },
  { html: '<strong class="kw">Tú llevas tres semanas sin publicar.</strong>', emphasis: false },
  { html: 'No es que no te importe.', emphasis: false },
  { html: 'Es que <strong class="kw">no tienes tiempo,</strong> no tienes equipo, y cada vez que lo intentas solo se ve... normal.', emphasis: false },
  { html: 'Mientras tanto, tus clientes potenciales están <strong class="kw">eligiendo al que sí se ve profesional.</strong>', emphasis: true },
];
---

<section id="problema" class="relative bg-white">
  <div class="max-w-2xl mx-auto px-6 lg:px-8 py-32 lg:py-48">
    <div class="flex flex-col gap-16 lg:gap-24">
      {lines.map((line, i) => (
        <p
          class={`problem-line text-xl sm:text-2xl lg:text-3xl font-medium leading-relaxed text-center ${line.emphasis ? 'font-bold text-charcoal' : 'text-charcoal'}`}
          data-index={i}
          set:html={line.html}
        />
      ))}
    </div>

    <div class="mt-24 text-center problem-cta">
      <a href="#servicios" class="inline-block text-lg font-bold text-gray-500 hover:text-charcoal transition-colors duration-300">
        Esto tiene solución &rarr;
      </a>
    </div>
  </div>
</section>

<style>
  /* Words start as faint ink and fill to full charcoal, scrubbed by
     scroll position (reversible) — the section reads itself as you move. */
  .problem-line :global(.pw) {
    opacity: 0.13;
    will-change: opacity;
  }
  .problem-cta {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s, transform 0.8s var(--ease-out-expo);
  }
  .problem-cta.emerged {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .problem-line :global(.pw) { opacity: 1 !important; }
    .problem-cta {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  const lines = Array.from(document.querySelectorAll<HTMLElement>('.problem-line'));
  const cta = document.querySelector<HTMLElement>('.problem-cta');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── CTA: simple one-time reveal ────────────────────────────────────
  if (cta) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('emerged'); io.disconnect(); }
      });
    }, { threshold: 0.5 });
    io.observe(cta);
  }

  // ── Scroll-scrubbed word-by-word ink fill ──────────────────────────
  if (!reduced && lines.length) {
    // Wrap every word in a span (preserving <strong class="kw"> children)
    function wrapWords(el: HTMLElement) {
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
      const nodes: Text[] = [];
      while (walker.nextNode()) nodes.push(walker.currentNode as Text);
      nodes.forEach((node) => {
        const parts = (node.textContent || '').split(/(\s+)/);
        if (parts.length <= 1) return;
        const frag = document.createDocumentFragment();
        parts.forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) {
            frag.appendChild(document.createTextNode(part));
          } else {
            const s = document.createElement('span');
            s.className = 'pw';
            s.textContent = part;
            frag.appendChild(s);
          }
        });
        node.parentNode?.replaceChild(frag, node);
      });
    }

    const lineWords = new Map<HTMLElement, HTMLElement[]>();
    lines.forEach((line) => {
      wrapWords(line);
      lineWords.set(line, Array.from(line.querySelectorAll<HTMLElement>('.pw')));
    });

    let raf = 0;
    function paint() {
      raf = 0;
      const vh = window.innerHeight;
      lines.forEach((line) => {
        const r = line.getBoundingClientRect();
        if (r.bottom < 0 || r.top > vh) return;
        // Progress: line starts filling in the lower third of the
        // viewport and completes just above center.
        const p = Math.min(Math.max((vh * 0.85 - r.top) / (vh * 0.45), 0), 1);
        const ws = lineWords.get(line)!;
        const n = ws.length;
        ws.forEach((w, i) => {
          const wp = Math.min(Math.max(p * n - i, 0), 1);
          w.style.opacity = (0.13 + 0.87 * wp).toFixed(3);
        });
      });
    }

    window.addEventListener('scroll', () => {
      if (!raf) raf = requestAnimationFrame(paint);
    }, { passive: true });
    window.addEventListener('resize', () => {
      if (!raf) raf = requestAnimationFrame(paint);
    }, { passive: true });
    paint();
  }
</script>

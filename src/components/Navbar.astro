---
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="#inicio" aria-label="Antemano Taller Creativo — inicio" class="flex-shrink-0">
      <!--
        El PNG original es 560×560 con mucho espacio vacío alrededor del logo.
        object-fit:cover + dimensiones ajustadas recortan ese espacio vacío
        mostrando solo la zona donde vive el logo real.
        object-position: center 52% apunta al centro exacto del logo.
      -->
      <img
        id="site-logo"
        src="/logo.png"
        alt="Antemano Taller Creativo"
        width="152"
        height="44"
        class="block"
        style="
          width: 152px;
          height: 44px;
          object-fit: cover;
          object-position: center 52%;
          /* inicio: sobre hero oscuro → logo blanco */
          filter: invert(1);
          mix-blend-mode: screen;
          transition: filter 0.3s ease;
        "
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium" id="nav-links">
      <li><a href="#servicios" class="nav-link transition-colors duration-200" style="color:#fff">Servicios</a></li>
      <li><a href="#portafolio" class="nav-link transition-colors duration-200" style="color:#fff">Portafolio</a></li>
      <li><a href="#nosotros" class="nav-link transition-colors duration-200" style="color:#fff">Nosotros</a></li>
      <li><a href="#proceso" class="nav-link transition-colors duration-200" style="color:#fff">Proceso</a></li>
      <li>
        <a
          href="#contacto"
          id="nav-cta"
          class="px-4 py-2 border rounded-full text-sm font-semibold transition-all duration-200 hover:bg-charcoal hover:border-charcoal hover:text-white"
          style="color:#fff; border-color: rgba(255,255,255,0.5);"
        >
          Hablemos
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="hamburger-line block w-6 h-0.5 transition-all duration-300" style="background:#fff"></span>
      <span class="hamburger-line block w-6 h-0.5 transition-all duration-300" style="background:#fff"></span>
      <span class="hamburger-line block w-6 h-0.5 transition-all duration-300" style="background:#fff"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-offwhite border-t border-gray-100 px-6 py-4"
  >
    <ul class="flex flex-col gap-4 text-sm font-medium text-charcoal">
      <li><a href="#servicios" class="mobile-link block py-1 hover:text-gray-400 transition-colors">Servicios</a></li>
      <li><a href="#portafolio" class="mobile-link block py-1 hover:text-gray-400 transition-colors">Portafolio</a></li>
      <li><a href="#nosotros" class="mobile-link block py-1 hover:text-gray-400 transition-colors">Nosotros</a></li>
      <li><a href="#proceso" class="mobile-link block py-1 hover:text-gray-400 transition-colors">Proceso</a></li>
      <li>
        <a href="#contacto" class="mobile-link inline-block mt-1 px-4 py-2 bg-charcoal text-white rounded-full text-sm font-semibold hover:bg-gray-700 transition-colors">
          Hablemos
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar  = document.getElementById('navbar')!;
  const logo    = document.getElementById('site-logo') as HTMLImageElement;
  const links   = document.querySelectorAll<HTMLElement>('.nav-link');
  const cta     = document.getElementById('nav-cta') as HTMLAnchorElement;
  const lines   = document.querySelectorAll<HTMLElement>('.hamburger-line');
  const toggle  = document.getElementById('menu-toggle')!;
  const mobile  = document.getElementById('mobile-menu')!;

  function updateNavbar() {
    const scrolled = window.scrollY > 60;

    if (scrolled) {
      navbar.classList.add('bg-offwhite', 'shadow-sm');
      // Logo negro normal sobre fondo blanco (sin filtro)
      logo.style.filter      = 'none';
      logo.style.mixBlendMode = 'normal';
      links.forEach(l => { l.style.color = '#1A1A1A'; });
      cta.style.color       = '#1A1A1A';
      cta.style.borderColor = '#1A1A1A';
      lines.forEach(l => { l.style.background = '#1A1A1A'; });
    } else {
      navbar.classList.remove('bg-offwhite', 'shadow-sm');
      // Logo blanco sobre hero oscuro: invert → blanco; screen → fondo transparente
      logo.style.filter      = 'invert(1)';
      logo.style.mixBlendMode = 'screen';
      links.forEach(l => { l.style.color = '#fff'; });
      cta.style.color       = '#fff';
      cta.style.borderColor = 'rgba(255,255,255,0.5)';
      lines.forEach(l => { l.style.background = '#fff'; });
    }
  }

  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  toggle.addEventListener('click', () => {
    const open = !mobile.classList.contains('hidden');
    mobile.classList.toggle('hidden', open);
    toggle.setAttribute('aria-expanded', String(!open));
  });

  mobile.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobile.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>

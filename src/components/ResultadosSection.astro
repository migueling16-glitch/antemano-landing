  { url: 'https://www.instagram.com/p/DENqmDTyBTj/', client: 'CLIENTE', metric: 'MÉTRICA' },
  { url: 'https://www.instagram.com/p/DWC_oKQDaIP/', client: 'CLIENTE', metric: 'MÉTRICA' },
];
---

<section id="resultados" class="relative py-24 lg:py-32 overflow-hidden" style="background: #F5F5F5;">
  <!-- Logo watermark -->
  <img
    src="/logo.png"
    alt=""
    aria-hidden="true"
    class="resultados-watermark select-none pointer-events-none"
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-xl mx-auto mb-14">
      <p class="text-gray-400 text-sm font-semibold tracking-widest uppercase mb-3 reveal">
        Casos de éxito
      </p>
      <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-charcoal reveal reveal-delay-1">
        No te pedimos que nos creas. Mira los números.
      </h2>
      <p class="text-gray-500 mt-3 text-base reveal reveal-delay-2">
        Posts que produjimos para nuestros clientes. Engagement real, no comprado.
      </p>
    </div>

    <!-- Carousel outer -->
    <div class="relative">

      <!-- Prev arrow (desktop only) -->
      <button
        id="res-prev"
        class="absolute left-0 top-[240px] z-10 -translate-x-5 w-10 h-10 rounded-full bg-white border border-gray-200 shadow-sm items-center justify-center hover:border-charcoal transition-colors hidden md:flex"
        aria-label="Anterior"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>

      <!-- Scrollable track -->
      <div
        id="res-track"
        class="flex gap-5 overflow-x-auto snap-x snap-mandatory pb-3"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {posts.map((post) => (
          <div class="snap-start flex-shrink-0 flex flex-col gap-3 res-card">

            <!-- Embed wrapper -->
            <div
              class="rounded-2xl overflow-hidden border border-gray-200 bg-gray-50 relative"
              style="height: 520px;"
            >
              <!-- Fallback: always shown behind the embed -->
              <div class="ig-fallback absolute inset-0 flex flex-col items-center justify-center gap-4 bg-gray-50 rounded-2xl">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-9 h-9 text-gray-300">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <a
                  href={post.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-semibold text-gray-400 hover:text-charcoal transition-colors"
                >
                  Ver en Instagram ↗
                </a>
              </div>

              <!-- Instagram embed (activated lazily) -->
              <blockquote
                class="ig-lazy"
                data-instgrm-permalink={post.url}
                data-instgrm-version="14"
                style="background: #fff; border: 0; margin: 0; padding: 0; width: 100%; position: relative; z-index: 1; min-width: 0 !important;"
              >
                <a href={post.url} target="_blank" rel="noopener noreferrer" style="font-size: 0;">Ver en Instagram</a>
              </blockquote>
            </div>

            <!-- Client / metric caption -->
            <p class="text-xs font-semibold text-gray-400 tracking-widest uppercase text-center px-1">
              [{post.client} — {post.metric}]
            </p>
          </div>
        ))}
      </div>

      <!-- Next arrow (desktop only) -->
      <button
        id="res-next"
        class="absolute right-0 top-[240px] z-10 translate-x-5 w-10 h-10 rounded-full bg-white border border-gray-200 shadow-sm items-center justify-center hover:border-charcoal transition-colors hidden md:flex"
        aria-label="Siguiente"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  #res-track::-webkit-scrollbar { display: none; }

  #res-track { scroll-behavior: smooth; cursor: grab; }
  #res-track.dragging { cursor: grabbing; scroll-behavior: auto; user-select: none; }
  #res-track.dragging * { pointer-events: none; }

  /* Card widths: almost full on mobile, ~300px on desktop */
  .res-card {
    width: min(calc(100vw - 64px), 320px);
    transition: transform 0.35s var(--ease-out-quart);
  }
  .res-card:hover {
    transform: translateY(-4px);
  }

  /* Force Instagram iframe to fill container */
  .res-card .instagram-media {
    min-width: 0 !important;
    width: 100% !important;
  }
  .res-card iframe {
    width: 100% !important;
  }

  /* Logo watermark */
  .resultados-watermark {
    position: absolute;
    top: 5%;
    right: -8%;
    width: min(55vh, 38vw);
    height: auto;
    opacity: 0.035;
    filter: brightness(0);
    transform: rotate(-5deg);
    z-index: 0;
  }
</style>

<script>
  const section = document.getElementById('resultados')!;
  const track = document.getElementById('res-track')!;
  const prevBtn = document.getElementById('res-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('res-next') as HTMLButtonElement;

  // ─── Lazy-load Instagram embeds ───────────────────────────────────────────
  const igObserver = new IntersectionObserver(
    (entries) => {
      if (!entries[0].isIntersecting) return;
      igObserver.disconnect();

      // Activate all pending embeds
      section.querySelectorAll<HTMLElement>('.ig-lazy').forEach((el) => {
        el.classList.replace('ig-lazy', 'instagram-media');
      });

      // Load or re-run the script
      const w = window as any;
      if (w.instgrm) {
        w.instgrm.Embeds.process();
      } else {
        const s = document.createElement('script');
        s.async = true;
        s.src = '//www.instagram.com/embed.js';
        s.onload = () => w.instgrm?.Embeds.process();
        document.body.appendChild(s);
      }
    },
    { threshold: 0.05 }
  );
  igObserver.observe(section);

  // ─── Drag to scroll (desktop mouse) ──────────────────────────────────────
  let isDown = false;
  let startX = 0;
  let startScroll = 0;

  track.addEventListener('mousedown', (e) => {
    // Don't hijack clicks on links/iframes — only plain drag
    const target = e.target as HTMLElement;
    if (target.closest('a, iframe, blockquote')) return;
    isDown = true;
    track.classList.add('dragging');
    startX = e.pageX - track.offsetLeft;
    startScroll = track.scrollLeft;
    e.preventDefault();
  });
  window.addEventListener('mouseup', () => {
    isDown = false;
    track.classList.remove('dragging');
  });
  track.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    const x = e.pageX - track.offsetLeft;
    const walk = (x - startX) * 1.3;
    track.scrollLeft = startScroll - walk;
  });

  // ─── Arrow navigation ─────────────────────────────────────────────────────
  function cardWidth(): number {
    const first = track.querySelector<HTMLElement>('.res-card');
    return first ? first.offsetWidth + 20 : 340; // 20 = gap-5
  }

  prevBtn?.addEventListener('click', () =>
    track.scrollBy({ left: -cardWidth() * 2, behavior: 'smooth' })
  );
  nextBtn?.addEventListener('click', () =>
    track.scrollBy({ left: cardWidth() * 2, behavior: 'smooth' })
  );

  function updateArrows() {
    if (!prevBtn || !nextBtn) return;
    prevBtn.disabled = track.scrollLeft <= 2;
    nextBtn.disabled =
      track.scrollLeft + track.clientWidth >= track.scrollWidth - 4;
  }

  track.addEventListener('scroll', updateArrows, { passive: true });
  // Small delay so layout is settled before first check
  requestAnimationFrame(updateArrows);
</script>

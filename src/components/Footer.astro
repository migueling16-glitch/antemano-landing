---
const year = new Date().getFullYear();
const navLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Portafolio', href: '#portafolio' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Testimonios', href: '#testimonios' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-charcoal text-white py-14">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-1 flex flex-col gap-4">
        <img
          src="/logo.png"
          alt="Antemano Taller Creativo"
          width="152"
          height="44"
          style="width:152px;height:44px;object-fit:cover;object-position:center 52%;filter:invert(1);mix-blend-mode:screen;"
        />
        <p class="text-white/40 text-sm leading-relaxed max-w-xs">
          Producción audiovisual y estrategia digital con raíces en Durango, México.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">
          Navegación
        </h3>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/70 hover:text-gray-400 transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact summary -->
      <div>
        <h3 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">
          Contacto
        </h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li>
            <a href="mailto:antemanotallercreativo@gmail.com" class="hover:text-gray-400 transition-colors duration-200">
              antemanotallercreativo@gmail.com
            </a>
          </li>
          <li>
            <a href="tel:+526181539643" class="hover:text-gray-400 transition-colors duration-200">
              +52 618 153 9643
            </a>
          </li>
          <li class="text-white/40">Durango, Dgo., México</li>
        </ul>

        <!-- Social links -->
        <div class="flex gap-3 mt-5">
          <a href="https://www.instagram.com/antemanomx/" target="_blank" class="text-white/40 hover:text-gray-400 transition-colors" aria-label="Instagram" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/30">
      <p>© {year} Antemano Taller Creativo. Todos los derechos reservados.</p>
      <p>Hecho con cuidado en Durango, México</p>
    </div>
  </div>
</footer>

---
const cases = [
  {
    specialty: 'Cardiólogo intervencionista',
    location: 'Durango',
    metrics: [
      { before: '3,200 seguidores', after: '18,400 seguidores' },
      { before: '0 pacientes/mes digitales', after: '12 pacientes/mes desde Instagram' },
      { before: 'Respuesta en horas', after: '2 min respuesta (automático)' },
      { before: 'Sin lista de espera', after: '3 semanas de espera para cita' },
    ],
  },
  {
    specialty: 'Dermatóloga estética',
    location: 'Monterrey',
    metrics: [
      { before: 'Contenido inconsistente', after: '+50K vistas en 5 reels orgánicos' },
      { before: 'Agenda variable', after: '100% ocupación · 4 meses consecutivos' },
      { before: 'No-shows: 31%', after: 'No-shows: 9% con sistema activo' },
      { before: 'Crecimiento plano', after: '+40% pacientes nuevos vs año anterior' },
    ],
  },
  {
    specialty: 'Cirujano plástico reconstructivo',
    location: 'CDMX',
    metrics: [
      { before: 'Sin presencia local', after: '#1 en búsquedas locales por especialidad' },
      { before: '11 reseñas Google', after: '94 reseñas en 6 meses' },
      { before: 'Solo referidos', after: '47 consultas/mes digitales' },
      { before: 'Costo de adquisición alto', after: '-60% costo por paciente nuevo' },
    ],
  },
];
---

<section id="resultados" class="py-24 lg:py-32 bg-offwhite relative">
  <span class="section-line absolute top-0 left-6 right-6 lg:left-8 lg:right-8 z-10" aria-hidden="true"></span>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-3xl mb-16">
      <p class="text-[11px] font-bold tracking-[0.22em] uppercase mb-4 text-charcoal/40 blur-reveal">
        No tienes que confiar en nuestra palabra
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-charcoal mb-6 blur-reveal" style="--brd:1">
        Lo que pasa cuando el sistema funciona.
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed blur-reveal" style="--brd:2">
        Por respeto a la privacidad de nuestros clientes, no mostramos nombres ni rostros. Los números son reales.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {cases.map((c, i) => (
        <article
          class="blur-reveal med-case-card med-glass med-grain-hover p-8 rounded-2xl flex flex-col relative overflow-hidden"
          style={`--brd:${i}`}
        >
          <div class="med-grain absolute inset-0"></div>

          <!-- Header -->
          <div class="flex items-center gap-3 mb-4 relative z-10">
            <span class="med-pulse-dot"></span>
            <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-gray-400">
              Caso {String(i + 1).padStart(2, '0')}
            </p>
          </div>

          <!-- Specialty + location -->
          <h3 class="text-xl font-black text-charcoal leading-tight mb-1 relative z-10">
            {c.specialty}
          </h3>
          <span class="inline-flex items-center gap-1 text-[10px] font-bold tracking-[0.12em] uppercase text-charcoal/40 mb-5 relative z-10">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
              <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.145 14.19 14.19 0 0 0 3.14-2.432C15.149 14.869 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.851 5.869 3.245 7.345a14.19 14.19 0 0 0 3.14 2.432 5.739 5.739 0 0 0 .282.145l.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
            </svg>
            {c.location}
          </span>

          <!-- Divider -->
          <hr class="border-charcoal/15 mb-5 relative z-10" />

          <!-- Métricas grid 2x2 -->
          <div class="grid grid-cols-2 gap-4 flex-1 relative z-10">
            {c.metrics.map(m => (
              <div>
                <p class="line-through text-gray-400 text-xs mb-1 leading-snug">{m.before}</p>
                <p class="font-black text-charcoal text-sm leading-snug">{m.after}</p>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>

    <!-- Disclaimer -->
    <p class="text-xs text-gray-400 text-center mt-10 max-w-2xl mx-auto blur-reveal">
      Los resultados corresponden a casos reales con identidad reservada. No garantizamos resultados idénticos — sí garantizamos que si no hay resultados, te devolvemos tu inversión.
    </p>
  </div>
</section>

<style>
  .med-case-card {
    transition:
      transform 0.4s var(--ease-out-quart),
      border-color 0.3s,
      box-shadow 0.4s var(--ease-out-quart);
    position: relative;
    overflow: hidden;
  }
  .med-case-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255,255,255,0.85);
    box-shadow:
      0 28px 48px -20px rgba(0,0,0,0.16),
      0 1px 0 rgba(255,255,255,0.8) inset;
    background-color: rgba(255,255,255,0.72);
  }
</style>

---
// Métricas ilustrativas. Miguel las reemplaza con casos reales conforme los tenga.
const cases = [
  {
    specialty: 'Cardiólogo intervencionista',
    metrics: [
      '3,200 → 18,400 seguidores en 6 meses',
      '12 nuevos pacientes/mes generados desde Instagram',
      'Lista de espera de 3 semanas',
    ],
  },
  {
    specialty: 'Dermatóloga estética',
    metrics: [
      '5 reels con +50,000 vistas',
      'Agenda llena al 100% durante 4 meses consecutivos',
      'Aumento de 40% en pacientes nuevos por mes',
    ],
  },
  {
    specialty: 'Cirujano plástico reconstructivo',
    metrics: [
      '47 consultas mensuales generadas online',
      'Reducción de 60% en costo por adquisición de paciente',
      'Posicionado como #1 en búsquedas locales',
    ],
  },
];
---

<section id="resultados" class="py-24 lg:py-32 bg-offwhite">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mb-16">
      <p class="text-amber text-xs font-bold tracking-[0.2em] uppercase mb-4 reveal">
        No tienes que confiar en nuestra palabra
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-charcoal mb-6 reveal reveal-delay-1">
        Resultados reales con doctores reales.
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed reveal reveal-delay-2">
        Por respeto a la privacidad de nuestros clientes médicos, no mostramos nombres ni rostros. Pero sí podemos mostrar <strong class="kw">lo que pasa cuando un especialista decide invertir en su presencia digital</strong> con nosotros.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {cases.map((c, i) => (
        <article
          class={`reveal-up reveal-delay-${i + 1} med-case-card p-8 bg-white border border-gray-100 rounded-2xl flex flex-col`}
        >
          <!-- Header -->
          <div class="flex items-center gap-3 mb-6">
            <span class="med-case-dot w-2 h-2 rounded-full bg-amber"></span>
            <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-gray-400">
              Caso {String(i + 1).padStart(2, '0')}
            </p>
          </div>

          <!-- Specialty -->
          <h3 class="text-2xl font-black text-charcoal mb-6 leading-tight">
            {c.specialty}
          </h3>

          <!-- Divider -->
          <div class="w-8 h-px bg-amber mb-6"></div>

          <!-- Metrics -->
          <ul class="space-y-4 flex-1">
            {c.metrics.map((m) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#C8963E" stroke-width="2.2" class="w-4 h-4 mt-0.5 flex-shrink-0">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
                </svg>
                <span class="text-sm text-gray-700 leading-snug font-medium">{m}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <!-- Disclaimer footnote -->
    <p class="text-xs text-gray-400 text-center mt-10 max-w-2xl mx-auto reveal">
      Los resultados presentados corresponden a casos reales con identidad reservada por confidencialidad profesional. No garantizamos resultados idénticos — cada consultorio tiene su propia realidad.
    </p>
  </div>
</section>

<style>
  .med-case-card {
    transition:
      transform 0.4s var(--ease-out-quart),
      border-color 0.3s,
      box-shadow 0.4s var(--ease-out-quart);
    position: relative;
    overflow: hidden;
  }
  .med-case-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    box-shadow: 0 0 0 0 rgba(200,150,62,0.3) inset;
    pointer-events: none;
    transition: box-shadow 0.4s var(--ease-out-quart);
  }
  .med-case-card:hover {
    transform: translateY(-6px);
    border-color: #C8963E;
    box-shadow: 0 28px 48px -20px rgba(0,0,0,0.14);
  }
  .med-case-card:hover .med-case-dot {
    transform: scale(1.6);
    box-shadow: 0 0 0 6px rgba(200,150,62,0.18);
  }
  .med-case-dot {
    transition: transform 0.3s var(--ease-out-quart), box-shadow 0.3s;
  }
</style>

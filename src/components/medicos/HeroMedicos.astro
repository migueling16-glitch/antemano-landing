---
---

<section
  id="inicio"
  class="relative min-h-[92vh] flex items-center overflow-hidden bg-offwhite pt-24"
>
  <!-- Soft background accent -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="med-hero-accent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-center">
      <!-- Text column (60% = 3/5) -->
      <div class="lg:col-span-3">
        <p class="med-hero-line text-amber text-xs font-bold tracking-[0.2em] uppercase mb-6" style="--i:0">
          Antemano para especialistas médicos
        </p>

        <h1 class="med-hero-line text-4xl sm:text-5xl lg:text-[4rem] font-black leading-[1.05] tracking-tight text-charcoal mb-6" style="--i:1">
          Tus pacientes te buscan en Google antes de marcarte.
          <span class="block text-amber mt-2">La pregunta es qué encuentran.</span>
        </h1>

        <p class="med-hero-line text-lg sm:text-xl text-gray-500 font-medium leading-relaxed max-w-2xl mb-10" style="--i:2">
          Hacemos que tu presencia digital trabaje para llenar tu agenda — sin que tú tengas que pensar en redes sociales.
        </p>

        <div class="med-hero-line flex flex-col sm:flex-row gap-4 items-start sm:items-center" style="--i:3">
          <span class="magnetic inline-block" data-magnetic="0.25">
            <a
              href="#agendar"
              class="med-hero-cta inline-flex items-center justify-center gap-2 px-8 py-4 bg-amber text-white font-bold rounded-full text-sm tracking-wide"
            >
              Agendar llamada de descubrimiento
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.4" stroke="currentColor" class="w-4 h-4 med-hero-arrow">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </span>
          <p class="text-xs text-gray-400 sm:ml-2">
            Llamada de 30 minutos. Sin compromiso. Sin venta agresiva.
          </p>
        </div>
      </div>

      <!-- Visual column (40% = 2/5) — abstract composition en lugar de stock -->
      <div class="med-hero-line hidden lg:block lg:col-span-2" style="--i:4">
        <div class="med-hero-visual relative">
          <!-- Mock profile card -->
          <div class="med-mock-card absolute top-6 right-0 w-[85%] p-5 bg-white rounded-2xl border border-gray-100 shadow-lg">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full bg-charcoal/10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="1.5" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
              </div>
              <div>
                <div class="h-2 w-24 bg-charcoal/70 rounded-full"></div>
                <div class="h-1.5 w-16 bg-gray-200 rounded-full mt-1.5"></div>
              </div>
            </div>
            <div class="h-1.5 w-full bg-gray-100 rounded-full mb-2"></div>
            <div class="h-1.5 w-[75%] bg-gray-100 rounded-full mb-3"></div>
            <div class="flex items-center gap-1 text-amber">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              <span class="text-[10px] text-gray-400 ml-1 font-semibold">5.0</span>
            </div>
          </div>

          <!-- Mock chart card -->
          <div class="med-mock-card med-mock-card-2 absolute bottom-6 left-0 w-[75%] p-5 bg-charcoal text-white rounded-2xl shadow-xl">
            <p class="text-[10px] font-bold tracking-[0.15em] uppercase text-white/50 mb-3">Consultas online · últimos 6 meses</p>
            <div class="flex items-end gap-2 h-16">
              <div class="flex-1 bg-white/20 rounded-sm" style="height:20%"></div>
              <div class="flex-1 bg-white/30 rounded-sm" style="height:32%"></div>
              <div class="flex-1 bg-white/40 rounded-sm" style="height:48%"></div>
              <div class="flex-1 bg-white/55 rounded-sm" style="height:58%"></div>
              <div class="flex-1 bg-white/70 rounded-sm" style="height:80%"></div>
              <div class="flex-1 bg-amber rounded-sm" style="height:100%"></div>
            </div>
          </div>

          <!-- Spacer to hold height -->
          <div class="aspect-[4/5]"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .med-hero-accent {
    position: absolute;
    top: -30%;
    right: -15%;
    width: 70vw;
    height: 70vw;
    max-width: 900px;
    max-height: 900px;
    background: radial-gradient(circle at center, rgba(200,150,62,0.10) 0%, rgba(200,150,62,0) 70%);
    border-radius: 9999px;
    pointer-events: none;
  }

  .med-hero-line {
    opacity: 0;
    transform: translateY(24px);
    animation: medHeroIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.15s + var(--i, 0) * 0.11s);
  }
  @keyframes medHeroIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .med-hero-cta {
    transition:
      background 0.25s var(--ease-out-quart),
      box-shadow 0.25s,
      transform 0.2s;
    box-shadow: 0 10px 22px -8px rgba(200,150,62,0.45);
  }
  .med-hero-cta:hover {
    background: #b2832f;
    box-shadow: 0 14px 28px -8px rgba(200,150,62,0.6);
  }
  .med-hero-arrow { transition: transform 0.25s var(--ease-out-quart); }
  .med-hero-cta:hover .med-hero-arrow { transform: translateX(4px); }

  /* Mock cards */
  .med-mock-card {
    transition: transform 0.6s var(--ease-out-quart);
  }
  .med-hero-visual:hover .med-mock-card {
    transform: translateY(-4px) rotate(-1deg);
  }
  .med-hero-visual:hover .med-mock-card-2 {
    transform: translateY(4px) rotate(1deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .med-hero-line { opacity: 1; transform: none; animation: none; }
  }
</style>

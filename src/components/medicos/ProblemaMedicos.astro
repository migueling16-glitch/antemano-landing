---
// Estadísticas ilustrativas. Miguel puede reemplazarlas con fuentes verificadas.
const stats = [
  {
    number: '77%',
    text: 'de los pacientes investiga en internet antes de elegir un médico especialista',
  },
  {
    number: '1 de 3',
    text: 'doctores pierde pacientes potenciales por una mala presencia digital',
  },
  {
    number: '94%',
    text: 'de las personas confía más en un especialista con reseñas y contenido visible',
  },
];
---

<section id="problema" class="py-24 lg:py-32 bg-white relative overflow-hidden">
  <!-- Draw line -->
  <span class="section-line absolute top-0 left-6 right-6 lg:left-8 lg:right-8 z-10" aria-hidden="true"></span>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mb-16">
      <p class="text-[11px] font-bold tracking-[0.22em] uppercase mb-4 text-charcoal/40 reveal">
        La realidad del sector salud en 2026
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-charcoal reveal reveal-delay-1">
        Tus pacientes ya no eligen como antes.
      </h2>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">
      {stats.map((s, i) => (
        <article
          class={`med-stat-card med-glass-ghost med-grain-hover p-8 rounded-2xl relative overflow-hidden stat-card-enter`}
          style={`--ci:${i}`}
        >
          <div class="med-grain absolute inset-0"></div>
          <p
            class="med-stat-number med-text-textured text-5xl lg:text-6xl font-black leading-none mb-5 tracking-tight relative z-10"
            data-count-target={s.number}
          >
            {s.number}
          </p>
          <p class="text-gray-500 text-sm leading-relaxed relative z-10">
            {s.text}
          </p>
        </article>
      ))}
    </div>

    <!-- Closing text -->
    <div class="max-w-3xl space-y-4 text-gray-600 text-lg leading-relaxed reveal reveal-delay-2">
      <p>
        No es que necesites más marketing. Necesitas que tu presencia digital esté <strong class="kw">a la altura de tu práctica clínica.</strong>
      </p>
      <p>
        El paciente que te busca en Instagram y encuentra un perfil sin actualizar va a marcarle al de la competencia. Aunque tú seas mejor médico.
      </p>
    </div>
  </div>
</section>

<style>
  /* 3D + motion-blur entry */
  .stat-card-enter {
    opacity: 0;
    filter: blur(24px);
    transform: perspective(700px) rotateX(16deg) translateY(36px) scale(0.97);
    transition:
      opacity   0.85s var(--ease-out-expo),
      filter    0.65s cubic-bezier(0.22, 1, 0.36, 1),  /* blur clears first */
      transform 0.85s var(--ease-out-expo);
    transition-delay: calc(var(--ci, 0) * 0.13s + 0.05s);
    will-change: filter, transform, opacity;
  }
  .stat-card-enter.visible {
    opacity: 1;
    filter: blur(0px);
    transform: perspective(700px) rotateX(0deg) translateY(0) scale(1);
  }

  .med-stat-card {
    transition:
      transform 0.4s var(--ease-out-quart),
      border-color 0.3s,
      box-shadow 0.4s var(--ease-out-quart);
    position: relative;
    overflow: hidden;
  }
  .med-stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    height: 2px; width: 0;
    background: #1A1A1A;
    transition: width 0.55s var(--ease-out-quart);
    z-index: 10;
  }
  .med-stat-card:hover {
    transform: translateY(-4px);
    border-color: rgba(26,26,26,0.18);
    box-shadow: 0 24px 48px -16px rgba(0,0,0,0.12);
    background-color: rgba(255,255,255,0.65);
  }
  .med-stat-card:hover::before { width: 100%; }

  /* .med-stat-number styles now come from global .med-text-textured */

  @media (prefers-reduced-motion: reduce) {
    .stat-card-enter { opacity: 1; filter: none; transform: none; transition: none; }
  }
</style>

<script>
  (() => {
    /* ── Intersection observer: 3D card enter + number counter ── */
    const cards = document.querySelectorAll<HTMLElement>('.stat-card-enter');
    if (!cards.length) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const card = entry.target as HTMLElement;
        card.classList.add('visible');

        // Counter animation
        const numEl = card.querySelector<HTMLElement>('[data-count-target]');
        if (!numEl) return;
        const raw = numEl.dataset.countTarget ?? '';

        // Parse: "77%" → {value:77, suffix:'%'}, "1 de 3" → skip
        const match = raw.match(/^(\d+)(.*)/);
        if (!match) return;
        const target = parseInt(match[1], 10);
        const suffix = raw.slice(match[1].length);

        const duration = 1400;
        const start = performance.now();
        const ease = (t: number) => 1 - Math.pow(1 - t, 3); // ease-out-cubic

        function step(now: number) {
          const t = Math.min((now - start) / duration, 1);
          const val = Math.round(ease(t) * target);
          numEl.textContent = val + suffix;
          if (t < 1) requestAnimationFrame(step);
        }

        // Small delay matching card entrance delay
        const delay = (parseInt(card.style.getPropertyValue('--ci') || '0', 10) * 120) + 200;
        setTimeout(() => requestAnimationFrame(step), delay);

        obs.unobserve(card);
      });
    }, { threshold: 0.25 });

    cards.forEach(c => obs.observe(c));
  })();
</script>

---
const items = [
  'Producción de video',
  'Fotografía',
  'Estrategia digital',
  'Reels',
  'Branding',
  'Community management',
  'Spots publicitarios',
  'Contenido que vende',
];
---

<section class="marquee-band" aria-hidden="true">
  <div class="marquee-skew sv-skew">
    <div class="marquee-row" id="marquee-row">
      <div class="marquee-group">
        {items.map((t) => (
          <span class="marquee-item">
            {t}
            <span class="marquee-star">✦</span>
          </span>
        ))}
      </div>
      <div class="marquee-group">
        {items.map((t) => (
          <span class="marquee-item">
            {t}
            <span class="marquee-star">✦</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-band {
    background: #1a1a1a;
    color: #fff;
    overflow: hidden;
    padding: 1.6rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .marquee-skew {
    transition: transform 0.12s linear;
  }
  .marquee-row {
    display: flex;
    width: max-content;
    will-change: transform;
  }
  .marquee-group {
    display: flex;
    flex-shrink: 0;
  }
  .marquee-item {
    display: inline-flex;
    align-items: center;
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    white-space: nowrap;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.55);
    transition: color 0.3s var(--ease-out-quart), -webkit-text-stroke-color 0.3s;
  }
  /* Alternate solid / outline for rhythm */
  .marquee-item:nth-child(even) {
    color: #fff;
    -webkit-text-stroke: 1px transparent;
  }
  .marquee-band:hover .marquee-item {
    color: #fff;
    -webkit-text-stroke-color: transparent;
  }
  .marquee-star {
    display: inline-block;
    margin: 0 1.4rem;
    font-size: 0.55em;
    color: rgba(255, 255, 255, 0.4);
    transform: translateY(-0.15em);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-skew { transform: none !important; }
  }
</style>

<script>
  const row = document.getElementById('marquee-row');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (row && !reduced) {
    const group = row.querySelector<HTMLElement>('.marquee-group')!;
    let groupWidth = group.offsetWidth;
    let pos = 0;
    let last = performance.now();

    const measure = () => { groupWidth = group.offsetWidth; };
    window.addEventListener('resize', measure, { passive: true });
    // Re-measure once fonts settle
    if ((document as any).fonts?.ready) {
      (document as any).fonts.ready.then(measure);
    }
    setTimeout(measure, 600);

    function frame(now: number) {
      const dt = Math.min(now - last, 50);
      last = now;

      const sv = (window as any).__sv || 0;        // scroll velocity
      const base = 0.035;                            // px per ms — gentle drift
      const boost = Math.min(Math.abs(sv) * 0.013, 0.55);
      const speed = base + boost;

      // Direction follows scroll: scroll down → left, up → right
      const dir = sv > 0.4 ? -1 : sv < -0.4 ? 1 : -1;
      pos += dir * speed * dt;

      // Seamless wrap
      if (groupWidth > 0) {
        if (pos <= -groupWidth) pos += groupWidth;
        else if (pos > 0) pos -= groupWidth;
      }

      row!.style.transform = `translateX(${pos}px)`;
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
</script>

---
// Editorial kinetic band — alternates black sans and serif italic,
// Blu-style "ideas // brands." typography mixing, adapted to B&W.
const items = [
  { t: 'Producción de video', serif: false },
  { t: 'fotografía', serif: true },
  { t: 'Estrategia digital', serif: false },
  { t: 'reels', serif: true },
  { t: 'Branding', serif: false },
  { t: 'marca persona', serif: true },
  { t: 'Spots publicitarios', serif: false },
  { t: 'contenido que vende', serif: true },
];
---

<section class="marquee-band" aria-hidden="true">
  <div class="marquee-skew sv-skew">
    <div class="marquee-row" id="marquee-row">
      <div class="marquee-group">
        {items.map((it) => (
          <span class={`marquee-item ${it.serif ? 'mq-serif' : 'mq-sans'}`}>
            {it.t}
            <span class="mq-sep">/</span>
          </span>
        ))}
      </div>
      <div class="marquee-group">
        {items.map((it) => (
          <span class={`marquee-item ${it.serif ? 'mq-serif' : 'mq-sans'}`}>
            {it.t}
            <span class="mq-sep">/</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-band {
    background: #1a1a1a;
    color: #fff;
    overflow: hidden;
    padding: 2rem 0 2.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .marquee-skew {
    transition: transform 0.12s linear;
  }
  .marquee-row {
    display: flex;
    width: max-content;
    will-change: transform;
  }
  .marquee-group {
    display: flex;
    flex-shrink: 0;
    align-items: baseline;
  }
  .marquee-item {
    display: inline-flex;
    align-items: baseline;
    font-size: clamp(2rem, 5vw, 3.6rem);
    white-space: nowrap;
    color: #fff;
  }
  .mq-sans {
    font-weight: 900;
    letter-spacing: -0.025em;
    text-transform: uppercase;
  }
  .mq-serif {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.1rem, 5.4vw, 3.9rem);
    color: rgba(255, 255, 255, 0.9);
  }
  .mq-sep {
    font-family: 'Inter', sans-serif;
    font-style: normal;
    font-weight: 200;
    font-size: 0.75em;
    color: rgba(255, 255, 255, 0.22);
    margin: 0 1.5rem;
    transform: translateY(-0.05em);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-skew { transform: none !important; }
  }
</style>

<script>
  const row = document.getElementById('marquee-row');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (row && !reduced) {
    const group = row.querySelector<HTMLElement>('.marquee-group')!;
    let groupWidth = group.offsetWidth;
    let pos = 0;
    let last = performance.now();

    const measure = () => { groupWidth = group.offsetWidth; };
    window.addEventListener('resize', measure, { passive: true });
    // Re-measure once fonts settle
    if ((document as any).fonts?.ready) {
      (document as any).fonts.ready.then(measure);
    }
    setTimeout(measure, 600);

    function frame(now: number) {
      const dt = Math.min(now - last, 50);
      last = now;

      const sv = (window as any).__sv || 0;        // scroll velocity
      const base = 0.035;                            // px per ms — gentle drift
      const boost = Math.min(Math.abs(sv) * 0.013, 0.55);
      const speed = base + boost;

      // Direction follows scroll: scroll down → left, up → right
      const dir = sv > 0.4 ? -1 : sv < -0.4 ? 1 : -1;
      pos += dir * speed * dt;

      // Seamless wrap
      if (groupWidth > 0) {
        if (pos <= -groupWidth) pos += groupWidth;
        else if (pos > 0) pos -= groupWidth;
      }

      row!.style.transform = `translateX(${pos}px)`;
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }
</script>

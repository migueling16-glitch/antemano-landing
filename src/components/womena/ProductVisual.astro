---
// Representación SVG del packaging real de cada producto (ref. brandbook pp. 29-39).
// id 1: tubo pulpa cream (Gentle Relief) · id 2: mist gris (Intimate Balance)
// id 3: botella aluminio con gatillo (Inner Flow) · id 4: sticks terra (Mineral Restore)
interface Props {
  id: number;
  name: string;
}
const { id, name } = Astro.props;

// Trazo "W" del isotipo — gesto orgánico de la marca
const squiggle =
  'M0 42 C6 10, 18 6, 22 26 C26 44, 36 46, 42 26 C46 12, 55 11, 58 25 C61 40, 70 36, 76 18';
---

<svg
  viewBox="0 0 300 375"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={`Empaque de ${name}`}
  class="w-full h-full block"
>
  <defs>
    <linearGradient id={`bg-${id}`} x1="0" y1="0" x2="0.6" y2="1">
      {id === 1 && (<><stop offset="0" stop-color="#EDE9DC" /><stop offset="1" stop-color="#DBD5C2" /></>)}
      {id === 2 && (<><stop offset="0" stop-color="#E9E7E1" /><stop offset="1" stop-color="#D2D0C9" /></>)}
      {id === 3 && (<><stop offset="0" stop-color="#E4E6E8" /><stop offset="1" stop-color="#CDD1D4" /></>)}
      {id === 4 && (<><stop offset="0" stop-color="#F0EDC5" /><stop offset="1" stop-color="#E2DDA5" /></>)}
    </linearGradient>
    <linearGradient id="metal" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#9FA3A6" />
      <stop offset="0.28" stop-color="#EAECED" />
      <stop offset="0.55" stop-color="#B9BDBF" />
      <stop offset="0.78" stop-color="#DFE1E2" />
      <stop offset="1" stop-color="#8F9497" />
    </linearGradient>
  </defs>

  <rect width="300" height="375" fill={`url(#bg-${id})`} />
  <ellipse cx="150" cy="318" rx="76" ry="10" fill="#332B14" opacity="0.10" />

  {id === 1 && (
    <g>
      <rect x="103" y="96" width="94" height="36" rx="15" fill="#EDE6D2" />
      <rect x="103" y="128" width="94" height="184" rx="15" fill="#F2EDDC" />
      <line x1="105" y1="136" x2="195" y2="136" stroke="#D9D2BA" stroke-width="1.5" />
      <line x1="105" y1="292" x2="195" y2="292" stroke="#D9D2BA" stroke-width="1.5" />
      <g fill="#8A8455" opacity="0.35">
        <circle cx="120" cy="152" r="1.1" /><circle cx="168" cy="147" r="0.9" />
        <circle cx="142" cy="163" r="0.8" /><circle cx="185" cy="170" r="1.2" />
        <circle cx="113" cy="192" r="0.9" /><circle cx="176" cy="205" r="1" />
        <circle cx="131" cy="248" r="1.1" /><circle cx="158" cy="262" r="0.8" />
        <circle cx="187" cy="252" r="0.9" /><circle cx="118" cy="274" r="1" />
        <circle cx="149" cy="118" r="0.9" /><circle cx="172" cy="286" r="1.1" />
      </g>
      <path
        d={squiggle}
        transform="translate(112, 168) scale(1.0)"
        stroke="#AAA967" stroke-width="7" fill="none" stroke-linecap="round"
      />
      <text x="150" y="240" text-anchor="middle" font-family="'Share Tech Mono', monospace" font-size="10" letter-spacing="2.5" fill="#8A8455">GENTLE RELIEF</text>
      <text x="150" y="256" text-anchor="middle" font-family="'Share Tech Mono', monospace" font-size="8" letter-spacing="2" fill="#A39D77">50 G</text>
    </g>
  )}

  {id === 2 && (
    <g>
      <rect x="141" y="84" width="18" height="16" rx="3" fill="#141210" />
      <rect x="134" y="98" width="32" height="42" rx="5" fill="#1D1B18" />
      <rect x="126" y="138" width="48" height="172" rx="9" fill="#C8C7C2" />
      <rect x="132" y="146" width="7" height="156" rx="3.5" fill="#FFFFFF" opacity="0.28" />
      <text
        transform="rotate(-90 150 224)"
        x="150" y="228" text-anchor="middle"
        font-family="'Share Tech Mono', monospace" font-size="11" letter-spacing="3"
        fill="#F1ECDB"
      >INTIMATE BALANCE</text>
    </g>
  )}

  {id === 3 && (
    <g>
      <path d="M138 148 v-20 q0 -9 9 -9 h28 q16 0 13 15 l-4 14" fill="#17150F" />
      <path d="M150 124 q-20 7 -17 32" stroke="#17150F" stroke-width="8" fill="none" stroke-linecap="round" />
      <rect x="145" y="106" width="12" height="12" rx="2" fill="#17150F" />
      <rect x="117" y="148" width="66" height="164" rx="11" fill="url(#metal)" />
      <text x="150" y="210" text-anchor="middle" font-family="'Share Tech Mono', monospace" font-size="10" letter-spacing="2.5" fill="#4A4A46">INNER FLOW</text>
      <text x="150" y="226" text-anchor="middle" font-family="'Share Tech Mono', monospace" font-size="8" letter-spacing="2" fill="#6B6B66">250 ML</text>
      <path
        d={squiggle}
        transform="translate(114, 262) scale(0.95)"
        stroke="#F1ECDB" stroke-width="5" fill="none" stroke-linecap="round" opacity="0.85"
      />
    </g>
  )}

  {id === 4 && (
    <g>
      <g transform="rotate(-7 130 210)">
        <rect x="106" y="118" width="44" height="182" rx="9" fill="#94523E" />
        <g stroke="#7C4232" stroke-width="2">
          <line x1="110" y1="126" x2="146" y2="126" /><line x1="110" y1="131" x2="146" y2="131" />
          <line x1="110" y1="288" x2="146" y2="288" /><line x1="110" y1="293" x2="146" y2="293" />
        </g>
        <path
          d={squiggle}
          transform="translate(103, 185) scale(0.68)"
          stroke="#EFECBD" stroke-width="8" fill="none" stroke-linecap="round"
        />
      </g>
      <g transform="rotate(6 170 210)">
        <rect x="152" y="126" width="44" height="182" rx="9" fill="#94523E" />
        <g stroke="#7C4232" stroke-width="2">
          <line x1="156" y1="134" x2="192" y2="134" /><line x1="156" y1="139" x2="192" y2="139" />
          <line x1="156" y1="296" x2="192" y2="296" /><line x1="156" y1="301" x2="192" y2="301" />
        </g>
        <text
          transform="rotate(-90 174 220)"
          x="174" y="224" text-anchor="middle"
          font-family="'Share Tech Mono', monospace" font-size="9" letter-spacing="2"
          fill="#EFECBD"
        >MINERAL RESTORE</text>
      </g>
    </g>
  )}
</svg>

---
import ProductCard from './ProductCard.astro';
import products from '../../data/products.json';
---

<section id="productos" class="py-24 lg:py-32 px-6 lg:px-16 bg-womena-cream/40">
  <div class="max-w-6xl mx-auto">

    <!-- Section header -->
    <div class="mb-14 lg:mb-20 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
      <div>
        <span class="rv font-womena-mono text-[10px] uppercase tracking-[0.24em] text-womena-terra/60 block mb-5">
          ✳ Colección
        </span>
        <h2 class="rv w-display text-3xl lg:text-5xl text-womena-dark" style="--d:1">
          Productos<br />seleccionados
        </h2>
      </div>
      <p class="rv font-womena-mono text-[10px] text-womena-dark/45 leading-[2] max-w-[260px] sm:text-right uppercase tracking-wider" style="--d:2">
        Cada producto cuenta una historia consciente, creada para cuidar desde el origen.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
      {products.map((product, i) => (
        <ProductCard
          id={product.id}
          name={product.name}
          category={product.category}
          description={product.description}
          price={product.price}
          weight={product.weight}
          index={i}
        />
      ))}
    </div>

  </div>
</section>

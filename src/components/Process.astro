---
const steps = [
  {
    number: '01',
    title: 'Te escuchamos',
    description:
      'Nos sentamos contigo (o por videollamada) y entendemos qué necesita tu negocio. No qué video quieres. Qué resultado necesitas.',
  },
  {
    number: '02',
    title: 'Diseñamos el plan',
    description:
      'Te presentamos una propuesta con calendario, contenidos y métricas esperadas. Sabes exactamente qué vas a recibir.',
  },
  {
    number: '03',
    title: 'Producimos',
    description:
      'Llegamos con equipo profesional, grabamos, editamos y te entregamos todo listo. Tú no mueves un dedo.',
  },
  {
    number: '04',
    title: 'Medimos y ajustamos',
    description:
      'Revisamos qué funcionó, qué no, y ajustamos. No es un proyecto de una vez — es un sistema que mejora cada mes.',
  },
];
---

<section id="proceso" class="py-24 lg:py-32 bg-charcoal text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-xl mb-16">
      <p class="text-gray-400 text-sm font-semibold tracking-widest uppercase mb-3 reveal">
        Cómo trabajamos
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight reveal reveal-delay-1">
        Un proceso claro de principio a fin
      </h2>
    </div>

    <!-- Steps — horizontal timeline (desktop) / vertical (mobile) -->
    <div class="relative" id="process-timeline">
      <!-- Connector line (desktop only) -->
      <div
        class="hidden lg:block absolute top-5 left-0 right-0 h-px bg-white/10"
        aria-hidden="true"
      ></div>
      <!-- Progress line (fills on scroll) -->
      <div
        id="process-progress"
        class="hidden lg:block absolute top-5 left-0 h-px bg-white origin-left"
        style="width: 0%; transition: width 1.2s var(--ease-out-expo);"
        aria-hidden="true"
      ></div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-10 lg:gap-8">
        {steps.map((step, i) => (
          <div class={`reveal-up reveal-delay-${i + 1} process-step relative flex flex-col gap-4`}>
            <!-- Step number circle -->
            <div class="flex items-center gap-4 lg:flex-col lg:items-start">
              <div
                class="process-circle w-10 h-10 rounded-full flex items-center justify-center text-sm font-black flex-shrink-0 z-10"
                style="background-color: #1A1A1A; color: white; border: 1px solid rgba(255,255,255,0.2);"
              >
                {step.number}
              </div>
              {i < steps.length - 1 && (
                <div class="lg:hidden flex-1 h-px bg-white/10" aria-hidden="true"></div>
              )}
            </div>
            <h3 class="text-xl font-bold">{step.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .process-step .process-circle {
    transition:
      transform 0.4s var(--ease-out-expo),
      background 0.3s,
      border-color 0.3s;
  }
  .process-step:hover .process-circle {
    background: #fff !important;
    color: #1a1a1a !important;
    border-color: #fff !important;
    transform: scale(1.12);
  }
  #process-timeline.filled #process-progress {
    width: 100%;
  }
</style>

<script>
  const timeline = document.getElementById('process-timeline');
  if (timeline) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          timeline.classList.add('filled');
          obs.disconnect();
        }
      });
    }, { threshold: 0.35 });
    obs.observe(timeline);
  }
</script>

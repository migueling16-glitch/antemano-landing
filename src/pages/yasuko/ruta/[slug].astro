---
import YasukoLayout from '../../../layouts/YasukoLayout.astro';
import {
  getAllRutas,
  getRutaBySlug,
  getModuloBySlug,
  getTipoBadge,
} from '../../../data/content-yasuko';
import type { Ruta } from '../../../data/content-yasuko';

export async function getStaticPaths() {
  return getAllRutas().map((r) => ({
    params: { slug: r.slug },
    props: { ruta: r },
  }));
}

interface Props { ruta: Ruta; }
const { ruta } = Astro.props;

const pasos = ruta.modulos
  .map((slug, idx) => ({ modulo: getModuloBySlug(slug), orden: idx + 1 }))
  .filter((p): p is { modulo: NonNullable<typeof p.modulo>; orden: number } => p.modulo !== undefined);
---

<YasukoLayout
  title={ruta.titulo}
  backHref="/yasuko/"
  backLabel="Inicio"
>

  <!-- ── Header de ruta ───────────────────────────────────────────────────── -->
  <section style="padding:2.25rem 1.25rem 1.25rem;max-width:680px;margin:0 auto;">
    <p style="font-size:0.65rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:rgba(201,164,93,0.7);margin-bottom:0.6rem;font-family:'Montserrat',sans-serif;">
      {ruta.puesto}
    </p>
    <h1 class="display" style="font-size:clamp(1.7rem,6vw,2.4rem);line-height:1.14;color:#F2EFE8;margin-bottom:0.6rem;">
      {ruta.titulo}
    </h1>
    <p style="font-size:0.9rem;color:rgba(242,239,232,0.58);line-height:1.6;margin-bottom:1.5rem;">{ruta.descripcion}</p>

    <!-- Barra de progreso -->
    <div style="background:rgba(201,164,93,0.15);border-radius:999px;height:4px;margin-bottom:0.5rem;overflow:hidden;">
      <div id="barra-progreso" style="height:100%;background:var(--yk);border-radius:999px;transition:width 0.4s;width:0%;"></div>
    </div>
    <p id="texto-progreso" style="font-size:0.75rem;color:rgba(242,239,232,0.48);">0 de {pasos.length} completados</p>
  </section>

  <!-- ── Lista de pasos ────────────────────────────────────────────────────── -->
  <section id="pasos-section" data-slugs={ruta.modulos.join(',')} style="padding:0.5rem 1.25rem 4rem;max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:0.6rem;">

    {pasos.map(({ modulo: m, orden }) => {
      const badge = getTipoBadge(m.tipo);
      return (
        <div class="paso-card" data-slug={m.slug} style="background:var(--yk-soft);border:1px solid var(--yk-border);border-radius:14px;overflow:hidden;">

          <!-- Fila principal clicable al módulo -->
          <a href={`/yasuko/modulo/${m.slug}`} style="display:flex;align-items:center;gap:1rem;padding:1rem 1.1rem 0.8rem;text-decoration:none;">

            <!-- Número / check -->
            <div class="paso-num" data-slug={m.slug} style="flex-shrink:0;width:2rem;height:2rem;border-radius:50%;border:1.5px solid rgba(201,164,93,0.4);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:600;color:rgba(242,239,232,0.45);transition:all 0.2s;position:relative;">
              <span class="num-label">{orden}</span>
              <span class="check-label" style="display:none;">
                <svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#C9A45D" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>

            <!-- Info -->
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.3rem;">
                <span class="badge" style={badge.style}>{badge.label}</span>
                <span style="font-size:0.7rem;color:rgba(242,239,232,0.4);">{m.duracion}</span>
              </div>
              <p class="display" style="font-size:0.98rem;color:#F2EFE8;line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                {m.titulo}
              </p>
            </div>

            <!-- Arrow -->
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0;color:rgba(201,164,93,0.6);"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>

          <!-- Nota + marcar completado -->
          <div style="padding:0 1.1rem 0.85rem;display:flex;align-items:center;justify-content:space-between;gap:0.75rem;">
            <p style="font-size:0.72rem;color:rgba(242,239,232,0.4);line-height:1.45;flex:1;">
              Practícalo con tu supervisor antes de marcar completo.
            </p>
            <button
              class="marcar-btn"
              data-slug={m.slug}
              style="flex-shrink:0;padding:0.3rem 0.75rem;border-radius:999px;border:1px solid rgba(201,164,93,0.45);background:transparent;font-size:0.7rem;font-weight:600;color:rgba(201,164,93,0.8);cursor:pointer;white-space:nowrap;transition:all 0.18s;font-family:'Montserrat',sans-serif;"
            >
              Marcar
            </button>
          </div>
        </div>
      );
    })}

  </section>

</YasukoLayout>

<script>
  // Se re-vincula en cada navegación (View Transitions). Los datos de la ruta
  // viajan en data-slugs del section para evitar define:vars + re-ejecución.
  const KEY = 'yasuko_completados';

  function getCompletados(): string[] {
    try { return JSON.parse(localStorage.getItem(KEY) || '[]'); }
    catch { return []; }
  }

  function setCompletados(list: string[]) {
    localStorage.setItem(KEY, JSON.stringify(list));
  }

  function actualizarUI(slugsOrden: string[], totalPasos: number) {
    const completados = getCompletados();

    // checkmarks
    document.querySelectorAll<HTMLElement>('.paso-num').forEach((el) => {
      const slug = el.dataset.slug!;
      const hecho = completados.includes(slug);
      const num = el.querySelector<HTMLElement>('.num-label');
      const check = el.querySelector<HTMLElement>('.check-label');
      if (hecho) {
        el.style.borderColor = '#C9A45D';
        el.style.background = 'rgba(201,164,93,0.1)';
        if (num) num.style.display = 'none';
        if (check) check.style.display = 'flex';
      } else {
        el.style.borderColor = 'rgba(201,164,93,0.4)';
        el.style.background = 'transparent';
        if (num) num.style.display = 'block';
        if (check) check.style.display = 'none';
      }
    });

    // botones
    document.querySelectorAll<HTMLElement>('.marcar-btn').forEach((btn) => {
      const slug = btn.dataset.slug!;
      const hecho = completados.includes(slug);
      btn.textContent = hecho ? 'Desmarcar' : 'Marcar';
      btn.style.color = hecho ? '#C9A45D' : 'rgba(201,164,93,0.8)';
      btn.style.borderColor = hecho ? '#C9A45D' : 'rgba(201,164,93,0.45)';
      btn.style.background = hecho ? 'rgba(201,164,93,0.07)' : 'transparent';
    });

    // progreso
    const relevantes = slugsOrden.filter((s) => completados.includes(s));
    const done = relevantes.length;
    const barra = document.getElementById('barra-progreso');
    const texto = document.getElementById('texto-progreso');
    if (barra) barra.style.width = `${(done / totalPasos) * 100}%`;
    if (texto) texto.textContent = `${done} de ${totalPasos} completados`;
  }

  function initRuta() {
    const cont = document.getElementById('pasos-section');
    if (!cont) return; // no estamos en una página de ruta

    const slugsOrden = (cont.dataset.slugs || '').split(',').filter(Boolean);
    const totalPasos = slugsOrden.length;

    // toggle al marcar
    document.querySelectorAll<HTMLElement>('.marcar-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const slug = btn.dataset.slug!;
        const completados = getCompletados();
        const idx = completados.indexOf(slug);
        if (idx === -1) completados.push(slug);
        else completados.splice(idx, 1);
        setCompletados(completados);
        actualizarUI(slugsOrden, totalPasos);
      });
    });

    actualizarUI(slugsOrden, totalPasos);
  }

  document.addEventListener('astro:page-load', initRuta);
</script>

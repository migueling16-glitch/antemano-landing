---
import YasukoLayout from '../../../layouts/YasukoLayout.astro';
import {
  getAllModulos,
  getModuloBySlug,
  getEstacionBySlug,
  getRelatedModulos,
  getTipoBadge,
  getRutasForModulo,
  getNextInRuta,
} from '../../../data/content-yasuko';
import type { Modulo } from '../../../data/content-yasuko';

export async function getStaticPaths() {
  return getAllModulos().map((m) => ({
    params: { slug: m.slug },
    props: { modulo: m },
  }));
}

interface Props { modulo: Modulo; }
const { modulo } = Astro.props;

const estacion = getEstacionBySlug(modulo.estacion)!;
const badge    = getTipoBadge(modulo.tipo);
const usa      = getRelatedModulos(modulo.usaRecetas);
const aparece  = getRelatedModulos(modulo.usadaEn);
const rutas    = getRutasForModulo(modulo.slug);
const siguiente = rutas.length > 0 ? getNextInRuta(modulo.slug, rutas[0].slug) : undefined;

const fichEntradas = modulo.ficha ? Object.entries(modulo.ficha) : [];
---

<YasukoLayout
  title={modulo.titulo}
  description={modulo.descripcion}
  backHref={`/yasuko/estacion/${modulo.estacion}`}
  backLabel={estacion.titulo}
>

  <!-- ── Video placeholder 9:16 ───────────────────────────────────────────── -->
  <div style="width:100%;max-width:400px;margin:0 auto;">
    <div style="position:relative;width:100%;aspect-ratio:9/16;background:#0E1114;overflow:hidden;">

      {modulo.videoUrl ? (
        <iframe
          src={modulo.videoUrl}
          style="position:absolute;inset:0;width:100%;height:100%;border:0;"
          allowfullscreen
        />
      ) : (
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;padding:2rem;">
          <!-- Fondo textural sutil -->
          <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%, rgba(201,164,93,0.08) 0%, transparent 70%);pointer-events:none;"></div>

          <!-- Play circle -->
          <div class="pulse" style="width:4rem;height:4rem;border-radius:50%;border:2px solid rgba(201,164,93,0.8);display:flex;align-items:center;justify-content:center;position:relative;z-index:1;">
            <svg width="18" height="22" viewBox="0 0 18 22" fill="none">
              <path d="M2 1.5L16 11 2 20.5V1.5z" fill="#C9A45D"/>
            </svg>
          </div>

          <!-- Label -->
          <div style="text-align:center;position:relative;z-index:1;">
            <p style="font-size:0.65rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:rgba(201,164,93,0.8);margin-bottom:0.35rem;font-family:'Montserrat',sans-serif;">
              Video en producción
            </p>
            <p style="font-size:0.75rem;color:rgba(255,255,255,0.3);letter-spacing:0.06em;">{modulo.duracion}</p>
          </div>

          <!-- Título watermark -->
          <p class="display" style="position:absolute;bottom:1.5rem;left:0;right:0;text-align:center;font-size:0.82rem;color:rgba(201,164,93,0.28);letter-spacing:0.04em;padding:0 1.5rem;line-height:1.4;">
            {modulo.titulo}
          </p>
        </div>
      )}

    </div>
  </div>

  <!-- ── Contenido ─────────────────────────────────────────────────────────── -->
  <div style="max-width:680px;margin:0 auto;padding:0 1.25rem;">

    <!-- Título y badges -->
    <div style="padding-top:1.75rem;padding-bottom:1.5rem;border-bottom:1px solid var(--yk-border);">
      <h1 class="display" style="font-size:clamp(1.7rem,7vw,2.4rem);line-height:1.12;color:#F2EFE8;margin-bottom:0.9rem;">
        {modulo.titulo}
      </h1>

      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem;margin-bottom:1rem;">
        <span class="badge" style={badge.style}>{badge.label}</span>
        <span class="badge" style="border:1px solid rgba(242,239,232,0.2);color:rgba(242,239,232,0.5);background:transparent;">
          {modulo.duracion}
        </span>
        <span class="badge" style="border:1px solid rgba(201,164,93,0.3);color:rgba(201,164,93,0.75);background:transparent;">
          {estacion.titulo}
        </span>
      </div>

      <p style="font-size:1rem;color:rgba(242,239,232,0.65);line-height:1.65;">{modulo.descripcion}</p>
    </div>

    <!-- Ficha técnica -->
    {fichEntradas.length > 0 && (
      <div style="padding:1.5rem 0;border-bottom:1px solid var(--yk-border);">
        <p class="menu-head" style="margin-bottom:1.1rem;">
          Ficha técnica <span style="opacity:0.6;">†</span>
        </p>

        <div style="display:grid;grid-template-columns:1fr;gap:0;">
          {fichEntradas.map(([key, val], i) => (
            <div style={`display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:0.6rem 0;${i > 0 ? 'border-top:1px solid rgba(201,164,93,0.12);' : ''}`}>
              <span style="font-size:0.82rem;color:rgba(242,239,232,0.5);font-weight:400;flex-shrink:0;">{key}</span>
              <span style="font-size:0.88rem;color:#F2EFE8;font-weight:500;text-align:right;">{val}</span>
            </div>
          ))}
        </div>

        <p style="margin-top:1rem;font-size:0.72rem;color:rgba(242,239,232,0.4);line-height:1.5;padding-top:0.75rem;border-top:1px solid rgba(201,164,93,0.1);">
          † Gramajes sujetos a validación con el chef — en producción. Los precios corresponden al menú vigente.
        </p>
      </div>
    )}

    <!-- Criterio de calidad -->
    {modulo.criterio && (
      <div style="padding:1.5rem 0;border-bottom:1px solid var(--yk-border);">
        <p class="menu-head" style="margin-bottom:1.25rem;">
          Criterio de calidad
        </p>

        <div style="display:grid;grid-template-columns:1fr;gap:0.75rem;">

          <!-- Bien -->
          <div style="background:var(--yk-soft);border-radius:12px;padding:1.1rem 1.1rem 1.1rem 1.35rem;border:1px solid rgba(201,164,93,0.18);border-left:3px solid var(--yk);">
            <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--yk);margin-bottom:0.6rem;display:flex;align-items:center;gap:0.4rem;font-family:'Montserrat',sans-serif;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9 10 3" stroke="#C9A45D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Cuando está bien
            </p>
            <p style="font-size:0.88rem;color:rgba(242,239,232,0.72);line-height:1.65;">{modulo.criterio.bien}</p>
          </div>

          <!-- Mal -->
          <div style="background:var(--yk-soft);border-radius:12px;padding:1.1rem 1.1rem 1.1rem 1.35rem;border:1px solid rgba(242,239,232,0.1);border-left:3px solid rgba(242,239,232,0.35);">
            <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:rgba(242,239,232,0.5);margin-bottom:0.6rem;display:flex;align-items:center;gap:0.4rem;font-family:'Montserrat',sans-serif;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3l-6 6" stroke="rgba(242,239,232,0.5)" stroke-width="1.5" stroke-linecap="round"/></svg>
              Cuando está mal
            </p>
            <p style="font-size:0.88rem;color:rgba(242,239,232,0.62);line-height:1.65;">{modulo.criterio.mal}</p>
          </div>

        </div>
      </div>
    )}

    <!-- Esta receta usa → (dependencias) -->
    <div style="padding:1.5rem 0;border-bottom:1px solid var(--yk-border);">
      <p class="menu-head" style="margin-bottom:0.9rem;">
        Esta receta usa →
      </p>

      {usa.length > 0 ? (
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
          {usa.map((m) => (
            <a href={`/yasuko/modulo/${m.slug}`} class="btn-pill" style="font-size:0.8rem;padding:0.45rem 1rem;">
              {m.titulo}
            </a>
          ))}
        </div>
      ) : (
        <p style="font-size:0.85rem;color:rgba(242,239,232,0.4);font-style:italic;">
          Receta base — no depende de otras preparaciones.
        </p>
      )}
    </div>

    <!-- Aparece en → (quién me usa) -->
    {aparece.length > 0 && (
      <div style="padding:1.5rem 0;border-bottom:1px solid var(--yk-border);">
        <p class="menu-head" style="margin-bottom:0.9rem;">
          Aparece en →
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
          {aparece.map((m) => (
            <a href={`/yasuko/modulo/${m.slug}`} class="btn-pill" style="font-size:0.8rem;padding:0.45rem 1rem;">
              {m.titulo}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Siguiente en la ruta -->
    <div style="padding:2rem 0 3.5rem;">
      {siguiente ? (
        <div>
          <p style="font-size:0.65rem;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:rgba(242,239,232,0.4);margin-bottom:0.9rem;font-family:'Montserrat',sans-serif;">
            Siguiente en tu ruta
          </p>
          <a href={`/yasuko/modulo/${siguiente.slug}`} class="card" style="display:flex;align-items:center;justify-content:space-between;padding:1.1rem 1.25rem;gap:1rem;">
            <div>
              <p style="font-size:0.7rem;color:rgba(201,164,93,0.75);font-weight:600;margin-bottom:0.25rem;font-family:'Montserrat',sans-serif;">{siguiente.duracion}</p>
              <p class="display" style="font-size:1.1rem;color:#F2EFE8;">{siguiente.titulo}</p>
            </div>
            <div style="flex-shrink:0;width:2.25rem;height:2.25rem;border-radius:50%;border:1.5px solid var(--yk);display:flex;align-items:center;justify-content:center;color:var(--yk);">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2.5 6.5h8M7 3L10.5 6.5 7 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        </div>
      ) : (
        <a href="/yasuko/ruta/sushiman-barra" class="btn-pill-filled" style="width:100%;justify-content:center;padding:0.85rem 1.5rem;font-size:0.9rem;">
          Ver la ruta completa →
        </a>
      )}
    </div>

  </div>

</YasukoLayout>

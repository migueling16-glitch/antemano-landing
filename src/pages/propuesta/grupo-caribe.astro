  { id: 'p3',  name: 'Enchiladas verdes',        subs: [1, 7, 11]      },
  { id: 'p4',  name: 'Quesadillas',              subs: [12, 8, 3]      },
  { id: 'p5',  name: 'Burrito clásico',          subs: [5, 4, 8, 9]    },
  { id: 'p6',  name: 'Sopa de mariscos',         subs: [11, 10, 6]     },

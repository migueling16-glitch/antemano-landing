<!-- ─── JAVASCRIPT ─────────────────────────────────────────────────────── -->
<script is:inline>
(function () {
  /* ── Scroll-reveal ─────────────────────────────────────────── */
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ── Sticky nav ────────────────────────────────────────────── */
  const nav = document.getElementById('pnav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  /* ── Calculator ────────────────────────────────────────────── */
  let displayedTotal = 0;
  let rafId = null;
  let savedTotal = 374780;

  function fmt(n) {
    return '$' + Math.round(n).toLocaleString('es-MX');
  }

  function get(id)  { return parseFloat(document.getElementById(id).value); }
  function setText(id, val) { document.getElementById(id).textContent = val; }

  function calcAll() {
    const cocineros = get('s-cocineros');
    const rotacion  = get('s-rotacion');
    const dias      = get('s-dias');
    const hora      = get('s-hora');
    const fcAct     = get('s-fc-actual');
    const fcObj     = get('s-fc-obj');
    const venta     = get('s-venta');
    const dev       = get('s-dev');

    // Labels
    setText('v-cocineros', cocineros);
    setText('v-rotacion',  rotacion);
    setText('v-dias',      dias + ' días');
    setText('v-hora',      '$' + hora + '/hr');
    setText('v-fc',        fcAct + '% vs ' + fcObj + '%');
    setText('v-venta',     '$' + Math.round(venta / 1000) + 'k');
    setText('v-dev',       dev);

    // Calculations
    const horasEntrenador = dias * 4;
    const salarioDiarioNuevo = 250;
    const cap = (horasEntrenador * hora + dias * salarioDiarioNuevo) * rotacion;
    const rot = rotacion * 5000;
    const gap = Math.max(0, fcAct - fcObj) / 100;
    const mer = gap * venta * 12;
    const devCost = dev * 280 * 52;
    const total = cap + rot + mer + devCost;

    // Bars
    setText('br-cap', fmt(cap));
    setText('br-rot', fmt(rot));
    setText('br-mer', fmt(mer));
    setText('br-dev', fmt(devCost));

    const max = Math.max(cap, rot, mer, devCost, 1);
    document.getElementById('bar-cap').style.width = (cap / max * 100) + '%';
    document.getElementById('bar-rot').style.width = (rot / max * 100) + '%';
    document.getElementById('bar-mer').style.width = (mer / max * 100) + '%';
    document.getElementById('bar-dev').style.width = (devCost / max * 100) + '%';

    // Animate star number
    savedTotal = total;
    animateTo(total);

    // Sync offer anchor & print
    const prEl = document.getElementById('pr-star');
    const anEl = document.getElementById('star-anchor');
    if (prEl) prEl.textContent = fmt(total);
    if (anEl) anEl.textContent = fmt(total);
  }

  function animateTo(target) {
    if (rafId) cancelAnimationFrame(rafId);
    const start = displayedTotal;
    const diff  = target - start;
    const dur   = 600;
    const t0    = performance.now();
    function tick(now) {
      const p = Math.min((now - t0) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      displayedTotal = start + diff * eased;
      document.getElementById('star-num').textContent = fmt(displayedTotal);
      if (p < 1) rafId = requestAnimationFrame(tick);
    }
    rafId = requestAnimationFrame(tick);
  }

  ['s-cocineros','s-rotacion','s-dias','s-hora','s-fc-actual','s-fc-obj','s-venta','s-dev']
    .forEach(id => document.getElementById(id).addEventListener('input', calcAll));

  calcAll(); // initial

  /* ── Modular Explorer ──────────────────────────────────────── */
  const platillosData = {
    'p1':  { subs: [2, 3, 9]       },
    'p2':  { subs: [3, 7, 4]       },
    'p3':  { subs: [1, 7, 11]      },
    'p4':  { subs: [12, 8, 3]      },
    'p5':  { subs: [5, 4, 8, 9]    },
    'p6':  { subs: [11, 10, 6]     },
    'p7':  { subs: [5, 11, 10]     },
    'p8':  { subs: [10, 6, 1]      },
    'p9':  { subs: [10, 9, 7]      },
    'p10': { subs: [11, 2, 3]      },
    'p11': { subs: [4, 7, 3]       },
    'p12': { subs: [6, 1, 10, 2]   },
    'p13': { subs: [10, 11, 6]     },
    'p14': { subs: [10, 6, 1]      },
    'p15': { subs: [10, 9, 3]      },
  };

  const subNames = {
    1: 'Salsa de tomate', 2: 'Adobo caribeño', 3: 'Sofrito base',
    4: 'Frijoles negros', 5: 'Arroz blanco', 6: 'Mojo de ajo',
    7: 'Crema chipotle', 8: 'Guacamole base', 9: 'Pico de gallo',
    10: 'Base de mariscos', 11: 'Caldo de pollo', 12: 'Masa para tortilla',
  };

  let activeSubId = null;
  let activePlatId = null;

  const chips    = document.querySelectorAll('.sub-chip');
  const platItems = document.querySelectorAll('.plat-item');
  const punchline = document.getElementById('explorer-punchline');

  function clearAll() {
    chips.forEach(c => { c.classList.remove('active'); c.setAttribute('aria-pressed','false'); });
    platItems.forEach(p => { p.classList.remove('active','dimmed'); });
    document.querySelectorAll('.plat-sub-tag').forEach(t => t.classList.remove('highlight'));
    activeSubId = null; activePlatId = null;
    punchline.innerHTML = '<strong>Toca una subreceta</strong> para ver en cuántos platillos aparece.';
    punchline.classList.remove('has-selection');
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const sid = parseInt(chip.dataset.subId);
      if (activeSubId === sid) { clearAll(); return; }
      clearAll();
      activeSubId = sid;
      chip.classList.add('active');
      chip.setAttribute('aria-pressed','true');

      let matchCount = 0;
      platItems.forEach(p => {
        const platSubs = platillosData[p.dataset.platId]?.subs || [];
        if (platSubs.includes(sid)) {
          p.classList.add('active');
          matchCount++;
          p.querySelectorAll('.plat-sub-tag').forEach(tag => {
            if (parseInt(tag.dataset.tagSub) === sid) tag.classList.add('highlight');
          });
        } else {
          p.classList.add('dimmed');
        }
      });

      punchline.classList.add('has-selection');
      punchline.innerHTML = `<strong>1 video de "${subNames[sid]}" = ${matchCount} platillos</strong> — el mismo estándar, reutilizado.`;
    });
  });

  platItems.forEach(platEl => {
    platEl.addEventListener('click', () => {
      const pid = platEl.dataset.platId;
      if (activePlatId === pid) { clearAll(); return; }
      clearAll();
      activePlatId = pid;
      platEl.classList.add('active');

      const platSubs = platillosData[pid]?.subs || [];
      chips.forEach(c => {
        if (platSubs.includes(parseInt(c.dataset.subId))) {
          c.classList.add('active');
        }
      });
      platEl.querySelectorAll('.plat-sub-tag').forEach(t => t.classList.add('highlight'));

      punchline.classList.add('has-selection');
      punchline.innerHTML = `Este platillo usa <strong>${platSubs.length} subrecetas base</strong> — cada una, un video compartido con otros platillos.`;
    });
  });

  /* ── Print leave-behind ─────────────────────────────────────── */
  const printBtn = document.getElementById('btn-print');
  if (printBtn) {
    printBtn.addEventListener('click', () => {
      const dateEl = document.getElementById('pr-date-val');
      if (dateEl) dateEl.textContent = new Date().toLocaleDateString('es-MX', { year:'numeric', month:'long', day:'numeric' });
      const prStar = document.getElementById('pr-star');
      if (prStar) prStar.textContent = document.getElementById('star-num').textContent;
      window.print();
    });
  }

  /* ── Date in print page ─────────────────────────────────────── */
  const dateEl = document.getElementById('pr-date-val');
  if (dateEl) dateEl.textContent = new Date().toLocaleDateString('es-MX', { year:'numeric', month:'long', day:'numeric' });

})();
</script>
</body>
</html>

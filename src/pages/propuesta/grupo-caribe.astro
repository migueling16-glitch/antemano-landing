  { id: 3,  name: 'Sofrito base',        count: 6 },
  { id: 4,  name: 'Frijoles negros',     count: 3 },
  { id: 5,  name: 'Arroz blanco',        count: 2 },
  { id: 6,  name: 'Mojo de ajo',         count: 5 },

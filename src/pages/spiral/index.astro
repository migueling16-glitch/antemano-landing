---
import SpiralLayout from '../../layouts/SpiralLayout.astro';
import { getAllEstaciones, getAllRutas, getModulosByEstacion } from '../../data/content';

const estaciones = getAllEstaciones();
const rutas = getAllRutas();

const estacionesConConteo = estaciones.map((e) => ({
  ...e,
  conteo: getModulosByEstacion(e.slug).length,
}));
---

<SpiralLayout title="Inicio">

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section style="padding: 3.5rem 1.25rem 2.5rem; max-width:680px; margin:0 auto; text-align:center;">
    <p style="font-size:0.68rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:rgba(196,82,42,0.55);margin-bottom:1.5rem;">
      Tu cocina · Tu estándar · Tu sistema
    </p>
    <h1 class="serif" style="font-size:clamp(2.4rem,9vw,3.6rem);font-weight:600;line-height:1.08;color:#2C1810;letter-spacing:-0.01em;margin-bottom:1rem;">
      Aprende a hacerlo<br />
      como <em style="color:var(--sc);font-style:italic;">Spiral.</em>
    </h1>
    <p style="font-size:clamp(0.95rem,3vw,1.1rem);color:rgba(44,24,16,0.6);line-height:1.65;max-width:38ch;margin:0 auto 2rem;">
      Cada receta, en video, en tu estación. Sin buscar en carpetas — en 3 segundos.
    </p>
    <a href="/spiral/ruta/cocinero-de-pizzas" class="btn-pill-filled">
      Empezar mi ruta
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </section>

  <!-- ── Estaciones ────────────────────────────────────────────────────────── -->
  <section style="padding: 0 1.25rem 3rem; max-width:680px; margin:0 auto;">
    <p style="font-size:0.65rem;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;color:rgba(44,24,16,0.4);margin-bottom:1.25rem;">Tu cocina</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
      {estacionesConConteo.map((e) => (
        <a href={`/spiral/estacion/${e.slug}`} class="card" style="padding:1.25rem 1.1rem;display:block;">
          <p style="font-size:0.65rem;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(196,82,42,0.55);margin-bottom:0.45rem;">
            {e.conteo} {e.conteo === 1 ? 'módulo' : 'módulos'}
          </p>
          <p class="serif" style="font-size:1.2rem;font-weight:600;color:#2C1810;line-height:1.2;margin-bottom:0.4rem;">
            {e.titulo}
          </p>
          <p style="font-size:0.78rem;color:rgba(44,24,16,0.52);line-height:1.5;">
            {e.descripcion}
          </p>
          <div style="margin-top:0.85rem;display:flex;align-items:center;gap:0.3rem;color:var(--sc);font-size:0.78rem;font-weight:500;">
            Ver módulos
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6.5 2.5L10 6l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Rutas de aprendizaje ──────────────────────────────────────────────── -->
  <section style="padding: 0 1.25rem 4rem; max-width:680px; margin:0 auto;">
    <p style="font-size:0.65rem;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;color:rgba(44,24,16,0.4);margin-bottom:1.25rem;">Rutas de aprendizaje</p>

    {rutas.map((r) => (
      <a href={`/spiral/ruta/${r.slug}`} class="card" style="display:flex;align-items:center;justify-content:space-between;padding:1.35rem 1.25rem;gap:1rem;">
        <div>
          <p style="font-size:0.65rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:rgba(196,82,42,0.55);margin-bottom:0.3rem;">{r.puesto}</p>
          <p class="serif" style="font-size:1.35rem;font-weight:600;color:#2C1810;line-height:1.2;margin-bottom:0.3rem;">{r.titulo}</p>
          <p style="font-size:0.8rem;color:rgba(44,24,16,0.52);">{r.modulos.length} módulos ordenados</p>
        </div>
        <div style="flex-shrink:0;width:2.5rem;height:2.5rem;border-radius:50%;border:1.5px solid var(--sc);display:flex;align-items:center;justify-content:center;color:var(--sc);">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
      </a>
    ))}
  </section>

</SpiralLayout>

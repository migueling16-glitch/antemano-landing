    const subChipsEl = document.getElementById('sub-chips');
    const platListEl = document.getElementById('plat-list');
    const subCountEl = document.getElementById('exp-sub-count');
    const platLabelEl = document.getElementById('exp-plat-label');
    const punch = document.getElementById('exp-punch');

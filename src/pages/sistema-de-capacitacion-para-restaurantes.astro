          { name: 'Pizza Salame pepperoncino', subs: [1, 6] },
          { name: 'Pizza Alcachofa espinaca trufa', subs: [1, 6] },
          { name: 'Spaghetti al limón', subs: [3] },
          { name: 'Carbonara', subs: [3] },
          { name: 'Bucatini arrabiata con nduja', subs: [3, 4] },
          { name: 'Spicy vodka rigatoni', subs: [3, 5, 4] },
          { name: 'Short rib pappardelle', subs: [3] },

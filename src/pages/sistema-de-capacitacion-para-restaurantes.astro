---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Sistema de Capacitación para Restaurantes — Antemano</title>
  <link rel="icon" href="/logo-a.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --c:#1A1A1A;--w:#FAFAFA;--ww:#FFFFFF;--g:#F3F3F3;
      --mid:#6B7280;--border:rgba(26,26,26,.10);
      --ease-out-expo:cubic-bezier(0.16,1,0.3,1);
      --ease-out-quart:cubic-bezier(0.25,1,0.5,1);
    }
    html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
    body{background:var(--ww);color:var(--c);font-family:'Inter',system-ui,sans-serif;
      -webkit-font-smoothing:antialiased;overflow-x:hidden}
    ::selection{background:#1a1a1a;color:#fff}
    :focus-visible{outline:2px solid #1a1a1a;outline-offset:3px;border-radius:4px}

    .si{font-family:'Instrument Serif',Georgia,serif;font-style:italic;font-weight:400;
      font-size:1.06em;line-height:1;letter-spacing:-.01em}

    .container{max-width:1100px;margin:0 auto;padding:0 1.5rem}
    .s-dark {background:var(--c);color:#fff;padding:6rem 0}
    .s-light{background:var(--w);color:var(--c);padding:6rem 0}
    .s-white{background:var(--ww);color:var(--c);padding:6rem 0}

    .eyebrow{font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
      color:rgba(255,255,255,.4);margin-bottom:1.25rem}
    .eyebrow-dark{font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
      color:var(--mid);margin-bottom:1.25rem}

    .h1{font-size:clamp(2.5rem,6.5vw,5.5rem);font-weight:900;line-height:1;letter-spacing:-.03em}
    .h2{font-size:clamp(1.9rem,4.5vw,3.5rem);font-weight:900;line-height:1.05;letter-spacing:-.025em}
    .h2-c{text-align:center;margin:0 auto}
    .ssub{font-size:1.1rem;color:var(--mid);margin-top:.75rem;max-width:44ch;line-height:1.6}
    .ssub-c{text-align:center;margin:.75rem auto 0}

    .btn{display:inline-flex;align-items:center;gap:.5rem;font-size:.95rem;font-weight:700;
      padding:.85rem 1.75rem;border-radius:9999px;border:none;cursor:pointer;text-decoration:none;
      transition:transform .2s var(--ease-out-quart),box-shadow .2s var(--ease-out-quart)}
    .btn:hover{transform:scale(1.025)}
    .btn:active{transform:scale(0.96);transition-duration:.08s}
    .btn-light{background:#fff;color:var(--c)}
    .btn-light:hover{box-shadow:0 12px 28px -8px rgba(0,0,0,.22)}
    .btn-dark{background:var(--c);color:#fff}
    .btn-dark:hover{box-shadow:0 12px 28px -8px rgba(0,0,0,.35)}
    .btn-outline{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.35)}
    .btn-outline:hover{border-color:#fff;background:rgba(255,255,255,.06)}

    .reveal{opacity:0;transform:translateY(24px);
      transition:opacity .7s var(--ease-out-expo),transform .7s var(--ease-out-expo)}
    .reveal.visible{opacity:1;transform:none}
    .reveal-d1{transition-delay:.12s}.reveal-d2{transition-delay:.22s}.reveal-d3{transition-delay:.32s}

    /* ── NAV ── */
    #pnav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1rem 1.5rem;
      transition:background .4s,backdrop-filter .4s}
    #pnav.scrolled{background:rgba(26,26,26,.85);backdrop-filter:blur(16px);
      border-bottom:1px solid rgba(255,255,255,.07)}
    .pnav-inner{max-width:1100px;width:100%;margin:0 auto;display:flex;
      align-items:center;justify-content:space-between}
    .pnav-logo img{height:28px;width:auto;display:block;filter:invert(1)}
    .pnav-tag{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
      color:rgba(255,255,255,.3);display:none}
    @media(min-width:640px){.pnav-tag{display:block}}

    /* ── HERO ── */
    #hero{min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;
      padding:8rem 0 5rem;position:relative;overflow:hidden;background:var(--c)}
    #hero::before{content:'';position:absolute;inset:0;
      background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(255,255,255,.03) 0%,transparent 70%);
      pointer-events:none}
    .hero-tag{font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
      color:rgba(255,255,255,.3);margin-bottom:2rem;display:flex;align-items:center;gap:.75rem}
    .hero-tag::before{content:'';display:block;width:2rem;height:1px;background:rgba(255,255,255,.2)}
    .hero-h1{font-size:clamp(2.6rem,7vw,6rem);font-weight:900;line-height:1;
      letter-spacing:-.035em;color:#fff;margin-bottom:2rem;max-width:18ch}
    .hero-sub{font-size:clamp(.95rem,1.8vw,1.2rem);color:rgba(255,255,255,.55);
      max-width:54ch;line-height:1.65;margin-bottom:1.25rem}
    .hero-brands{display:flex;flex-wrap:wrap;gap:.5rem;margin:1.5rem 0 2.5rem}
    .hero-brand-pill{font-size:.72rem;font-weight:700;padding:.35rem .8rem;border-radius:9999px;
      border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.45);letter-spacing:.04em}
    .scroll-hint{position:absolute;bottom:2rem;right:2rem;display:flex;flex-direction:column;
      align-items:center;gap:.4rem;color:rgba(255,255,255,.2);font-size:.68rem;font-weight:600;
      letter-spacing:.1em;text-transform:uppercase}
    .scroll-hint svg{animation:bounce 1.8s ease-in-out infinite}
    @keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

    /* ── PROBLEMA ── */
    .prob-grid{display:grid;grid-template-columns:1fr;gap:3rem;margin-top:3rem}
    @media(min-width:768px){.prob-grid{grid-template-columns:1fr 1fr;align-items:start}}
    .prob-body p{font-size:1.05rem;color:#4B5563;line-height:1.7;margin-bottom:1.25rem}
    .prob-list{list-style:none;margin:1rem 0 1.75rem;display:flex;flex-direction:column;gap:.85rem}
    .prob-list li{font-size:1rem;color:#374151;line-height:1.6;padding-left:1.5rem;position:relative}
    .prob-list li::before{content:'—';position:absolute;left:0;color:var(--c);font-weight:700}
    .prob-remate{font-size:1.05rem;font-weight:600;color:var(--c);line-height:1.65;
      border-left:3px solid var(--c);padding-left:1rem;margin-top:1.5rem}
    .stat-chips{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .stat-chip{background:var(--c);color:#fff;border-radius:16px;padding:1.5rem;
      display:flex;flex-direction:column;gap:.5rem}
    .stat-chip:first-child{grid-column:1/-1}
    .stat-n{font-size:2.25rem;font-weight:900;letter-spacing:-.04em;line-height:1}
    .stat-l{font-size:.78rem;color:rgba(255,255,255,.5);line-height:1.4}

    /* ── CALC ── */
    .calc-layout{display:grid;grid-template-columns:1fr;gap:2.5rem;margin-top:3.5rem}
    @media(min-width:900px){.calc-layout{grid-template-columns:1fr 1fr;align-items:start}}
    .calc-inputs{display:flex;flex-direction:column;gap:1.5rem}
    .ig{display:flex;flex-direction:column;gap:.5rem}
    .il{font-size:.8rem;font-weight:700;color:#374151;display:flex;justify-content:space-between}
    .iv{font-size:1rem;font-weight:800;color:var(--c)}
    input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:3px;
      background:#E5E7EB;border-radius:9999px;cursor:pointer;outline:none}
    input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;
      border-radius:50%;background:var(--c);border:2px solid #fff;
      box-shadow:0 1px 6px rgba(0,0,0,.2);cursor:pointer;transition:transform .15s}
    input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.2)}
    input[type=range]::-moz-range-thumb{width:18px;height:18px;border-radius:50%;
      background:var(--c);border:2px solid #fff;cursor:pointer}
    .ih{font-size:.72rem;color:#9CA3AF;font-style:italic}
    .calc-out{position:sticky;top:6rem;background:var(--c);color:#fff;border-radius:24px;
      padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.5rem}
    .star-ltop{font-size:.72rem;font-weight:700;letter-spacing:.15em;
      text-transform:uppercase;color:rgba(255,255,255,.4)}
    .star-num{font-size:clamp(2.75rem,7vw,4.5rem);font-weight:900;letter-spacing:-.04em;
      line-height:1;color:#fff}
    .star-sub{font-size:.82rem;color:rgba(255,255,255,.4);margin-top:.25rem}
    .breakdown{display:flex;flex-direction:column;gap:1rem}
    .br-row{display:flex;flex-direction:column;gap:.35rem}
    .br-lr{display:flex;justify-content:space-between;font-size:.78rem;font-weight:600}
    .br-ln{color:rgba(255,255,255,.6)}.br-lv{color:#fff}
    .br-bg{height:4px;background:rgba(255,255,255,.1);border-radius:9999px;overflow:hidden}
    .br-fill{height:100%;background:rgba(255,255,255,.7);border-radius:9999px;
      transition:width .6s var(--ease-out-expo);width:0}
    .calc-disc{font-size:.72rem;color:rgba(255,255,255,.28);line-height:1.5;
      padding-top:1rem;border-top:1px solid rgba(255,255,255,.08)}
    .calc-remate{margin-top:2.5rem;font-size:1.05rem;color:#374151;line-height:1.7;max-width:52ch}

    /* ── WHY FAIL ── */
    .fail-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:3rem}
    @media(min-width:640px){.fail-grid{grid-template-columns:1fr 1fr}}
    @media(min-width:900px){.fail-grid{grid-template-columns:1fr 1fr 1fr}}
    .fail-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
      border-radius:16px;padding:1.5rem}
    .fail-n{font-size:2rem;font-weight:900;color:rgba(255,255,255,.12);
      letter-spacing:-.04em;margin-bottom:.75rem}
    .fail-t{font-size:.92rem;color:rgba(255,255,255,.65);line-height:1.6}
    .fail-remate{margin-top:2.5rem;font-size:1.1rem;color:rgba(255,255,255,.5);
      line-height:1.7;max-width:52ch}
    .fail-remate strong{color:#fff}

    /* ── SISTEMA / EXPLORER ── */
    .layers-grid{display:grid;grid-template-columns:1fr;gap:.75rem;margin-top:2.5rem}
    @media(min-width:640px){.layers-grid{grid-template-columns:1fr 1fr}}
    .layer-card{border:1.5px solid var(--border);border-radius:16px;padding:1.25rem 1.5rem;
      display:flex;gap:1rem;align-items:flex-start;transition:border-color .2s,background .2s}
    .layer-card:hover{border-color:var(--c);background:rgba(26,26,26,.02)}
    .layer-n{font-size:2rem;font-weight:900;color:rgba(26,26,26,.1);
      letter-spacing:-.04em;line-height:1;flex-shrink:0}
    .layer-t{font-size:.95rem;font-weight:800;color:var(--c)}
    .layer-d{font-size:.85rem;color:#6B7280;line-height:1.5;margin-top:.3rem}

    #explorer{margin-top:4rem;background:var(--c);border-radius:24px;
      padding:2.5rem 2rem;color:#fff}
    .exp-h{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
      color:rgba(255,255,255,.35);margin-bottom:1.5rem}
    .exp-cols{display:grid;grid-template-columns:1fr;gap:2rem}
    @media(min-width:700px){.exp-cols{grid-template-columns:1fr 1fr}}
    .exp-col-t{font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
      color:rgba(255,255,255,.3);margin-bottom:1rem}
    .sub-chips{display:flex;flex-wrap:wrap;gap:.5rem}
    .sub-chip{font-size:.78rem;font-weight:600;padding:.4rem .85rem;border-radius:9999px;
      border:1.5px solid rgba(255,255,255,.14);color:rgba(255,255,255,.5);
      cursor:pointer;transition:all .2s;user-select:none;display:flex;align-items:center;gap:.4rem}
    .sub-chip:hover{border-color:rgba(255,255,255,.38);color:rgba(255,255,255,.8)}
    .sub-chip.active{background:#fff;color:var(--c);border-color:#fff}
    .chip-badge{font-size:.65rem;font-weight:800;background:rgba(255,255,255,.13);
      color:rgba(255,255,255,.55);padding:.1rem .38rem;border-radius:9999px}
    .sub-chip.active .chip-badge{background:rgba(26,26,26,.1);color:var(--c)}
    .plat-list{display:flex;flex-direction:column;gap:.35rem}
    .plat-item{font-size:.88rem;padding:.55rem .85rem;border-radius:10px;
      color:rgba(255,255,255,.42);border:1px solid transparent;
      transition:all .2s;cursor:pointer;user-select:none}
    .plat-item:hover{color:rgba(255,255,255,.78);background:rgba(255,255,255,.05)}
    .plat-item.active{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.14)}
    .plat-item.dimmed{opacity:.22}
    .plat-subs{display:flex;flex-wrap:wrap;gap:.28rem;margin-top:.3rem}
    .plat-sub-tag{font-size:.63rem;font-weight:600;padding:.12rem .45rem;border-radius:9999px;
      background:rgba(255,255,255,.07);color:rgba(255,255,255,.38);transition:all .2s}
    .plat-sub-tag.hl{background:rgba(255,255,255,.2);color:rgba(255,255,255,.85)}
    .exp-punch{margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,.08);
      font-size:.88rem;color:rgba(255,255,255,.38);text-align:center}
    .exp-punch strong{color:#fff;font-size:1.05rem}
    .exp-punch.sel{color:rgba(255,255,255,.6)}
    .exp-punch.sel strong{font-size:1.2rem}
    .exp-yasu-note{margin-top:1rem;padding:.85rem 1rem;background:rgba(255,255,255,.04);
      border-radius:10px;font-size:.8rem;color:rgba(255,255,255,.4);line-height:1.55}
    .exp-yasu-note strong{color:rgba(255,255,255,.7)}

    /* ── PRODUCCIÓN ── */
    .prod-body{font-size:1.05rem;color:rgba(255,255,255,.55);line-height:1.7;
      max-width:52ch;margin:2rem 0}
    .prod-body p+p{margin-top:1rem}
    .prod-feats{display:grid;grid-template-columns:1fr;gap:1px;
      background:rgba(255,255,255,.07);border-radius:20px;overflow:hidden;margin-top:3rem}
    @media(min-width:640px){.prod-feats{grid-template-columns:1fr 1fr}}
    @media(min-width:900px){.prod-feats{grid-template-columns:repeat(4,1fr)}}
    .prod-feat{background:var(--c);padding:1.75rem 1.5rem;
      display:flex;flex-direction:column;gap:.65rem;transition:background .2s}
    .prod-feat:hover{background:#252525}
    .pf-icon{font-size:1.4rem;line-height:1}
    .pf-t{font-size:.92rem;font-weight:800;color:#fff;line-height:1.3}
    .pf-d{font-size:.8rem;color:rgba(255,255,255,.42);line-height:1.5}
    .prod-result{margin-top:3rem;background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:2rem;max-width:56ch}
    .prod-result p{font-size:1.1rem;color:rgba(255,255,255,.7);line-height:1.65}
    .prod-result strong{color:#fff}

    /* ── DEMO ── */
    .demo-layout{display:grid;grid-template-columns:1fr;gap:3rem;margin-top:3.5rem;align-items:center}
    @media(min-width:768px){.demo-layout{grid-template-columns:1fr 1fr}}
    .qr-mock{aspect-ratio:1;max-width:260px;margin:0 auto;border:2px dashed var(--border);
      border-radius:20px;display:flex;flex-direction:column;align-items:center;
      justify-content:center;gap:1rem;color:#9CA3AF;background:var(--g)}
    .qr-icon{font-size:2.75rem;line-height:1}
    .qr-label{font-size:.78rem;font-weight:600;text-align:center;line-height:1.5}
    .demo-steps{display:flex;flex-direction:column;gap:1.25rem}
    .demo-step{display:flex;gap:1rem;align-items:flex-start}
    .demo-step-n{width:2rem;height:2rem;border-radius:50%;background:var(--c);color:#fff;
      font-size:.78rem;font-weight:800;display:flex;align-items:center;
      justify-content:center;flex-shrink:0}
    .demo-step-t{font-size:.92rem;font-weight:700;color:var(--c);padding-top:.25rem}
    .demo-step-d{font-size:.85rem;color:#6B7280;line-height:1.5;margin-top:.2rem}

    /* ── OFERTA ── */
    .offer-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:3.5rem}
    @media(min-width:900px){.offer-grid{grid-template-columns:1fr 1fr 1fr;align-items:start}}
    .offer-card{border-radius:20px;padding:2rem 1.75rem;display:flex;flex-direction:column;gap:1rem}
    .oc1{background:var(--w);border:2px solid var(--c)}
    .oc2{background:var(--w);border:1.5px solid var(--border)}
    .oc3{background:var(--c);color:#fff}
    .offer-step{font-size:.7rem;font-weight:800;letter-spacing:.12em;
      text-transform:uppercase;color:var(--mid)}
    .oc3 .offer-step{color:rgba(255,255,255,.38)}
    .offer-h{font-size:1.35rem;font-weight:900;letter-spacing:-.02em;line-height:1.15}
    .oc3 .offer-h{color:#fff}
    .offer-pp{display:inline-block;padding:.25rem .75rem;
      border:1.5px dashed var(--border);border-radius:8px;
      font-size:.95rem;font-weight:700;color:var(--mid)}
    .oc3 .offer-pp{border-color:rgba(255,255,255,.2);color:rgba(255,255,255,.45)}
    .offer-d{font-size:.88rem;color:#4B5563;line-height:1.65}
    .oc3 .offer-d{color:rgba(255,255,255,.55)}
    .offer-tag{font-size:.73rem;font-weight:700;padding:.32rem .75rem;
      border-radius:9999px;align-self:flex-start;
      background:rgba(26,26,26,.07);color:var(--c)}
    .offer-anchor{margin-top:2.5rem;padding:2rem;background:rgba(26,26,26,.04);
      border-radius:16px;max-width:58ch}
    .offer-anchor p{font-size:1rem;color:#374151;line-height:1.65}
    .offer-anchor strong{color:var(--c);font-weight:800}
    #star-anchor{font-size:1.5rem;font-weight:900;letter-spacing:-.03em;color:var(--c)}
    .offer-prop{margin-top:1.5rem;padding:1.5rem;border:1px solid var(--border);
      border-radius:16px;max-width:58ch;font-size:.88rem;color:#4B5563;line-height:1.65}
    .offer-prop strong{color:var(--c)}

    /* ── CTA ── */
    #piloto{text-align:center}
    .cta-big{font-size:clamp(1.9rem,5vw,3.75rem);font-weight:900;letter-spacing:-.03em;
      color:#fff;line-height:1.05;max-width:22ch;margin:0 auto 1.5rem}
    .cta-sub{font-size:1rem;color:rgba(255,255,255,.48);max-width:44ch;
      margin:0 auto 2.5rem;line-height:1.65}
    .cta-btns{display:flex;flex-direction:column;align-items:center;gap:1rem}
    @media(min-width:480px){.cta-btns{flex-direction:row;justify-content:center}}
    .cta-note{margin:1.5rem auto 0;font-size:.8rem;color:rgba(255,255,255,.28);
      max-width:44ch;line-height:1.55}

    /* ── FOOTER ── */
    #foot{padding:3.5rem 0;border-top:1px solid var(--border);background:var(--ww)}
    .foot-inner{display:flex;flex-direction:column;gap:1.25rem;align-items:flex-start}
    @media(min-width:640px){.foot-inner{flex-direction:row;align-items:center;justify-content:space-between}}
    .foot-logo img{height:26px;width:auto;display:block}
    .foot-copy{font-size:.83rem;color:#6B7280;line-height:1.6;max-width:52ch}
    .foot-link{color:var(--c);font-weight:600;text-decoration:none}
    .foot-link:hover{text-decoration:underline}

    /* ── PRINT ── */
    #print-pg{display:none}
    @media print{
      #pnav,#hero,#problema,#calculadora,#fallan,#sistema,
      #produccion,#demo,#oferta,#piloto,#foot{display:none!important}
      #print-pg{display:block!important;font-family:'Inter',system-ui,sans-serif;
        color:#1a1a1a;padding:2rem;max-width:780px;margin:0 auto}
      .pr-logo{font-size:1.25rem;font-weight:900;letter-spacing:-.03em;margin-bottom:.25rem}
      .pr-date{font-size:.72rem;color:#9CA3AF;margin-bottom:2.5rem}
      .pr-title{font-size:1.9rem;font-weight:900;letter-spacing:-.03em;margin-bottom:.4rem}
      .pr-sub{font-size:.9rem;color:#4B5563;margin-bottom:2.5rem}
      .pr-box{border:2px solid #1a1a1a;border-radius:14px;padding:1.75rem;
        margin-bottom:2rem;text-align:center}
      .pr-box-l{font-size:.68rem;font-weight:700;letter-spacing:.12em;
        text-transform:uppercase;color:#9CA3AF;margin-bottom:.4rem}
      .pr-star{font-size:3.25rem;font-weight:900;letter-spacing:-.04em}
      .pr-note{font-size:.75rem;color:#9CA3AF;margin-top:.4rem}
      .pr-steps{display:flex;flex-direction:column;gap:.85rem;margin-bottom:2rem}
      .pr-step{display:flex;gap:1rem;align-items:flex-start;padding:1.1rem;
        border:1px solid #E5E7EB;border-radius:11px}
      .pr-step-n{font-size:1.5rem;font-weight:900;color:#E5E7EB;flex-shrink:0}
      .pr-step-t{font-size:.88rem;font-weight:700}
      .pr-step-d{font-size:.78rem;color:#4B5563;line-height:1.5;margin-top:.2rem}
      .pr-cta{font-size:.95rem;font-weight:700;text-align:center;padding:.9rem;
        background:#1a1a1a;color:#fff;border-radius:10px}
      .pr-foot{margin-top:1.75rem;font-size:.68rem;color:#9CA3AF;
        text-align:center;border-top:1px solid #F3F3F3;padding-top:.85rem}
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav id="pnav">
  <div class="pnav-inner">
    <a href="https://antemano.com.mx" class="pnav-logo">
      <img src="/logo.png" alt="Antemano" />
    </a>
    <span class="pnav-tag">Sistema de Capacitación para Restaurantes</span>
    <a href="#piloto" class="btn btn-light" style="font-size:.78rem;padding:.55rem 1.2rem;">Quiero el Piloto</a>
  </div>
</nav>

<!-- S1: HERO -->
<section id="hero">
  <div class="container">
    <p class="hero-tag reveal">Propuesta para Grupo Caribe</p>
    <h1 class="hero-h1 reveal reveal-d1">
      Cada vez que renuncia un cocinero, tu mejor receta se va <em class="si">con él.</em>
    </h1>
    <p class="hero-sub reveal reveal-d2">
      En Yasuko, en Spiral, en Ototo, en El Caribeño. Cuatro cocinas distintas, cuatro cartas que viven en la memoria de personas que pueden renunciar mañana.
    </p>
    <div class="hero-brands reveal reveal-d2">
      {marcas.map(m => <span class="hero-brand-pill">{m}</span>)}
    </div>
    <a href="#calculadora" class="btn btn-light reveal reveal-d3">
      Ver cuánto le está costando al grupo
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    </a>
  </div>
  <div class="scroll-hint" aria-hidden="true">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    <span>scroll</span>
  </div>
</section>

<!-- S2: PROBLEMA -->
<section id="problema" class="s-light">
  <div class="container">
    <p class="eyebrow-dark reveal">El diagnóstico</p>
    <div class="prob-grid">
      <div>
        <h2 class="h2 reveal">
          No es un problema de capacitación.<br>
          Es un problema de <em class="si">memoria.</em>
        </h2>
        <div class="prob-body" style="margin-top:2rem;">
          <p>El reto de Grupo Caribe no es capacitar en un restaurante. Es mantener el estándar en cuatro conceptos completamente distintos —desde el shari de Yasuko hasta el recado negro de El Caribeño— con equipos que rotan y cocinas que no comparten ni una sola receta.</p>
          <p>Mientras tanto, en cada marca:</p>
          <ul class="prob-list">
            <li>El que entrena es tu chef o cocinero más caro, fuera de la línea, repitiendo lo mismo con cada nuevo.</li>
            <li>El roll o el platillo sale diferente según quién esté en turno. El cliente lo nota — y no regresa.</li>
            <li>Cada cocinero porciona "al ojo". Ahí se va el food cost, gramo por gramo, en las cuatro marcas.</li>
            <li>Cuando cambias la carta, tardas semanas en que el nuevo platillo salga parejo en toda la cocina.</li>
          </ul>
          <p class="prob-remate">
            Cuatro marcas sin sistema documentado = cuatro veces el mismo problema.<br>
            Ese costo se puede medir. Y se puede bajar.
          </p>
        </div>
        <a href="#calculadora" class="btn btn-dark" style="margin-top:2rem;">Calcular el costo real →</a>
      </div>

      <div class="stat-chips reveal reveal-d2">
        <div class="stat-chip">
          <span class="stat-n">4 marcas</span>
          <span class="stat-l">Yasuko, Spiral, Ototo, El Caribeño — cuatro cocinas distintas, un solo problema sin resolver</span>
        </div>
        <div class="stat-chip">
          <span class="stat-n">~40</span>
          <span class="stat-l">SKUs solo en El Caribeño. De esos, 12 guisos base generan el 100 % de la carta</span>
        </div>
        <div class="stat-chip">
          <span class="stat-n">3 sem</span>
          <span class="stat-l">Lo que tarda un cocinero nuevo en ejecutar al estándar sin material de apoyo</span>
        </div>
        <div class="stat-chip">
          <span class="stat-n">75 %</span>
          <span class="stat-l">Rotación anual en la industria restaurantera. El conocimiento renuncia con las personas</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- S3: CALCULADORA -->
<section id="calculadora" class="s-white">
  <div class="container">
    <p class="eyebrow-dark reveal">Calculadora de impacto — Grupo Caribe</p>
    <h2 class="h2 reveal reveal-d1">Mete los números del grupo.<br>Mira lo que estás <em class="si">dejando en la mesa.</em></h2>
    <p class="ssub reveal reveal-d2">Los defaults son estimados para un grupo de 4 marcas. Ajústalos con tus cifras reales.</p>

    <div class="calc-layout">
      <div class="calc-inputs">
        <div class="ig reveal">
          <label class="il">Cocineros en el grupo (total 4 marcas)<span class="iv" id="v-cocineros">20</span></label>
          <input type="range" id="s-cocineros" min="4" max="80" value="20" step="1" />
          <span class="ih">Total de personas en cocina sumando las 4 marcas</span>
        </div>
        <div class="ig reveal reveal-d1">
          <label class="il">Contrataciones por año (grupo)<span class="iv" id="v-rotacion">15</span></label>
          <input type="range" id="s-rotacion" min="2" max="60" value="15" step="1" />
          <span class="ih">¿Cuántos cocineros nuevos contratas en total al año?</span>
        </div>
        <div class="ig reveal reveal-d1">
          <label class="il">Días hasta que opera al estándar<span class="iv" id="v-dias">21 días</span></label>
          <input type="range" id="s-dias" min="7" max="60" value="21" step="1" />
          <span class="ih">¿Cuánto tarda un nuevo en ser autónomo en su estación?</span>
        </div>
        <div class="ig reveal reveal-d2">
          <label class="il">Costo-hora del que entrena<span class="iv" id="v-hora">$150/hr</span></label>
          <input type="range" id="s-hora" min="80" max="500" value="150" step="10" />
          <span class="ih">Chef o cocinero senior que saca de la línea para capacitar</span>
        </div>
        <div class="ig reveal reveal-d2">
          <label class="il">Food cost actual vs. objetivo<span class="iv" id="v-fc">35% vs 30%</span></label>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
            <div><input type="range" id="s-fc-actual" min="20" max="60" value="35" step="1" /><span class="ih">Actual</span></div>
            <div><input type="range" id="s-fc-obj" min="15" max="55" value="30" step="1" /><span class="ih">Objetivo</span></div>
          </div>
        </div>
        <div class="ig reveal reveal-d2">
          <label class="il">Venta mensual del grupo<span class="iv" id="v-venta">$800k</span></label>
          <input type="range" id="s-venta" min="100000" max="5000000" value="800000" step="50000" />
          <span class="ih">Suma de ventas mensuales de las 4 marcas</span>
        </div>
        <div class="ig reveal reveal-d3">
          <label class="il">Platillos rehechos o devueltos / semana<span class="iv" id="v-dev">12</span></label>
          <input type="range" id="s-dev" min="0" max="60" value="12" step="1" />
          <span class="ih">Suma de devoluciones en todas las marcas por inconsistencia</span>
        </div>
      </div>

      <div class="calc-out reveal reveal-d1">
        <div>
          <p class="star-ltop">Costo anual del sistema actual — Grupo Caribe</p>
          <p class="star-num" id="star-num">$1,144,560</p>
          <p class="star-sub">por año — estimado con tus datos del grupo</p>
        </div>
        <div class="breakdown">
          <div class="br-row">
            <div class="br-lr"><span class="br-ln">Capacitación</span><span class="br-lv" id="br-cap">$267,750</span></div>
            <div class="br-bg"><div class="br-fill" id="bar-cap"></div></div>
          </div>
          <div class="br-row">
            <div class="br-lr"><span class="br-ln">Rotación</span><span class="br-lv" id="br-rot">$75,000</span></div>
            <div class="br-bg"><div class="br-fill" id="bar-rot"></div></div>
          </div>
          <div class="br-row">
            <div class="br-lr"><span class="br-ln">Merma / food cost</span><span class="br-lv" id="br-mer">$480,000</span></div>
            <div class="br-bg"><div class="br-fill" id="bar-mer"></div></div>
          </div>
          <div class="br-row">
            <div class="br-lr"><span class="br-ln">Devoluciones</span><span class="br-lv" id="br-dev">$174,720</span></div>
            <div class="br-bg"><div class="br-fill" id="bar-dev"></div></div>
          </div>
        </div>
        <p class="calc-disc">Estimado con benchmarks de la industria. Ajusta los sliders con cifras reales para mayor precisión. El número de capacitación asume 4 horas diarias de entrenador por nuevo contratado.</p>
      </div>
    </div>

    <p class="calc-remate reveal">Ese número ya lo estás pagando cada año — solo que no aparece en ningún reporte. No está en el P&L. No lo ve tu contador. Pero está ahí.</p>
    <a href="#fallan" class="btn btn-dark reveal" style="margin-top:2rem;">Ver cómo dejas de pagarlo →</a>
  </div>
</section>

<!-- S4: POR QUÉ FALLAN -->
<section id="fallan" class="s-dark">
  <div class="container">
    <p class="eyebrow reveal">El problema con lo que existe</p>
    <h2 class="h2 reveal reveal-d1" style="color:#fff;">El 88 % abandona la capacitación.<br>Y con <em class="si">razón.</em></h2>
    <div class="fail-grid">
      {[
        { n:'01', t:'Un PDF de 80 páginas que nadie abre. Si lo abren, no lo terminan. Si lo terminan, no lo aplican en la línea.' },
        { n:'02', t:'Un video corporativo plano grabado con un celular fijo. Tu equipo consume short-form todo el día — eso no lo van a ver.' },
        { n:'03', t:'Una carpeta en Drive sin orden. Nadie sabe qué buscar, nadie sabe dónde está. El que sabía ya renunció.' },
        { n:'04', t:'El entrenamiento verbal no escala entre marcas. En Yasuko se aprende diferente que en El Caribeño. El estándar muere con quien lo enseñó.' },
        { n:'05', t:'Capacitación que se ve mal en el celular. Tu personal está en la cocina, con una mano, sin tiempo. Si no carga en 3 segundos, no sirve.' },
        { n:'06', t:'Material que se pudre. Cambias la carta, y el video sigue mostrando el platillo viejo. Nadie lo actualiza. El sistema muere.' },
      ].map(c => (
        <div class="fail-card reveal">
          <div class="fail-n">{c.n}</div>
          <p class="fail-t">{c.t}</p>
        </div>
      ))}
    </div>
    <p class="fail-remate reveal">
      <strong>Una carpeta de videos en Drive no es un sistema.</strong><br>
      Es un cementerio de buenas intenciones.<br>
      Nosotros no hacemos eso.
    </p>
    <a href="#sistema" class="btn btn-light reveal" style="margin-top:2.5rem;">Entonces qué hacen →</a>
  </div>
</section>

<!-- S5: EL SISTEMA -->
<section id="sistema" class="s-light">
  <div class="container">
    <p class="eyebrow-dark reveal">La solución</p>
    <h2 class="h2 reveal reveal-d1">No te vendemos videos.<br>Te construimos un <em class="si">sistema.</em></h2>
    <p class="ssub reveal reveal-d2" style="max-width:60ch;">
      El Caribeño no tiene 40 recetas independientes. Tiene 12 guisos base que se sirven en 5 formatos. La misma cebolla curtida vive en 10 platillos. El mismo recado rojo, en 7. Por eso el sistema se arma en capas que se reutilizan — y cerca del 40 % del contenido sirve a más de un platillo.
    </p>

    <div class="layers-grid">
      {[
        { n:'01', t:'Contenido', d:'Protocolos, subrecetas base y platillos de cada marca. El conocimiento de tu cocina, filmado al estándar de Antemano.' },
        { n:'02', t:'Acceso', d:'QR en cada estación. Tu cocinero escanea y cae al video exacto en 3 segundos. Sin apps, sin login, sin buscar.' },
        { n:'03', t:'Vivo', d:'Cambias la carta, actualizamos el video. El mismo QR ya apunta a la versión nueva. El sistema no se pudre.' },
        { n:'04', t:'Medible', d:'Sabes qué módulos se están usando, qué rutas se completan y cuánto baja tu tiempo de onboarding.' },
      ].map(l => (
        <div class="layer-card reveal">
          <div class="layer-n">{l.n}</div>
          <div><div class="layer-t">{l.t}</div><div class="layer-d">{l.d}</div></div>
        </div>
      ))}
    </div>

    <!-- Explorador modular -->
    <div id="explorer">
      <p class="exp-h">Explorador modular — El Caribeño (toca una subreceta)</p>
      <div class="exp-cols">
        <div>
          <p class="exp-col-t">Subrecetas base ({subrecetas.length})</p>
          <div class="sub-chips" id="sub-chips">
            {subrecetas.map(s => (
              <button class="sub-chip" data-sub-id={s.id} aria-pressed="false">
                {s.name}<span class="chip-badge">{s.count}</span>
              </button>
            ))}
          </div>
        </div>
        <div>
          <p class="exp-col-t">Platillos ({platillos.length} de ~40)</p>
          <div class="plat-list" id="plat-list">
            {platillos.map(p => (
              <div class="plat-item" data-plat-id={p.id} data-subs={p.subs.join(',')}>
                <div>{p.name}</div>
                <div class="plat-subs">
                  {p.subs.map(sid => {
                    const sr = subrecetas.find(s => s.id === sid);
                    return <span class="plat-sub-tag" data-tag-sub={sid}>{sr?.name}</span>;
                  })}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="exp-punch" id="exp-punch">
        <strong>Toca "Cebolla morada curtida"</strong> — el mejor ejemplo del sistema.
      </div>
      <div class="exp-yasu-note">
        <strong>En Yasuko aplica igual:</strong> el arroz de sushi (shari) aparece en los 30+ rolls de la carta. 1 video de cómo preparar el shari = todos los rolls. La spicy mayo: 8 platillos. La tempura batter: 5. El sistema es el mismo — el contenido es de Yasuko.
      </div>
    </div>
  </div>
</section>

<!-- S6: PRODUCCIÓN ⭐ -->
<section id="produccion" class="s-dark">
  <div class="container">
    <p class="eyebrow reveal">Lo que nos diferencia</p>
    <h2 class="h2 reveal reveal-d1" style="color:#fff;">Si tu personal lo abandona a los 10 segundos,<br><em class="si">no sirve.</em> Punto.</h2>
    <div class="prod-body reveal reveal-d1">
      <p>La mayoría de quienes hacen "videos de capacitación" ponen una cámara fija frente al cocinero y graban 8 minutos planos. Nadie los ve completo.</p>
      <p>Antemano es productora audiovisual. Producimos contenido para que se consuma, no para que se archive. Lo mismo que hacemos para las redes de tus marcas, lo aplicamos a la capacitación.</p>
    </div>
    <div class="prod-feats reveal">
      {[
        { icon:'📱', t:'Vertical, para el celular', d:'Se ve en la estación, con una mano, en la pantalla que tu equipo ya trae en la bolsa.' },
        { icon:'⚡', t:'30–90 segundos por video', d:'Una técnica, un paso, una subreceta. Si es más largo, lo partimos. Cero relleno.' },
        { icon:'🎯', t:'Hook en 3 segundos', d:'Arranca con el resultado final — el platillo terminado, el corte perfecto — para que sepan a dónde van antes de ver el proceso.' },
        { icon:'📝', t:'Texto y gramajes en pantalla', d:'La cocina es ruidosa y a veces sin sonido. El gramaje del recado, la temperatura del aceite: se lee, no solo se escucha.' },
        { icon:'✅', t:'"Así se ve bien / así se ve mal"', d:'No solo el paso: el criterio de qué es correcto. Tu estándar visible, no interpretable.' },
        { icon:'🎬', t:'Color de cine — DaVinci Resolve', d:'La cochinita pibil de El Caribeño y el sashimi de Yasuko merecen producción que haga honor a su calidad.' },
        { icon:'🏷️', t:'Plantilla por marca', d:'Cada restaurante tiene su identidad: tipografía, color, intro. El cocinero sabe al instante si está en Yasuko o en El Caribeño.' },
        { icon:'🔁', t:'Sistema que no se pudre', d:'Cambia la carta, actualizamos el video. El mismo QR ya apunta a la versión nueva. No hay nada que descargar.' },
      ].map(f => (
        <div class="prod-feat reveal">
          <div class="pf-icon">{f.icon}</div>
          <div class="pf-t">{f.t}</div>
          <div class="pf-d">{f.d}</div>
        </div>
      ))}
    </div>
    <div class="prod-result reveal">
      <p>El resultado: capacitación que tu personal <strong>ve hasta el final</strong>, en cualquiera de las cuatro marcas, porque por fin se parece a algo que sí querrían ver.</p>
    </div>
    <a href="#demo" class="btn btn-light reveal" style="margin-top:2rem;">Ver cómo se ve →</a>
  </div>
</section>

<!-- S7: DEMO -->
<section id="demo" class="s-light">
  <div class="container">
    <p class="eyebrow-dark reveal">Demo funcional</p>
    <h2 class="h2 reveal reveal-d1">Escanéalo.<br>Es <em class="si">de verdad.</em></h2>
    <p class="ssub reveal reveal-d2">No es una promesa. Es un módulo terminado — lo que vería tu cocinero en la estación de El Caribeño o Yasuko al escanear el QR.</p>
    <div class="demo-layout">
      <div class="qr-mock reveal">
        <div class="qr-icon">⬛</div>
        <p class="qr-label">
          Video demo<br>
          <strong style="color:#374151;">próximamente</strong><br>
          <span style="font-size:.68rem;color:#9CA3AF;">se activa con el piloto</span>
        </p>
      </div>
      <div class="demo-steps reveal reveal-d1">
        <p style="font-size:.95rem;color:#374151;font-weight:600;margin-bottom:.5rem;">Así funciona en la operación:</p>
        {[
          { n:'1', t:'QR pegado en la estación', d:'Sin apps que descargar, sin contraseñas, sin capacitación para usar la capacitación. Un código en la pared.' },
          { n:'2', t:'Video en 3 segundos', d:'El cocinero escanea y cae directo al video que necesita. En Yasuko: cómo preparar el shari. En El Caribeño: cómo hacer el recado negro.' },
          { n:'3', t:'30–90 segundos y a trabajar', d:'Ve el video, lo aplica, sigue. Si necesita verlo otra vez, lo escanea otra vez. Sin preguntar al chef.' },
          { n:'4', t:'Siempre actualizado', d:'Cuando El Caribeño cambia su cochinita o Yasuko lanza un roll nuevo, actualizamos el video. El mismo QR ya apunta a la versión correcta.' },
        ].map(s => (
          <div class="demo-step reveal">
            <div class="demo-step-n">{s.n}</div>
            <div><p class="demo-step-t">{s.t}</p><p class="demo-step-d">{s.d}</p></div>
          </div>
        ))}
        <p style="margin-top:1rem;font-size:.85rem;color:#6B7280;font-style:italic;">
          Eso que acabas de ver, multiplicado por la carta completa de cada una de tus marcas y organizado para que nunca se pierda. Eso es <strong style="color:#1a1a1a;font-style:normal;">Manual Vivo.</strong>
        </p>
      </div>
    </div>
    <a href="#oferta" class="btn btn-dark reveal" style="margin-top:3rem;">Ver cómo empezamos →</a>
  </div>
</section>

<!-- S8: OFERTA -->
<section id="oferta" class="s-white">
  <div class="container">
    <p class="eyebrow-dark reveal">La propuesta</p>

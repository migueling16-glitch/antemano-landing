      platLabelEl.innerHTML = 'Platillos <span style="color:rgba(255,255,255,.3);font-weight:600;text-transform:none;letter-spacing:0;">' + cur.platLabel + '</span>';
      subChipsEl.innerHTML = cur.subs.map(s =>
        `<button class="sub-chip" data-sub-id="${s.id}" aria-pressed="false">${s.name}<span class="chip-badge">${s.count}</span></button>`
      ).join('');
      platListEl.innerHTML = cur.plats.map((p, i) => {
        const tags = p.subs.map(sid => {
          const sr = cur.subs.find(s => s.id === sid);
          return `<span class="plat-sub-tag" data-tag-sub="${sid}">${sr ? sr.name : ''}</span>`;
        }).join('');
        return `<div class="plat-item" data-plat-id="${i}" data-subs="${p.subs.join(',')}"><div>${p.name}</div><div class="plat-subs">${tags}</div></div>`;
      }).join('');
      resetPunch();
    }

    function clearSel() {
      subChipsEl.querySelectorAll('.sub-chip').forEach(c => { c.classList.remove('active'); c.setAttribute('aria-pressed', 'false'); });
      platListEl.querySelectorAll('.plat-item').forEach(p => p.classList.remove('active', 'dimmed'));
      platListEl.querySelectorAll('.plat-sub-tag').forEach(t => t.classList.remove('hl'));
      activeSub = null; activePlat = null;
      resetPunch();
    }

    subChipsEl.addEventListener('click', (e) => {
      const chip = e.target.closest('.sub-chip'); if (!chip) return;
      const sid = parseInt(chip.dataset.subId);
      if (activeSub === sid) { clearSel(); return; }
      clearSel(); activeSub = sid;
      chip.classList.add('active'); chip.setAttribute('aria-pressed', 'true');
      let count = 0;
      platListEl.querySelectorAll('.plat-item').forEach(p => {
        const subs = (p.dataset.subs || '').split(',').filter(Boolean).map(Number);
        if (subs.includes(sid)) {
          p.classList.add('active'); count++;
          p.querySelectorAll('.plat-sub-tag').forEach(t => { if (parseInt(t.dataset.tagSub) === sid) t.classList.add('hl'); });
        } else { p.classList.add('dimmed'); }
      });
      const sname = cur.subs.find(s => s.id === sid).name;
      punch.classList.add('sel');
      punch.innerHTML = `<strong>1 video de "${sname}" = ${count} ${count === 1 ? 'platillo' : 'platillos'}</strong> — el mismo estándar, reutilizado.`;
    });

    platListEl.addEventListener('click', (e) => {
      const platEl = e.target.closest('.plat-item'); if (!platEl) return;
      const pid = platEl.dataset.platId;
      if (activePlat === pid) { clearSel(); return; }
      clearSel(); activePlat = pid;
      platEl.classList.add('active');
      const subs = (platEl.dataset.subs || '').split(',').filter(Boolean).map(Number);
      subChipsEl.querySelectorAll('.sub-chip').forEach(c => { if (subs.includes(parseInt(c.dataset.subId))) c.classList.add('active'); });
      platEl.querySelectorAll('.plat-sub-tag').forEach(t => t.classList.add('hl'));
      punch.classList.add('sel');
      punch.innerHTML = `Este platillo se arma con <strong>${subs.length} ${subs.length === 1 ? 'base' : 'bases'}</strong> — cada una compartida con otros platillos.`;
    });

    tabs.forEach(tab => tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      render(tab.dataset.brand);
    }));

    render('spiral');

    /* ── Print ── */
    const stamp = () => {
      const d = document.getElementById('pr-date-val');
      if (d) d.textContent = new Date().toLocaleDateString('es-MX', { year:'numeric', month:'long', day:'numeric' });
    };
    stamp();
    const pBtn = document.getElementById('btn-print');
    if (pBtn) pBtn.addEventListener('click', () => {
      stamp();
      const ps = document.getElementById('pr-star');
      if (ps) ps.textContent = document.getElementById('star-num').textContent;
      window.print();
    });
  })();
</script>
</body>
</html>

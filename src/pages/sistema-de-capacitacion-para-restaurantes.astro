    <p class="pr-note">Calculado con tus datos. Ya lo estás pagando — no aparece en ningún reporte.</p>
  </div>
  <div class="pr-steps">
    <div class="pr-step"><span class="pr-step-n">01</span><div><p class="pr-step-t">El Piloto</p><p class="pr-step-d">3 videos en una de tus marcas (sugerido: El Caribeño). Ves la calidad y el sistema funcionando antes de comprometerte a más.</p></div></div>
    <div class="pr-step"><span class="pr-step-n">02</span><div><p class="pr-step-t">La Biblioteca</p><p class="pr-step-d">Sistema completo por marca con QR por estación. Se escala a las 4 marcas en fases. ~40 % del contenido es reutilizable dentro de El Caribeño.</p></div></div>
    <div class="pr-step"><span class="pr-step-n">03</span><div><p class="pr-step-t">Mantenimiento (Manual Vivo)</p><p class="pr-step-d">El sistema se mantiene actualizado. Cambios de carta, nuevos platillos, auditoría trimestral. Retainer mensual.</p></div></div>
  </div>
  <p class="pr-cta">Próximo paso: el Piloto — antemano.com.mx</p>
  <p class="pr-foot">Propuesta privada preparada por Antemano Taller Creativo · Durango, México · antemano.com.mx</p>
</div>

<script is:inline>
(function(){
  /* Reveal */
  const io = new IntersectionObserver(
    es => es.forEach(e => { if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)} }),
    {threshold:.08,rootMargin:'0px 0px -40px 0px'}
  );
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* Sticky nav */
  const nav = document.getElementById('pnav');
  window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 60), {passive:true});

  /* Calculator */
  let displayed = 0, rafId = null, savedTotal = 0;
  const fmt = n => '$' + Math.round(n).toLocaleString('es-MX');
  const get = id => parseFloat(document.getElementById(id).value);
  const setText = (id,v) => { const el = document.getElementById(id); if(el) el.textContent = v; };

  function calc(){
    const cocineros = get('s-cocineros'), rotacion = get('s-rotacion'),
          dias = get('s-dias'), hora = get('s-hora'),
          fcA = get('s-fc-actual'), fcO = get('s-fc-obj'),
          venta = get('s-venta'), dev = get('s-dev');

    setText('v-cocineros', cocineros);
    setText('v-rotacion', rotacion);
    setText('v-dias', dias + ' días');
    setText('v-hora', '$' + hora + '/hr');
    setText('v-fc', fcA + '% vs ' + fcO + '%');
    setText('v-venta', '$' + Math.round(venta/1000) + 'k');
    setText('v-dev', dev);

    const cap = (dias * 4 * hora + dias * 250) * rotacion;
    const rot = rotacion * 5000;
    const mer = Math.max(0, (fcA - fcO) / 100) * venta * 12;
    const dv  = dev * 280 * 52;
    const total = cap + rot + mer + dv;

    setText('br-cap', fmt(cap)); setText('br-rot', fmt(rot));
    setText('br-mer', fmt(mer)); setText('br-dev', fmt(dv));

    const mx = Math.max(cap, rot, mer, dv, 1);
    ['cap','rot','mer','dev'].forEach((k,i) => {
      const v = [cap,rot,mer,dv][i];
      const el = document.getElementById('bar-' + k);
      if(el) el.style.width = (v/mx*100) + '%';
    });

    savedTotal = total;
    animateTo(total);
    setText('pr-star', fmt(total));
    setText('star-anchor', fmt(total));
  }

  function animateTo(target){
    if(rafId) cancelAnimationFrame(rafId);
    const start = displayed, diff = target - start, dur = 600, t0 = performance.now();
    function tick(now){
      const p = Math.min((now-t0)/dur,1), e = 1-Math.pow(1-p,3);
      displayed = start + diff*e;
      setText('star-num', fmt(displayed));
      if(p<1) rafId = requestAnimationFrame(tick);
    }
    rafId = requestAnimationFrame(tick);
  }

  ['s-cocineros','s-rotacion','s-dias','s-hora','s-fc-actual','s-fc-obj','s-venta','s-dev']
    .forEach(id => { const el = document.getElementById(id); if(el) el.addEventListener('input', calc); });
  calc();

  /* Explorer */
  const platData = {
    'p1':{subs:[2,3,8]},'p2':{subs:[2,3,5,8]},'p3':{subs:[2,3,8]},
    'p4':{subs:[2,3,7]},'p5':{subs:[2,3,6]},'p6':{subs:[2,11,3]},
    'p7':{subs:[1,5,8]},'p8':{subs:[10,7,8]},'p9':{subs:[10,7,3]},
    'p10':{subs:[10,9,8]},'p11':{subs:[1,4,5,8]},'p12':{subs:[4,12,6]},
    'p13':{subs:[2,3,7]},'p14':{subs:[1,5,3,8]},'p15':{subs:[10,7,3]},
  };
  const subNames = {
    1:'Recado negro',2:'Recado rojo / achiote',3:'Cebolla morada curtida',
    4:'Habanero tatemado',5:'Frijoles negros colados',6:'Arroz con epazote',
    7:'Xnipec (salsa habanero)',8:'Masa nixtamalizada',9:'Chipotle adobado',
    10:'Mojo de ajo caribeño',11:'Escabeche oriental',12:'Salpicón de rábanos',
  };

  let activeSub = null, activePlat = null;
  const chips = document.querySelectorAll('.sub-chip');
  const plats = document.querySelectorAll('.plat-item');
  const punch = document.getElementById('exp-punch');

  function clearAll(){
    chips.forEach(c => { c.classList.remove('active'); c.setAttribute('aria-pressed','false'); });
    plats.forEach(p => { p.classList.remove('active','dimmed'); });
    document.querySelectorAll('.plat-sub-tag').forEach(t => t.classList.remove('hl'));
    activeSub = null; activePlat = null;
    punch.innerHTML = '<strong>Toca "Cebolla morada curtida"</strong> — el mejor ejemplo del sistema.';
    punch.classList.remove('sel');
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const sid = parseInt(chip.dataset.subId);
      if(activeSub === sid){ clearAll(); return; }
      clearAll(); activeSub = sid;
      chip.classList.add('active'); chip.setAttribute('aria-pressed','true');
      let count = 0;
      plats.forEach(p => {
        const subs = platData[p.dataset.platId]?.subs || [];
        if(subs.includes(sid)){
          p.classList.add('active'); count++;
          p.querySelectorAll('.plat-sub-tag').forEach(t => {
            if(parseInt(t.dataset.tagSub) === sid) t.classList.add('hl');
          });
        } else { p.classList.add('dimmed'); }
      });
      punch.classList.add('sel');
      punch.innerHTML = `<strong>1 video de "${subNames[sid]}" = ${count} platillos</strong> — el mismo estándar, reutilizado.`;
    });
  });

  plats.forEach(platEl => {
    platEl.addEventListener('click', () => {
      const pid = platEl.dataset.platId;
      if(activePlat === pid){ clearAll(); return; }
      clearAll(); activePlat = pid;
      platEl.classList.add('active');
      const subs = platData[pid]?.subs || [];
      chips.forEach(c => { if(subs.includes(parseInt(c.dataset.subId))) c.classList.add('active'); });
      platEl.querySelectorAll('.plat-sub-tag').forEach(t => t.classList.add('hl'));
      punch.classList.add('sel');
      punch.innerHTML = `Este platillo usa <strong>${subs.length} subrecetas base</strong> — cada una compartida con otros platillos de la carta.`;
    });
  });

  /* Print */
  const pBtn = document.getElementById('btn-print');
  if(pBtn) pBtn.addEventListener('click', () => {
    const d = document.getElementById('pr-date-val');
    if(d) d.textContent = new Date().toLocaleDateString('es-MX',{year:'numeric',month:'long',day:'numeric'});
    const ps = document.getElementById('pr-star');
    if(ps) ps.textContent = document.getElementById('star-num').textContent;
    window.print();
  });

  const dv = document.getElementById('pr-date-val');
  if(dv) dv.textContent = new Date().toLocaleDateString('es-MX',{year:'numeric',month:'long',day:'numeric'});
})();
</script>
</body>
</html>

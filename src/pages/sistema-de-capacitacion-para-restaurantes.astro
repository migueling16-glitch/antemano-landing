  { id: 'p3',  name: 'Salbutes de cochinita',       subs: [2, 3, 8]    },
  { id: 'p4',  name: 'Tostada de cochinita',        subs: [2, 3, 7]    },
  { id: 'p5',  name: 'Burrito de cochinita',        subs: [2, 3, 6]    },
  { id: 'p6',  name: 'Taco de poc chuc',            subs: [2, 11, 3]   },
  { id: 'p7',  name: 'Taco de relleno negro',       subs: [1, 5, 8]    },
  { id: 'p8',  name: 'Tacos de camarón al mojo',   subs: [10, 7, 8]   },
  { id: 'p9',  name: 'Tostada de camarón',          subs: [10, 7, 3]   },
  { id: 'p10', name: 'Quesadilla de camarón',       subs: [10, 9, 8]   },
  { id: 'p11', name: 'Papadzules',                  subs: [1, 4, 5, 8] },
  { id: 'p12', name: 'Sopa de lima',                subs: [4, 12, 6]   },

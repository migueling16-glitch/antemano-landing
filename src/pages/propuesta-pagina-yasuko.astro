---
// Manual Vivo™ × Antemano — Propuesta de sitio web para Yasuko Durango
// noindex — propuesta privada
// Paleta oscura nativa (ADN Yasuko): carbón #16191E, marfil #F2EFE8, oro #C9A45D.
const WA = 'https://wa.me/5216181539643?text=Hola%2C%20vi%20la%20propuesta%20del%20sitio%20de%20Yasuko%20Durango%20y%20quiero%20platicar';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Un sitio propio para Yasuko Durango — Propuesta Antemano</title>
  <link rel="icon" href="/logo-a.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Inter:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --c:#16191E;        /* fondo carbón */
      --c2:#1B1F26;       /* superficie elevada */
      --c3:#20252D;       /* tarjetas */
      --ink:#F2EFE8;      /* texto marfil */
      --gold:#C9A45D;     /* oro Yasuko */
      --gold-lt:#DDBE7E;
      --muted:rgba(242,239,232,.55);
      --faint:rgba(242,239,232,.32);
      --border:rgba(201,164,93,.22);
      --border-soft:rgba(242,239,232,.10);
      --ease:cubic-bezier(0.16,1,0.3,1);
    }
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
    body{background:var(--c);color:var(--ink);font-family:'Inter',system-ui,sans-serif;
      -webkit-font-smoothing:antialiased;overflow-x:hidden;line-height:1.5}
    ::selection{background:var(--gold);color:var(--c)}
    a{color:inherit;text-decoration:none}

    .display{font-family:'Montserrat',system-ui,sans-serif;font-weight:900;letter-spacing:-.02em}
    .si{font-family:'Instrument Serif',Georgia,serif;font-style:italic;font-weight:400;
      letter-spacing:.005em}
    .container{max-width:1080px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:2}

    section{position:relative;overflow:hidden}
    .s-pad{padding:6rem 0}
    @media(max-width:640px){.s-pad{padding:4.25rem 0}}

    .eyebrow{font-family:'Montserrat',sans-serif;font-size:.7rem;font-weight:700;
      letter-spacing:.18em;text-transform:uppercase;color:var(--gold);
      margin-bottom:1.25rem;display:inline-flex;align-items:center;gap:.7rem}
    .eyebrow::before{content:'';width:1.7rem;height:1px;background:var(--gold);opacity:.6}

    .h2{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(1.8rem,4.6vw,3.1rem);line-height:1.08;letter-spacing:-.025em;
      text-wrap:balance;max-width:22ch}
    .h2 .si{color:var(--gold)}
    .lead{font-size:clamp(1rem,2vw,1.18rem);color:var(--muted);line-height:1.7;
      max-width:52ch;margin-top:1.1rem}
    .lead strong{color:var(--ink);font-weight:600}

    /* Botones */
    .btn{display:inline-flex;align-items:center;gap:.55rem;font-family:'Montserrat',sans-serif;
      font-size:.9rem;font-weight:700;padding:.85rem 1.6rem;border-radius:999px;border:none;
      cursor:pointer;text-decoration:none;transition:transform .25s var(--ease),
      background .25s,box-shadow .25s,border-color .25s,color .25s}
    .btn svg{transition:transform .3s var(--ease)}
    .btn:hover svg{transform:translateX(3px)}
    .btn:active{transform:scale(.96)}
    .btn-gold{background:var(--gold);color:var(--c)}
    .btn-gold:hover{background:var(--gold-lt);box-shadow:0 14px 34px -12px rgba(201,164,93,.5)}
    .btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--border)}
    .btn-ghost:hover{border-color:var(--gold);color:var(--gold)}

    /* Regla estilo menú Yasuko */
    .rule{font-family:'Montserrat',sans-serif;font-size:.7rem;font-weight:700;
      letter-spacing:.14em;text-transform:uppercase;color:var(--gold);padding:.55rem 0;
      border-top:1px solid rgba(242,239,232,.28);border-bottom:1px solid var(--border);
      display:block;margin-bottom:1.75rem}

    /* Watermark montaña / palabra */
    .wm{position:absolute;left:0;right:0;top:-1rem;display:flex;justify-content:center;
      pointer-events:none;user-select:none;z-index:0;overflow:hidden}
    .wm span{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(5rem,17vw,15rem);line-height:.85;letter-spacing:-.04em;
      text-transform:uppercase;white-space:nowrap;color:transparent;
      -webkit-text-stroke:1.5px rgba(201,164,93,.07)}

    /* Reveals */
    .rv{opacity:0;transform:translateY(20px);
      transition:opacity .75s var(--ease),transform .75s var(--ease);
      transition-delay:var(--d,0s)}
    .rv.in{opacity:1;transform:none}

    @media(prefers-reduced-motion:reduce){
      .rv{opacity:1!important;transform:none!important;transition:none!important}
      .float,.pulse,.mq-track{animation:none!important}
    }

    /* NAV */
    #nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1rem 1.5rem;
      transition:background .4s,backdrop-filter .4s,padding .4s,border-color .4s;
      border-bottom:1px solid transparent}
    #nav.scrolled{background:rgba(22,25,30,.85);backdrop-filter:blur(14px);
      -webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--border-soft);padding:.7rem 1.5rem}
    .nav-in{max-width:1080px;margin:0 auto;display:flex;align-items:center;
      justify-content:space-between;gap:1rem}
    .nav-logo img{width:132px;height:38px;object-fit:cover;object-position:center 52%;
      filter:invert(1);mix-blend-mode:screen;display:block;transition:transform .3s var(--ease)}
    .nav-logo:hover img{transform:scale(1.04)}
    @media(max-width:520px){.nav-logo img{width:108px;height:32px}}
    .nav-tag{font-family:'Montserrat',sans-serif;font-size:.64rem;font-weight:600;
      letter-spacing:.12em;text-transform:uppercase;color:var(--faint);display:none}
    @media(min-width:760px){.nav-tag{display:block}}

    /* HERO */
    #hero{min-height:100svh;display:flex;flex-direction:column;justify-content:flex-end;
      padding:7rem 0 4rem;background:
        radial-gradient(ellipse 70% 50% at 50% 0%,rgba(201,164,93,.08) 0%,transparent 65%),
        var(--c)}
    .hero-icon{width:3rem;height:3rem;object-fit:contain;margin-bottom:2rem;
      filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen;
      animation:fadeUp .9s var(--ease) .1s both}
    .float{animation:fadeUp .9s var(--ease) .1s both, yk-float 5s ease-in-out 1s infinite}
    @keyframes yk-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
    .hero-tag{font-family:'Montserrat',sans-serif;font-size:.7rem;font-weight:700;
      letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1.75rem;
      display:flex;align-items:center;gap:.75rem;opacity:0;animation:fadeUp .9s var(--ease) .2s both}
    .hero-tag::before{content:'';width:2rem;height:1px;background:var(--gold);opacity:.6}
    .hero-h1{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(2.4rem,7vw,5rem);line-height:1.02;letter-spacing:-.035em;
      margin-bottom:1.75rem;max-width:16ch}
    .hero-h1 .si{color:var(--gold);font-weight:400}
    .hero-h1 .hl{display:block;overflow:hidden;padding-bottom:.06em}
    .hero-h1 .hl span{display:block;transform:translateY(110%);
      animation:hRise 1s var(--ease) both;animation-delay:calc(.35s + var(--l,0)*.13s)}
    @keyframes hRise{0%{transform:translateY(110%)}100%{transform:translateY(0)}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
    .hero-sub{font-size:clamp(1rem,1.8vw,1.22rem);color:var(--muted);max-width:56ch;
      line-height:1.65;margin-bottom:2.5rem;opacity:0;animation:fadeUp 1s var(--ease) 1s both}
    .hero-sub .si{color:var(--ink)}
    .hero-cta{opacity:0;animation:fadeUp 1s var(--ease) 1.2s both;display:flex;gap:.85rem;flex-wrap:wrap}
    .scroll-hint{position:absolute;bottom:1.4rem;right:1.75rem;color:var(--faint);
      font-family:'Montserrat',sans-serif;font-size:.62rem;font-weight:600;letter-spacing:.1em;
      text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:.4rem;
      opacity:0;animation:fadeUp 1s ease 1.7s both}
    .scroll-hint svg{animation:bounce 1.8s ease-in-out infinite}
    @keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

    /* MARQUEE de evidencia */
    #mq{background:var(--c2);border-top:1px solid var(--border-soft);
      border-bottom:1px solid var(--border-soft);overflow:hidden;padding:1rem 0}
    .mq-track{display:flex;white-space:nowrap;width:max-content;animation:mq 32s linear infinite}
    @keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .mq-item{font-family:'Montserrat',sans-serif;font-size:clamp(.85rem,1.6vw,1.05rem);
      font-weight:700;letter-spacing:.02em;padding:0 1.4rem;display:inline-flex;align-items:center;gap:.6rem}
    .mq-torreon{color:#E0765A}
    .mq-durango{color:var(--gold)}
    .mq-sep{color:var(--faint);padding:0 .1rem}

    /* Auditoría de enlaces */
    .audit{display:flex;flex-direction:column;gap:.55rem;margin-top:2.5rem}
    .audit-row{display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;
      background:var(--c3);border:1px solid var(--border-soft);border-radius:13px;
      transition:border-color .25s,transform .3s var(--ease)}
    .audit-row:hover{transform:translateX(4px)}
    .audit-row.bad{border-left:3px solid #E0765A}
    .audit-row.good{border-left:3px solid var(--gold)}
    .audit-ico{flex-shrink:0;width:1.9rem;height:1.9rem;border-radius:50%;display:flex;
      align-items:center;justify-content:center}
    .audit-ico.bad{background:rgba(224,118,90,.14);color:#E0765A}
    .audit-ico.good{background:rgba(201,164,93,.14);color:var(--gold)}
    .audit-label{font-family:'Montserrat',sans-serif;font-weight:700;font-size:.92rem;
      color:var(--ink);flex-shrink:0}
    .audit-arrow{color:var(--faint);flex-shrink:0}
    .audit-dest{font-size:.82rem;color:var(--muted);font-family:'Inter',monospace;
      overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0}
    .audit-dest .tor{color:#E0765A;font-weight:600}
    .audit-dest .dur{color:var(--gold);font-weight:600}
    .audit-tag{flex-shrink:0;font-family:'Montserrat',sans-serif;font-size:.62rem;
      font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.22rem .6rem;
      border-radius:999px}
    .audit-tag.bad{background:rgba(224,118,90,.14);color:#E0765A}
    .audit-tag.good{background:rgba(201,164,93,.14);color:var(--gold)}
    @media(max-width:640px){
      .audit-dest{display:none}
      .audit-row{gap:.7rem}
    }
    .audit-note{margin-top:1.75rem;padding:1.4rem 1.5rem;background:rgba(224,118,90,.07);
      border:1px solid rgba(224,118,90,.25);border-radius:14px;font-size:1rem;
      color:var(--ink);line-height:1.6;max-width:60ch}
    .audit-note strong{color:#E0765A}

    /* Grid de costos */
    .cost-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:2.75rem}
    @media(min-width:640px){.cost-grid{grid-template-columns:1fr 1fr}}
    @media(min-width:960px){.cost-grid{grid-template-columns:1fr 1fr 1fr}}
    .cost-card{background:var(--c3);border:1px solid var(--border-soft);border-radius:16px;
      padding:1.6rem;transition:border-color .25s,transform .35s var(--ease)}
    .cost-card:hover{border-color:var(--border);transform:translateY(-3px)}
    .cost-ico{width:2.4rem;height:2.4rem;border-radius:11px;background:rgba(201,164,93,.1);
      display:flex;align-items:center;justify-content:center;color:var(--gold);margin-bottom:1rem}
    .cost-t{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.02rem;
      color:var(--ink);line-height:1.25;margin-bottom:.5rem}
    .cost-d{font-size:.88rem;color:var(--muted);line-height:1.6}

    /* Solución — lista */
    .sol-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:2.75rem}
    @media(min-width:720px){.sol-grid{grid-template-columns:1fr 1fr}}
    .sol-card{background:var(--c3);border:1px solid var(--border-soft);border-radius:16px;
      padding:1.7rem;display:flex;gap:1.1rem;align-items:flex-start;
      transition:border-color .25s,transform .35s var(--ease)}
    .sol-card:hover{border-color:var(--border);transform:translateY(-3px)}
    .sol-n{font-family:'Montserrat',sans-serif;font-weight:900;font-size:1.4rem;
      color:rgba(201,164,93,.35);line-height:1;flex-shrink:0;min-width:1.8rem}
    .sol-t{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.02rem;
      color:var(--ink);margin-bottom:.4rem;line-height:1.25}
    .sol-d{font-size:.88rem;color:var(--muted);line-height:1.6}

    /* Prueba — portal en vivo */
    .proof{background:linear-gradient(180deg,var(--c2),var(--c));border:1px solid var(--border);
      border-radius:24px;padding:2.75rem 2rem;text-align:center;margin-top:1rem}
    .proof-eye{font-family:'Montserrat',sans-serif;font-size:.68rem;font-weight:700;
      letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
    .proof-h{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(1.5rem,3.5vw,2.3rem);line-height:1.15;letter-spacing:-.02em;
      max-width:20ch;margin:0 auto 1rem}
    .proof-p{font-size:1rem;color:var(--muted);line-height:1.65;max-width:50ch;margin:0 auto 2rem}

    /* Fases */
    .fases{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:2.75rem}
    @media(min-width:900px){.fases{grid-template-columns:1fr 1fr 1fr;align-items:start}}
    .fase{border-radius:20px;padding:2rem 1.75rem;display:flex;flex-direction:column;gap:1rem;
      transition:transform .35s var(--ease)}
    .fase:hover{transform:translateY(-4px)}
    .fase1{background:var(--c3);border:2px solid var(--gold)}
    .fase2{background:var(--c3);border:1px solid var(--border-soft)}
    .fase3{background:var(--c2);border:1px solid var(--border-soft)}
    .fase-step{font-family:'Montserrat',sans-serif;font-size:.66rem;font-weight:800;
      letter-spacing:.12em;text-transform:uppercase;color:var(--gold)}
    .fase-h{font-family:'Montserrat',sans-serif;font-weight:900;font-size:1.3rem;
      letter-spacing:-.02em;color:var(--ink)}
    .fase-price{display:inline-block;padding:.25rem .75rem;border:1.5px dashed var(--border);
      border-radius:8px;font-family:'Montserrat',sans-serif;font-size:.82rem;font-weight:700;
      color:var(--muted);align-self:flex-start}
    .fase-d{font-size:.9rem;color:var(--muted);line-height:1.65}
    .fase-tag{font-family:'Montserrat',sans-serif;font-size:.68rem;font-weight:700;
      padding:.3rem .75rem;border-radius:999px;align-self:flex-start;
      background:rgba(201,164,93,.12);color:var(--gold)}

    /* CTA final */
    #cta{text-align:center;background:
      radial-gradient(ellipse 60% 50% at 50% 100%,rgba(201,164,93,.1) 0%,transparent 70%),var(--c)}
    .cta-h{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(1.9rem,5vw,3.2rem);line-height:1.1;letter-spacing:-.025em;
      max-width:20ch;margin:0 auto 1.25rem}
    .cta-h .si{color:var(--gold);font-weight:400}
    .cta-sub{font-size:1.05rem;color:var(--muted);max-width:48ch;margin:0 auto 2.5rem;line-height:1.65}
    .cta-note{margin-top:1.75rem;font-size:.8rem;color:var(--faint);max-width:44ch;
      margin-left:auto;margin-right:auto;line-height:1.55}

    /* Footer */
    #foot{padding:3rem 0;border-top:1px solid var(--border-soft)}
    .foot-in{display:flex;flex-direction:column;gap:1rem;align-items:flex-start}
    @media(min-width:640px){.foot-in{flex-direction:row;align-items:center;justify-content:space-between}}
    .foot-logo img{width:140px;height:40px;object-fit:cover;object-position:center 52%;
      filter:invert(1);mix-blend-mode:screen;display:block}
    .foot-copy{font-size:.8rem;color:var(--faint);line-height:1.6;max-width:52ch}
    .foot-copy a{color:var(--gold)}
  </style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <div class="nav-in">
    <a href="https://antemano.com.mx" class="nav-logo" aria-label="Antemano"><img src="/logo.png" alt="Antemano" /></a>
    <span class="nav-tag">Propuesta · Sitio web Yasuko Durango</span>
    <a href={WA} class="btn btn-gold" style="font-size:.78rem;padding:.55rem 1.15rem;">Hablar con Antemano</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="container">
    <img src="/yasuko-icon.png" alt="" class="hero-icon float" onerror="this.style.display='none'" />
    <p class="hero-tag">Propuesta para Yasuko Durango</p>
    <h1 class="hero-h1" aria-label="Tu página de Durango sigue siendo la de Torreón.">
      <span class="hl"><span style="--l:0">Tu página de Durango</span></span>
      <span class="hl"><span style="--l:1">sigue siendo la de</span></span>
      <span class="hl"><span style="--l:2" class="si">Torreón.</span></span>
    </h1>
    <p class="hero-sub">
      La abriste para Durango, pero por dentro sigue mandando a tu cliente a otra ciudad.
      El botón de <em class="si">Horarios y Ubicación</em> lleva a la dirección de Torreón. El menú de bebidas, el pago en línea y la facturación son copias de Torreón. Lo revisamos enlace por enlace.
    </p>
    <div class="hero-cta">
      <a href="#diagnostico" class="btn btn-gold">Ver el diagnóstico
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </a>
      <a href="/yasuko/" class="btn btn-ghost">Ver un demo en vivo →</a>
    </div>
  </div>
  <div class="scroll-hint" aria-hidden="true">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    <span>scroll</span>
  </div>
</section>

<!-- MARQUEE evidencia -->
<div id="mq" aria-hidden="true">
  <div class="mq-track">
    <span class="mq-item mq-torreon">bebidas-torreon-copia</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">horarios-torreon</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">pago-en-linea-torreon-copia</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">facturacion-torreon-copia</span><span class="mq-sep">/</span>
    <span class="mq-item mq-durango">reserva-durango</span><span class="mq-sep">/</span>
    <span class="mq-item mq-durango">menu-alimentos-durango</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">bebidas-torreon-copia</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">horarios-torreon</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">pago-en-linea-torreon-copia</span><span class="mq-sep">/</span>
    <span class="mq-item mq-torreon">facturacion-torreon-copia</span><span class="mq-sep">/</span>
    <span class="mq-item mq-durango">reserva-durango</span><span class="mq-sep">/</span>
    <span class="mq-item mq-durango">menu-alimentos-durango</span><span class="mq-sep">/</span>
  </div>
</div>

<!-- DIAGNÓSTICO -->
<section id="diagnostico" class="s-pad">
  <div class="wm"><span>Torreón</span></div>
  <div class="container">
    <p class="eyebrow rv">El diagnóstico</p>
    <h2 class="h2 rv">No es una impresión. Está <em class="si">en los enlaces.</em></h2>
    <p class="lead rv">Tu página de Durango es un menú de botones montado sobre <strong>Squarespace</strong>. Abrimos cada botón y revisamos a dónde lleva de verdad. Esto es lo que encontramos:</p>

    <div class="audit">
      <div class="audit-row good rv">
        <span class="audit-ico good"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9 10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <span class="audit-label">Reserva en línea</span>
        <svg class="audit-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>

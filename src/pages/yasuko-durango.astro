---
import { MENU, NOTAS, TAG_LABEL } from '../data/yasuko-menu';
import type { Tag } from '../data/yasuko-menu';

// Especialidades = platillos marcados como destacado
const destacados = MENU.flatMap((c) =>
  c.platillos.filter((p) => p.tags?.includes('destacado')).map((p) => ({ ...p, cat: c.titulo })),
);

const totalPlatillos = MENU.reduce((n, c) => n + c.platillos.length, 0);

// Enlace de Google Maps (búsqueda real del lugar)
const MAPS = 'https://www.google.com/maps/search/?api=1&query=Yasuko+Durango';
const TEL = '6181370086';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Yasuko Durango — Cocina japonesa de altura</title>
  <meta name="description" content="Sushi, rollos, ramen y sashimi en Durango. Conoce el menú completo de Yasuko y reserva tu mesa." />
  <link rel="icon" href="/yasuko-icon.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Inter:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <style is:global>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --c:#14171B;--c2:#1A1E24;--c3:#20252D;--c4:#262C35;
      --ink:#F2EFE8;--gold:#C9A45D;--gold-lt:#DDBE7E;
      --muted:rgba(242,239,232,.55);--faint:rgba(242,239,232,.34);
      --border:rgba(201,164,93,.22);--border-soft:rgba(242,239,232,.09);
      --ease:cubic-bezier(0.16,1,0.3,1);
    }
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
    body{background:var(--c);color:var(--ink);font-family:'Inter',system-ui,sans-serif;
      -webkit-font-smoothing:antialiased;overflow-x:hidden;line-height:1.5}
    ::selection{background:var(--gold);color:var(--c)}
    a{color:inherit;text-decoration:none}
    img{display:block;max-width:100%}

    .display{font-family:'Montserrat',system-ui,sans-serif;font-weight:900;letter-spacing:-.02em}
    .si{font-family:'Instrument Serif',Georgia,serif;font-style:italic;font-weight:400}
    .container{max-width:1080px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:2}
    section{position:relative}
    .s-pad{padding:5.5rem 0}
    @media(max-width:640px){.s-pad{padding:4rem 0}}

    .eyebrow{font-family:'Montserrat',sans-serif;font-size:.68rem;font-weight:700;
      letter-spacing:.18em;text-transform:uppercase;color:var(--gold);
      margin-bottom:1rem;display:inline-flex;align-items:center;gap:.7rem}
    .eyebrow::before{content:'';width:1.6rem;height:1px;background:var(--gold);opacity:.6}
    .eyebrow.ctr{justify-content:center}
    .h2{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(1.9rem,4.6vw,3rem);line-height:1.08;letter-spacing:-.025em;text-wrap:balance}
    .h2 .si{color:var(--gold)}

    /* Botones */
    .btn{display:inline-flex;align-items:center;gap:.5rem;font-family:'Montserrat',sans-serif;
      font-size:.88rem;font-weight:700;padding:.8rem 1.5rem;border-radius:999px;border:none;
      cursor:pointer;text-decoration:none;transition:transform .25s var(--ease),background .25s,
      box-shadow .25s,border-color .25s,color .25s}
    .btn svg{transition:transform .3s var(--ease)}
    .btn:hover svg{transform:translateX(3px)}
    .btn:active{transform:scale(.96)}
    .btn-gold{background:var(--gold);color:var(--c)}
    .btn-gold:hover{background:var(--gold-lt);box-shadow:0 14px 32px -12px rgba(201,164,93,.5)}
    .btn-ghost{background:transparent;color:var(--ink);border:1.5px solid var(--border)}
    .btn-ghost:hover{border-color:var(--gold);color:var(--gold)}

    /* Reveals */
    .rv{opacity:0;transform:translateY(20px);
      transition:opacity .7s var(--ease),transform .7s var(--ease);transition-delay:var(--d,0s)}
    .rv.in{opacity:1;transform:none}
    @media(prefers-reduced-motion:reduce){
      .rv{opacity:1!important;transform:none!important;transition:none!important}
      .float,.mq-track{animation:none!important}
    }

    /* NAV */
    #nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1rem 1.25rem;
      transition:background .4s,backdrop-filter .4s,padding .4s,border-color .4s;
      border-bottom:1px solid transparent}
    #nav.scrolled{background:rgba(20,23,27,.85);backdrop-filter:blur(14px);
      -webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--border-soft);padding:.65rem 1.25rem}
    .nav-in{max-width:1080px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:1rem}
    .nav-brand{display:flex;align-items:center;gap:.55rem}
    .nav-brand img{width:1.6rem;height:1.6rem;object-fit:contain;
      filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen}
    .nav-brand span{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.15rem;
      letter-spacing:.01em}
    .nav-links{display:none;gap:1.6rem;align-items:center}
    @media(min-width:800px){.nav-links{display:flex}}
    .nav-links a{font-family:'Montserrat',sans-serif;font-size:.8rem;font-weight:600;
      color:var(--muted);letter-spacing:.02em;transition:color .2s}
    .nav-links a:hover{color:var(--gold)}

    /* HERO */
    #hero{min-height:100svh;display:flex;flex-direction:column;justify-content:center;
      align-items:center;text-align:center;padding:7rem 1.5rem 4rem;position:relative;overflow:hidden;
      background:radial-gradient(ellipse 65% 55% at 50% 38%,rgba(201,164,93,.1) 0%,transparent 65%),var(--c)}
    .hero-icon{width:4rem;height:4rem;object-fit:contain;margin-bottom:1.75rem;
      filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen;
      animation:fadeUp .9s var(--ease) .1s both}
    .float{animation:fadeUp .9s var(--ease) .1s both, yk-float 5s ease-in-out 1.1s infinite}
    @keyframes yk-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
    .hero-word{font-family:'Montserrat',sans-serif;font-weight:900;
      font-size:clamp(3.2rem,13vw,7rem);line-height:.95;letter-spacing:-.03em;
      opacity:0;animation:fadeUp 1s var(--ease) .25s both}
    .hero-tag{font-family:'Instrument Serif',serif;font-style:italic;
      font-size:clamp(1.15rem,3vw,1.7rem);color:var(--gold);margin-top:.6rem;
      opacity:0;animation:fadeUp 1s var(--ease) .5s both}
    .hero-sub{font-size:clamp(.95rem,2vw,1.1rem);color:var(--muted);max-width:44ch;
      line-height:1.65;margin:1.5rem auto 0;opacity:0;animation:fadeUp 1s var(--ease) .7s both}
    .hero-loc{display:inline-flex;align-items:center;gap:.4rem;margin-top:1.5rem;
      font-family:'Montserrat',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.14em;
      text-transform:uppercase;color:var(--faint);
      opacity:0;animation:fadeUp 1s var(--ease) .85s both}
    .hero-cta{display:flex;gap:.85rem;flex-wrap:wrap;justify-content:center;margin-top:2.25rem;
      opacity:0;animation:fadeUp 1s var(--ease) 1s both}
    .scroll-hint{position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);
      color:var(--faint);opacity:0;animation:fadeUp 1s ease 1.5s both}
    .scroll-hint svg{animation:bounce 1.8s ease-in-out infinite}
    @keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}

    /* Marquee promo QR */
    #promo{background:var(--gold);color:var(--c);overflow:hidden;padding:.7rem 0}
    .mq-track{display:flex;white-space:nowrap;width:max-content;animation:mq 34s linear infinite}
    @keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .mq-item{font-family:'Montserrat',sans-serif;font-size:.82rem;font-weight:700;
      letter-spacing:.02em;padding:0 1.1rem;display:inline-flex;align-items:center;gap:.7rem}
    .mq-item::after{content:'〰️';opacity:.5}

    /* HISTORIA */
    .hist-grid{display:grid;grid-template-columns:1fr;gap:2.5rem;align-items:center;margin-top:1rem}
    @media(min-width:820px){.hist-grid{grid-template-columns:1.1fr .9fr}}
    .hist-body p{color:var(--muted);line-height:1.75;margin-top:1.1rem;max-width:52ch}
    .hist-body p .si{color:var(--ink)}
    .hist-card{background:var(--c2);border:1px solid var(--border);border-radius:20px;
      padding:2.25rem 2rem;text-align:center}
    .hist-card img{width:3.4rem;height:3.4rem;object-fit:contain;margin:0 auto 1.25rem;
      filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen}
    .hist-card h3{font-family:'Instrument Serif',serif;font-style:italic;font-size:1.5rem;margin-bottom:.4rem}
    .hist-card .yr{font-family:'Montserrat',sans-serif;font-size:.66rem;font-weight:700;
      letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
    .hist-card p{font-size:.86rem;color:var(--muted);line-height:1.65}

    /* ESPECIALIDADES */
    .esp-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:2.5rem}
    @media(min-width:640px){.esp-grid{grid-template-columns:1fr 1fr}}
    @media(min-width:960px){.esp-grid{grid-template-columns:1fr 1fr 1fr}}
    .esp-card{background:linear-gradient(180deg,var(--c3),var(--c2));border:1px solid var(--border-soft);
      border-radius:18px;padding:1.6rem;transition:border-color .25s,transform .35s var(--ease)}
    .esp-card:hover{border-color:var(--border);transform:translateY(-4px)}
    .esp-top{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;margin-bottom:.5rem}
    .esp-name{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.05rem;line-height:1.2}
    .esp-price{font-family:'Montserrat',sans-serif;font-weight:800;color:var(--gold);flex-shrink:0}
    .esp-cat{font-family:'Montserrat',sans-serif;font-size:.62rem;font-weight:700;letter-spacing:.1em;
      text-transform:uppercase;color:var(--faint);margin-bottom:.6rem}
    .esp-desc{font-size:.85rem;color:var(--muted);line-height:1.6}

    /* MENÚ */
    #menu-controls{position:sticky;top:0;z-index:40;background:rgba(20,23,27,.9);
      backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
      border-bottom:1px solid var(--border-soft);padding:.85rem 0}
    .mc-in{max-width:1080px;margin:0 auto;padding:0 1.25rem}
    .search-wrap{position:relative;margin-bottom:.75rem}
    .search-wrap svg{position:absolute;left:.95rem;top:50%;transform:translateY(-50%);color:var(--faint)}
    #buscar{width:100%;background:var(--c3);border:1px solid var(--border-soft);border-radius:999px;
      padding:.7rem 1rem .7rem 2.6rem;color:var(--ink);font-family:'Inter',sans-serif;font-size:.9rem;
      outline:none;transition:border-color .2s}
    #buscar:focus{border-color:var(--gold)}
    #buscar::placeholder{color:var(--faint)}
    .chips{display:flex;gap:.5rem;overflow-x:auto;padding-bottom:.2rem;scrollbar-width:none}
    .chips::-webkit-scrollbar{display:none}
    .chip{flex-shrink:0;font-family:'Montserrat',sans-serif;font-size:.76rem;font-weight:700;
      padding:.4rem .9rem;border-radius:999px;border:1.5px solid var(--border-soft);
      background:transparent;color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .2s}
    .chip:hover{border-color:var(--border);color:var(--ink)}
    .chip.active{background:var(--gold);border-color:var(--gold);color:var(--c)}

    .menu-body{max-width:1080px;margin:0 auto;padding:2.5rem 1.25rem 0}
    .cat-block{margin-bottom:3rem;scroll-margin-top:8rem}
    .cat-head{font-family:'Montserrat',sans-serif;font-weight:900;font-size:1.5rem;
      letter-spacing:-.02em;padding-bottom:.6rem;border-bottom:1px solid var(--border);
      display:flex;align-items:baseline;justify-content:space-between;gap:1rem}
    .cat-head .cnt{font-size:.7rem;font-weight:700;color:var(--faint);letter-spacing:.06em}
    .cat-nota{font-size:.82rem;color:var(--faint);font-style:italic;margin-top:.5rem}
    .dish-list{display:grid;grid-template-columns:1fr;gap:0;margin-top:.5rem}
    @media(min-width:760px){.dish-list{grid-template-columns:1fr 1fr;column-gap:2.5rem}}
    .dish{padding:1rem 0;border-bottom:1px solid var(--border-soft)}
    .dish-top{display:flex;align-items:baseline;gap:.75rem}
    .dish-name{font-family:'Montserrat',sans-serif;font-weight:700;font-size:.98rem;line-height:1.25}
    .dish-dots{flex:1;border-bottom:1px dotted rgba(242,239,232,.2);transform:translateY(-.2rem);min-width:1rem}
    .dish-price{font-family:'Montserrat',sans-serif;font-weight:800;color:var(--gold);flex-shrink:0}
    .dish-desc{font-size:.84rem;color:var(--muted);line-height:1.55;margin-top:.35rem;max-width:48ch}
    .dish-tags{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.5rem}
    .tag{font-family:'Montserrat',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:.08em;
      text-transform:uppercase;padding:.16rem .5rem;border-radius:999px}
    .tag-destacado{background:rgba(201,164,93,.16);color:var(--gold)}
    .tag-picante{background:rgba(224,118,90,.16);color:#E88C72}
    .tag-vegetariano{background:rgba(126,181,120,.16);color:#8FCF87}
    .tag-crudo{background:rgba(242,239,232,.09);color:var(--muted)}
    .cat-block.hidden{display:none}
    .dish.hidden{display:none}
    #no-result{display:none;text-align:center;color:var(--muted);padding:2rem 0 3rem;font-size:.95rem}
    #no-result.show{display:block}

    .menu-notas{max-width:1080px;margin:1.5rem auto 0;padding:1.5rem 1.25rem 0;
      border-top:1px solid var(--border-soft)}
    .menu-notas p{font-size:.76rem;color:var(--faint);line-height:1.6;margin-bottom:.3rem}

    /* VISÍTANOS */
    #visita{background:var(--c2)}
    .visita-grid{display:grid;grid-template-columns:1fr;gap:1rem;margin-top:2.5rem}
    @media(min-width:760px){.visita-grid{grid-template-columns:1fr 1fr 1fr}}
    .vcard{background:var(--c3);border:1px solid var(--border-soft);border-radius:16px;padding:1.75rem}
    .vcard .vico{width:2.4rem;height:2.4rem;border-radius:11px;background:rgba(201,164,93,.1);
      display:flex;align-items:center;justify-content:center;color:var(--gold);margin-bottom:1rem}
    .vcard h4{font-family:'Montserrat',sans-serif;font-weight:800;font-size:.95rem;margin-bottom:.5rem}
    .vcard p{font-size:.88rem;color:var(--muted);line-height:1.6}
    .vcard a.vlink{color:var(--gold);font-weight:600}
    .visita-cta{margin-top:2rem;display:flex;gap:.85rem;flex-wrap:wrap}

    /* FOOTER */
    #foot{padding:3rem 0 2.5rem;border-top:1px solid var(--border-soft);text-align:center}
    .foot-brand{display:inline-flex;align-items:center;gap:.6rem;margin-bottom:1rem}
    .foot-brand img{width:1.8rem;height:1.8rem;object-fit:contain;filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen}
    .foot-brand span{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.3rem}
    .foot-copy{font-size:.76rem;color:var(--faint);line-height:1.7;max-width:52ch;margin:0 auto}
    .foot-copy a{color:var(--gold)}
  </style>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <div class="nav-in">
    <a href="#hero" class="nav-brand" aria-label="Yasuko Durango">
      <img src="/yasuko-icon.png" alt="" onerror="this.style.display='none'" />
      <span>yasuko</span>
    </a>
    <div class="nav-links">
      <a href="#historia">Historia</a>
      <a href="#especialidades">Especialidades</a>
      <a href="#menu">Menú</a>
      <a href="#visita">Visítanos</a>
    </div>
    <a href="#visita" class="btn btn-gold" style="font-size:.76rem;padding:.5rem 1.1rem;">Reservar</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <img src="/yasuko-icon.png" alt="" class="hero-icon float" onerror="this.style.display='none'" />
  <h1 class="hero-word">yasuko</h1>
  <p class="hero-tag">Cocina japonesa de altura</p>
  <p class="hero-sub">Sushi, cortes y rollos de autor en el corazón de Durango. Producto fresco, técnica de barra y una carta que vale la pena explorar.</p>
  <span class="hero-loc">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
    Durango, Dgo.
  </span>
  <div class="hero-cta">
    <a href="#menu" class="btn btn-gold">Ver el menú
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
    <a href="#visita" class="btn btn-ghost">Reservar mesa</a>
  </div>
  <div class="scroll-hint" aria-hidden="true">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
  </div>
</section>

<!-- PROMO QR -->
<div id="promo" aria-hidden="true">
  <div class="mq-track">
    <span class="mq-item">Gana descuentos y promociones — escanea el QR cuando te lleven tu cuenta</span>
    <span class="mq-item">Gana descuentos y promociones — escanea el QR cuando te lleven tu cuenta</span>
    <span class="mq-item">Gana descuentos y promociones — escanea el QR cuando te lleven tu cuenta</span>
    <span class="mq-item">Gana descuentos y promociones — escanea el QR cuando te lleven tu cuenta</span>
  </div>
</div>

<!-- HISTORIA -->
<section id="historia" class="s-pad">
  <div class="container">
    <p class="eyebrow rv">Nuestra historia</p>
    <div class="hist-grid">
      <div class="hist-body">
        <h2 class="h2 rv">El nombre de una <em class="si">cumbre.</em></h2>
        <p class="rv">Yasuko Namba fue una montañista japonesa, una de las primeras mujeres en completar las <em class="si">Siete Cumbres</em> —las montañas más altas de cada continente— incluyendo el Monte Everest.</p>
        <p class="rv">Su historia inspira lo que hacemos: llegar a la cima exige disciplina, respeto por el proceso y no conformarse. La misma exigencia que ponemos en cada corte, cada arroz y cada plato que sale de nuestra barra.</p>
        <p class="rv">Por eso la montaña vive en nuestro logo, y por eso los personajes de los cuadros que te acompañan en la mesa cuentan, cada uno, una historia de altura.</p>
      </div>
      <div class="hist-card rv">
        <img src="/yasuko-icon.png" alt="" onerror="this.style.display='none'" />
        <h3>Yasuko Namba</h3>
        <p class="yr">1949 – 1996 · Leyenda de los Himalayas</p>
        <p>Una de las primeras mujeres en conquistar las Siete Cumbres. Su legado: nunca conformarse con menos que la cima.</p>
      </div>
    </div>
  </div>
</section>

<!-- ESPECIALIDADES -->
<section id="especialidades" class="s-pad" style="background:var(--c2)">
  <div class="container">
    <p class="eyebrow rv">Lo que no te puedes perder</p>
    <h2 class="h2 rv">Especialidades de <em class="si">la casa.</em></h2>
    <div class="esp-grid">
      {destacados.map((d) => (
        <div class="esp-card rv">
          <p class="esp-cat">{d.cat}</p>
          <div class="esp-top">
            <span class="esp-name">{d.nombre}</span>
            <span class="esp-price">{d.precio}</span>
          </div>
          {d.desc && <p class="esp-desc">{d.desc}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- MENÚ -->
<section id="menu">
  <div class="s-pad" style="padding-bottom:1.5rem">
    <div class="container">
      <p class="eyebrow ctr rv" style="justify-content:center">La carta</p>
      <h2 class="h2 rv" style="text-align:center;margin:0 auto;max-width:20ch">Nuestro menú <em class="si">completo.</em></h2>
      <p class="rv" style="text-align:center;color:var(--muted);margin-top:.75rem;font-size:.95rem">{totalPlatillos} platillos · busca o filtra por categoría</p>
    </div>
  </div>

  <!-- Controles pegajosos -->
  <div id="menu-controls">
    <div class="mc-in">
      <div class="search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input id="buscar" type="search" placeholder="Buscar platillo… (ej. atún, ramen, spicy)" autocomplete="off" />
      </div>
      <div class="chips" id="chips">
        <button class="chip active" data-cat="todos" type="button">Todos</button>
        {MENU.map((c) => (
          <button class="chip" data-cat={c.slug} type="button">{c.titulo}</button>
        ))}
      </div>
    </div>
  </div>

  <!-- Lista -->
  <div class="menu-body">
    {MENU.map((c) => (
      <div class="cat-block" data-cat={c.slug} id={`cat-${c.slug}`}>
        <div class="cat-head">
          <span>{c.titulo}</span>
          <span class="cnt">{c.platillos.length}</span>
        </div>
        {c.nota && <p class="cat-nota">{c.nota}</p>}
        <div class="dish-list">
          {c.platillos.map((p) => (
            <div class="dish" data-nombre={p.nombre.toLowerCase()} data-desc={(p.desc || '').toLowerCase()}>
              <div class="dish-top">
                <span class="dish-name">{p.nombre}</span>
                <span class="dish-dots"></span>
                <span class="dish-price">{p.precio}</span>
              </div>
              {p.desc && <p class="dish-desc">{p.desc}</p>}
              {p.tags && p.tags.length > 0 && (
                <div class="dish-tags">
                  {p.tags.map((t) => (
                    <span class={`tag tag-${t}`}>{TAG_LABEL[t as Tag]}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
    <p id="no-result">No encontramos platillos con esa búsqueda. Intenta con otro ingrediente.</p>
  </div>

  <div class="menu-notas">
    {NOTAS.map((n) => <p>· {n}</p>)}
  </div>
</section>

<!-- VISÍTANOS -->
<section id="visita" class="s-pad">
  <div class="container">
    <p class="eyebrow rv">Visítanos</p>
    <h2 class="h2 rv">Te esperamos en <em class="si">Durango.</em></h2>
    <div class="visita-grid">
      <div class="vcard rv">
        <div class="vico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        <h4>Ubicación</h4>
        <p>Durango, Dgo.<br /><a class="vlink" href={MAPS} target="_blank" rel="noopener">Cómo llegar →</a></p>
      </div>
      <div class="vcard rv">
        <div class="vico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
        <h4>Horario</h4>
        <p>Lunes a domingo<br />1:00 pm – 11:00 pm<br /><span style="color:var(--faint);font-size:.78rem">Horario sujeto a confirmación</span></p>
      </div>
      <div class="vcard rv">
        <div class="vico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div>
        <h4>Reservaciones</h4>
        <p><a class="vlink" href={`tel:${TEL}`}>618 137 0086</a><br />Llámanos para reservar tu mesa.</p>
      </div>
    </div>
    <div class="visita-cta rv">
      <a href={`tel:${TEL}`} class="btn btn-gold">Llamar para reservar
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a href={MAPS} target="_blank" rel="noopener" class="btn btn-ghost">Ver en el mapa</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer id="foot">
  <div class="container">
    <div class="foot-brand">
      <img src="/yasuko-icon.png" alt="" onerror="this.style.display='none'" />
      <span>yasuko</span>
    </div>
    <p class="foot-copy">
      Cocina japonesa en Durango. Los precios incluyen IVA. El consumo de alimentos crudos es responsabilidad de quien los consume.<br />
      Sitio de muestra desarrollado por <a href="https://antemano.com.mx">Antemano</a>.
    </p>
  </div>
</footer>

<script>
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Nav scrolled
    const nav = document.getElementById('nav');
    const onScroll = () => nav && nav.classList.toggle('scrolled', window.scrollY > 40);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Smooth scroll anclas
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      const a = t && t.closest && t.closest('a[href^="#"]');
      if (!a) return;
      const hash = a.getAttribute('href');
      if (!hash || hash.length < 2) return;
      const target = document.querySelector(hash);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
    });

    // ── Menú: chips + búsqueda ──────────────────────────────────────────
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
    const bloques = Array.from(document.querySelectorAll<HTMLElement>('.cat-block'));
    const platillos = Array.from(document.querySelectorAll<HTMLElement>('.dish'));
    const buscar = document.getElementById('buscar') as HTMLInputElement | null;
    const noResult = document.getElementById('no-result');
    let catActiva = 'todos';

    // Normaliza para buscar sin importar acentos ni mayúsculas
    const DIACRITICOS = new RegExp('[\\u0300-\\u036f]', 'g');
    const norm = (s: string) =>
      s.toLowerCase().normalize('NFD').replace(DIACRITICOS, '');

    function aplicar() {
      const q = norm((buscar?.value || '').trim());
      let visibles = 0;

      if (q) {
        // Búsqueda: ignora la categoría, muestra todo lo que haga match
        platillos.forEach((d) => {
          const hit = norm(d.dataset.nombre || '').includes(q) || norm(d.dataset.desc || '').includes(q);
          d.classList.toggle('hidden', !hit);
          if (hit) visibles++;
        });
        bloques.forEach((b) => {
          const algo = b.querySelector('.dish:not(.hidden)');
          b.classList.toggle('hidden', !algo);
        });
      } else {
        platillos.forEach((d) => d.classList.remove('hidden'));
        bloques.forEach((b) => {
          const show = catActiva === 'todos' || b.dataset.cat === catActiva;
          b.classList.toggle('hidden', !show);
          if (show) visibles += b.querySelectorAll('.dish').length;
        });
      }

      if (noResult) noResult.classList.toggle('show', visibles === 0);
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        catActiva = chip.dataset.cat || 'todos';
        if (buscar) buscar.value = '';
        aplicar();
        // Lleva la vista al inicio del menú al cambiar de categoría
        const menu = document.getElementById('menu-controls');
        if (menu) {
          const y = menu.getBoundingClientRect().top + window.scrollY - 4;
          window.scrollTo({ top: y, behavior: reduce ? 'auto' : 'smooth' });
        }
      });
    });

    if (buscar) {
      buscar.addEventListener('input', () => {
        if (buscar.value.trim()) {
          chips.forEach((c) => c.classList.toggle('active', c.dataset.cat === 'todos'));
          catActiva = 'todos';
        }
        aplicar();
      });
    }

    // ── Reveals ─────────────────────────────────────────────────────────
    if (!reduce) {
      const rvs = Array.from(document.querySelectorAll<HTMLElement>('.rv'));
      const porPadre = new Map<HTMLElement, HTMLElement[]>();
      rvs.forEach((el) => {
        const p = el.parentElement!;
        if (!porPadre.has(p)) porPadre.set(p, []);
        porPadre.get(p)!.push(el);
      });
      porPadre.forEach((grupo) => {
        grupo.forEach((el, i) => el.style.setProperty('--d', Math.min(i * 55, 300) + 'ms'));
      });
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
      );
      rvs.forEach((el) => io.observe(el));
    }
  })();
</script>

</body>
</html>

---
interface Props {
  title: string;
  description?: string;
  backHref?: string;
  backLabel?: string;
}
const { title, description, backHref, backLabel } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · Spiral</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sc:        #C4522A;
      --sc-light:  #D4714A;
      --sc-dark:   #2C1810;
      --sc-cream:  #EDE9D0;
      --sc-warm:   #F5F2E8;
      --sc-border: rgba(196, 82, 42, 0.18);
    }

    html {
      background: var(--sc-cream);
      color: var(--sc-dark);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      min-height: 100dvh;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 16px;
      line-height: 1.5;
    }

    .serif { font-family: 'Cormorant Garamond', Georgia, serif; }

    a { color: inherit; text-decoration: none; }

    /* pill button — outline */
    .btn-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1.25rem;
      border-radius: 999px;
      border: 1.5px solid var(--sc);
      color: var(--sc);
      background: transparent;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
      text-decoration: none;
    }
    .btn-pill:hover { background: var(--sc); color: var(--sc-cream); }

    /* pill button — filled */
    .btn-pill-filled {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1.25rem;
      border-radius: 999px;
      border: 1.5px solid var(--sc);
      color: var(--sc-cream);
      background: var(--sc);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
      text-decoration: none;
    }
    .btn-pill-filled:hover { background: var(--sc-light); border-color: var(--sc-light); }

    /* badge — small pill */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* section cards */
    .card {
      background: var(--sc-warm);
      border: 1px solid var(--sc-border);
      border-radius: 16px;
      transition: border-color 0.2s, transform 0.25s, box-shadow 0.25s;
    }
    .card:hover {
      border-color: rgba(196, 82, 42, 0.45);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -10px rgba(44, 24, 16, 0.12);
    }
  </style>
</head>
<body>

  <!-- ── Header ───────────────────────────────────────────────────────────── -->
  <header style="position:sticky;top:0;z-index:50;background:rgba(237,233,208,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--sc-border);">
    <div style="max-width:680px;margin:0 auto;padding:0 1rem;height:3.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">

      {backHref ? (
        <a href={backHref} style="display:flex;align-items:center;gap:0.4rem;color:rgba(196,82,42,0.65);font-size:0.8rem;font-weight:500;letter-spacing:0.02em;transition:color 0.18s;flex-shrink:0;" class="back-link">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M9 2.5L4.5 7 9 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {backLabel || 'Atrás'}
        </a>
      ) : (
        <span style="font-size:0.65rem;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(196,82,42,0.5);">Sistema de Capacitación</span>
      )}

      <a href="/spiral/" style="display:block;flex-shrink:0;">
        <img src="/spiral-logo.png" alt="Spiral" style="width:7.5rem;height:2.25rem;object-fit:cover;object-position:center 50%;mix-blend-mode:multiply;display:block;" />
      </a>

      {backHref ? (
        <span style="font-size:0.65rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:rgba(196,82,42,0.45);">Manual Vivo™</span>
      ) : (
        <a href="/spiral/ruta/cocinero-de-pizzas" style="font-size:0.72rem;font-weight:500;color:var(--sc);letter-spacing:0.04em;">Mi ruta →</a>
      )}

    </div>
  </header>

  <!-- ── Content ──────────────────────────────────────────────────────────── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ───────────────────────────────────────────────────────────── -->
  <footer style="border-top:1px solid var(--sc-border);margin-top:4rem;padding:2rem 1rem;">
    <div style="max-width:680px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;">
      <img src="/spiral-logo.png" alt="Spiral" style="width:5rem;height:1.5rem;object-fit:cover;object-position:center 50%;mix-blend-mode:multiply;opacity:0.45;" />
      <span style="font-size:0.7rem;color:rgba(44,24,16,0.38);letter-spacing:0.06em;">Manual Vivo™ × Antemano</span>
    </div>
  </footer>

  <style>
    .back-link:hover { color: var(--sc) !important; }
  </style>

</body>
</html>

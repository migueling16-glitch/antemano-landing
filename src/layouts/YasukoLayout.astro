---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  backHref?: string;
  backLabel?: string;
}
const { title, description, backHref, backLabel } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · Yasuko</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  <ViewTransitions />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --yk:        #C9A45D; /* dorado del menú, aclarado para fondo oscuro */
      --yk-light:  #DDBE7E;
      --yk-dark:   #F2EFE8; /* texto principal — marfil */
      --yk-bg:     #16191E; /* fondo carbón */
      --yk-soft:   #1F242B; /* tarjetas */
      --yk-border: rgba(201, 164, 93, 0.3);
    }

    html {
      background: var(--yk-bg);
      color: var(--yk-dark);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      min-height: 100dvh;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 16px;
      line-height: 1.5;
    }

    /* Display: geométrica del menú (estilo Gotham) */
    .display { font-family: 'Montserrat', system-ui, sans-serif; font-weight: 700; letter-spacing: -0.015em; }

    /* Encabezado de sección estilo menú: dorado, mayúsculas, regla arriba y abajo */
    .menu-head {
      font-family: 'Montserrat', system-ui, sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--yk);
      padding: 0.55rem 0;
      border-top: 1px solid rgba(242, 239, 232, 0.35);
      border-bottom: 1px solid var(--yk-border);
    }

    a { color: inherit; text-decoration: none; }

    /* pill button — outline dorado */
    .btn-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1.25rem;
      border-radius: 999px;
      border: 1.5px solid var(--yk);
      color: var(--yk);
      background: transparent;
      font-family: 'Montserrat', system-ui, sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
      text-decoration: none;
    }
    .btn-pill:hover { background: var(--yk); color: #16191E; }

    /* pill button — filled */
    .btn-pill-filled {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.6rem 1.25rem;
      border-radius: 999px;
      border: 1.5px solid var(--yk);
      color: #16191E;
      background: var(--yk);
      font-family: 'Montserrat', system-ui, sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
      text-decoration: none;
    }
    .btn-pill-filled:hover { background: var(--yk-light); border-color: var(--yk-light); }

    /* badge — small pill */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-family: 'Montserrat', system-ui, sans-serif;
    }

    /* section cards */
    .card {
      background: var(--yk-soft);
      border: 1px solid var(--yk-border);
      border-radius: 14px;
      transition: border-color 0.2s, transform 0.25s, box-shadow 0.25s;
    }
    .card:hover {
      border-color: var(--yk);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px -10px rgba(0, 0, 0, 0.55);
    }

    /* ── Animaciones ──────────────────────────────────────────────────── */

    /* Reveal al hacer scroll (aplicado por JS) */
    .rv {
      opacity: 0;
      transform: translateY(18px);
      transition:
        opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: var(--rv-d, 0s);
    }
    .rv.in { opacity: 1; transform: none; }

    /* Flechas que se deslizan al hover */
    .btn-pill svg, .btn-pill-filled svg, .card svg {
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn-pill:hover svg, .btn-pill-filled:hover svg { transform: translateX(3px); }
    .card:hover svg { transform: translateX(3px); }

    /* Botones con leve escala al presionar */
    .btn-pill:active, .btn-pill-filled:active { transform: scale(0.96); }
    .btn-pill, .btn-pill-filled { transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s; }

    /* Tarjetas de paso en rutas */
    .paso-card {
      transition: border-color 0.25s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .paso-card:hover { border-color: var(--yk) !important; transform: translateY(-2px); }

    /* Ícono de montaña flotando en el hero */
    @keyframes yk-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    .float { animation: yk-float 4.5s ease-in-out infinite; }

    /* Pulso del círculo de play en placeholders */
    @keyframes yk-pulse {
      0% { box-shadow: 0 0 0 0 rgba(201, 164, 93, 0.35); }
      70% { box-shadow: 0 0 0 14px rgba(201, 164, 93, 0); }
      100% { box-shadow: 0 0 0 0 rgba(201, 164, 93, 0); }
    }
    .pulse { animation: yk-pulse 2.4s ease-out infinite; }

    /* Logo del header con hover sutil */
    header a img { transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
    header a:hover img { transform: scale(1.05); }

    @media (prefers-reduced-motion: reduce) {
      .rv { opacity: 1 !important; transform: none !important; transition: none !important; }
      .float, .pulse { animation: none !important; }
      .card:hover, .paso-card:hover { transform: none; }
    }
  </style>
</head>
<body>

  <!-- ── Header ───────────────────────────────────────────────────────────── -->
  <header style="position:sticky;top:0;z-index:50;background:rgba(22,25,30,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--yk-border);">
    <div style="max-width:680px;margin:0 auto;padding:0 1rem;height:3.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">

      {backHref ? (
        <a href={backHref} style="display:flex;align-items:center;gap:0.4rem;color:rgba(201,164,93,0.75);font-size:0.78rem;font-weight:500;letter-spacing:0.02em;transition:color 0.18s;flex-shrink:0;" class="back-link">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M9 2.5L4.5 7 9 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {backLabel || 'Atrás'}
        </a>
      ) : (
        <span style="font-size:0.62rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(201,164,93,0.65);font-family:'Montserrat',sans-serif;">Capacitación</span>
      )}

      <a href="/yasuko/" style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
        <img src="/yasuko-icon.png" alt="" style="width:1.6rem;height:1.6rem;object-fit:contain;display:block;filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen;" onerror="this.style.display='none'" />
        <img src="/yasuko-logo.png" alt="Yasuko" style="width:6rem;height:1.6rem;object-fit:contain;display:block;filter:invert(1);mix-blend-mode:screen;" onerror="this.replaceWith(Object.assign(document.createElement('span'),{textContent:'yasuko',style:'font-family:Montserrat;font-weight:700;font-size:1.15rem;color:#F2EFE8;letter-spacing:0.02em;'}))" />
      </a>

      {backHref ? (
        <span style="font-size:0.62rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,239,232,0.4);font-family:'Montserrat',sans-serif;">Manual Vivo™</span>
      ) : (
        <a href="/yasuko/ruta/sushiman-barra" style="font-size:0.72rem;font-weight:600;color:var(--yk);letter-spacing:0.04em;font-family:'Montserrat',sans-serif;">Mi ruta →</a>
      )}

    </div>
  </header>

  <!-- ── Content ──────────────────────────────────────────────────────────── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ───────────────────────────────────────────────────────────── -->
  <footer style="border-top:1px solid var(--yk-border);margin-top:4rem;padding:2rem 1rem;">
    <div style="max-width:680px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <div style="display:flex;align-items:center;gap:0.45rem;opacity:0.55;">
        <img src="/yasuko-icon.png" alt="" style="width:1.2rem;height:1.2rem;object-fit:contain;filter:invert(1) hue-rotate(180deg);mix-blend-mode:screen;" onerror="this.style.display='none'" />
        <span style="font-size:0.72rem;color:rgba(242,239,232,0.55);letter-spacing:0.05em;font-weight:500;">Yasuko · Grupo Caribe</span>
      </div>
      <span style="font-size:0.7rem;color:rgba(242,239,232,0.38);letter-spacing:0.06em;">Manual Vivo™ × Antemano</span>
    </div>
  </footer>

  <style>
    .back-link:hover { color: var(--yk) !important; }
  </style>

  <script>
    // ── Sistema de reveals al hacer scroll ──────────────────────────────
    // Se re-ejecuta en cada navegación (View Transitions) vía astro:page-load.
    let lastUrl: string | null = null;

    function initReveals() {
      if (location.href === lastUrl) return;
      lastUrl = location.href;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      // Candidatos: hijos directos de secciones + bloques del módulo,
      // excluyendo contenedores de tarjetas (las tarjetas se revelan solas).
      const candidatos = new Set<HTMLElement>();
      document
        .querySelectorAll<HTMLElement>('main section > *, main > div > div')
        .forEach((el) => {
          if (el.matches('script, style')) return;
          if (el.querySelector('.card, .modulo-card, .paso-card')) return;
          candidatos.add(el);
        });
      document
        .querySelectorAll<HTMLElement>('.card, .modulo-card, .paso-card')
        .forEach((el) => candidatos.add(el));

      // Stagger por grupo de hermanos
      const porPadre = new Map<HTMLElement, HTMLElement[]>();
      candidatos.forEach((el) => {
        const p = el.parentElement!;
        if (!porPadre.has(p)) porPadre.set(p, []);
        porPadre.get(p)!.push(el);
      });
      porPadre.forEach((grupo) => {
        grupo.forEach((el, i) => {
          el.style.setProperty('--rv-d', `${Math.min(i * 70, 420)}ms`);
          el.classList.add('rv');
        });
      });

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
      );
      candidatos.forEach((el) => io.observe(el));
    }

    document.addEventListener('astro:after-swap', initReveals);
    document.addEventListener('astro:page-load', initReveals);
    if (document.readyState !== 'loading') initReveals();
    else document.addEventListener('DOMContentLoaded', initReveals, { once: true });
  </script>

</body>
</html>

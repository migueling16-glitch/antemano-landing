---
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = 'Antemano Taller Creativo — Producción Audiovisual y Estrategia Digital en Durango',
  description = 'Somos un equipo de realizadores y estrategas en Durango, México. Producimos lo que tu marca necesita contar: video, fotografía y estrategia digital.',
  canonicalPath = '',
} = Astro.props;

const origin = 'https://antemanoc.com';
const canonical = `${origin}${canonicalPath}`;
const ogImage = `${origin}/og-image.jpg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1A1A" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" href="/logo-a.png" type="image/png" />
    <link rel="apple-touch-icon" href="/logo-a.png" />

    <!-- Google Fonts (preload) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Per-page head extras (schema.org, tracking pixels, etc.) -->
    <slot name="head" />

    <!-- Intro gate: skip the preloader when already seen, on inner pages, or reduced-motion -->
    <script is:inline>
      (function () {
        try {
          var seen = sessionStorage.getItem('am_intro') === '1';
          var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var home = location.pathname === '/' || location.pathname === '/index.html';
          if (seen || rm || !home) document.documentElement.classList.add('intro-done');
        } catch (e) {
          document.documentElement.classList.add('intro-done');
        }
      })();
    </script>

    <style is:global>
      /* ─── Base ───────────────────────────────────────────────────────── */
      :root {
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-in-out-quart: cubic-bezier(0.76, 0, 0.24, 1);
      }

      *, *::before, *::after { box-sizing: border-box; }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background-color: #fafafa;
        color: #1a1a1a;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }

      ::selection {
        background: #1a1a1a;
        color: #fff;
      }

      /* ─── Keyword highlight ──────────────────────────────────────────── */
      /* Use <strong class="kw"> for persuasive words on light backgrounds  */
      /* Use <strong class="kw kw-light"> for dark (hero) backgrounds       */
      strong.kw {
        font-weight: 800;
        color: #1a1a1a;
        font-style: normal;
      }
      strong.kw-light {
        color: #ffffff;
      }

      /* ─── Focus ──────────────────────────────────────────────────────── */
      :focus { outline: none; }
      :focus-visible {
        outline: 2px solid #1a1a1a;
        outline-offset: 3px;
        border-radius: 4px;
      }

      /* ─── Reveal animations ──────────────────────────────────────────── */
      .reveal,
      .reveal-up,
      .reveal-left,
      .reveal-right,
      .reveal-scale,
      .reveal-fade {
        opacity: 0;
        will-change: opacity, transform;
        transition:
          opacity 0.85s var(--ease-out-expo),
          transform 0.85s var(--ease-out-expo);
      }
      .reveal,
      .reveal-up    { transform: translateY(32px); }
      .reveal-left  { transform: translateX(-32px); }
      .reveal-right { transform: translateX(32px); }
      .reveal-scale { transform: scale(0.94); }
      .reveal-fade  { transform: none; }

      .reveal.visible,
      .reveal-up.visible,
      .reveal-left.visible,
      .reveal-right.visible,
      .reveal-scale.visible,
      .reveal-fade.visible {
        opacity: 1;
        transform: none;
      }

      .reveal-delay-1 { transition-delay: 0.08s; }
      .reveal-delay-2 { transition-delay: 0.16s; }
      .reveal-delay-3 { transition-delay: 0.24s; }
      .reveal-delay-4 { transition-delay: 0.32s; }
      .reveal-delay-5 { transition-delay: 0.40s; }
      .reveal-delay-6 { transition-delay: 0.48s; }

      /* ─── Smooth image load ──────────────────────────────────────────── */
      img {
        transition: opacity 0.4s var(--ease-out-quart);
      }
      img[loading="lazy"]:not(.loaded) {
        opacity: 0;
      }
      img.loaded { opacity: 1; }

      /* ─── Scroll progress bar ────────────────────────────────────────── */
      #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0%;
        background: #1a1a1a;
        z-index: 100;
        transition: width 0.05s linear;
        pointer-events: none;
      }

      /* ─── Back to top ────────────────────────────────────────────────── */
      #back-to-top {
        position: fixed;
        right: 24px;
        bottom: 24px;
        width: 44px;
        height: 44px;
        border-radius: 9999px;
        background: #1a1a1a;
        color: #fff;
        border: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 60;
        opacity: 0;
        transform: translateY(12px) scale(0.9);
        pointer-events: none;
        transition:
          opacity 0.3s var(--ease-out-quart),
          transform 0.3s var(--ease-out-quart),
          background 0.2s;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
      }
      #back-to-top.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
      }
      #back-to-top:hover { background: #000; transform: translateY(-2px) scale(1); }
      #back-to-top svg { width: 18px; height: 18px; }

      /* ─── Toast ──────────────────────────────────────────────────────── */
      #toast-container {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 200;
        pointer-events: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
      }
      .toast {
        background: #1a1a1a;
        color: #fff;
        padding: 12px 20px;
        border-radius: 9999px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.02em;
        opacity: 0;
        transform: translateY(12px);
        transition:
          opacity 0.3s var(--ease-out-quart),
          transform 0.3s var(--ease-out-quart);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        white-space: nowrap;
      }
      .toast.show { opacity: 1; transform: translateY(0); }

      /* ─── Magnetic button wrapper ────────────────────────────────────── */
      .magnetic {
        display: inline-block;
        transition: transform 0.25s var(--ease-out-quart);
        will-change: transform;
      }

      /* ════════════════════════════════════════════════════════════════
         ENHANCED MOTION LAYER
         ════════════════════════════════════════════════════════════════ */

      /* ── Cinematic intro preloader ─────────────────────────────────── */
      #preloader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        will-change: transform;
      }
      html.intro-done #preloader { display: none !important; }
      .pre-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 22px;
      }
      .pre-mark {
        width: clamp(64px, 12vw, 104px);
        height: auto;
        filter: brightness(0) invert(1);
        opacity: 0;
        transform: translateY(10px) scale(0.94);
        animation: preMarkIn 0.8s var(--ease-out-expo) 0.05s forwards;
      }
      .pre-track {
        width: clamp(120px, 22vw, 200px);
        height: 2px;
        background: rgba(255, 255, 255, 0.14);
        border-radius: 2px;
        overflow: hidden;
      }
      .pre-fill {
        display: block;
        height: 100%;
        width: 0%;
        background: #fff;
        border-radius: 2px;
      }
      .pre-count {
        position: fixed;
        right: 6vw;
        bottom: 6vh;
        font-variant-numeric: tabular-nums;
        font-weight: 800;
        font-size: 12px;
        letter-spacing: 0.14em;
        color: rgba(255, 255, 255, 0.45);
      }
      #preloader.lift {
        transform: translateY(-100%);
        transition: transform 0.9s var(--ease-in-out-quart);
      }
      #preloader.lift .pre-inner,
      #preloader.lift .pre-count {
        opacity: 0;
        transition: opacity 0.35s ease;
      }
      @keyframes preMarkIn { to { opacity: 1; transform: none; } }

      /* ── Custom cursor (desktop fine-pointer only) ─────────────────── */
      .cursor-dot,
      .cursor-ring {
        position: fixed;
        top: 0;
        left: 0;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9990;
        mix-blend-mode: difference;
        opacity: 0;
        will-change: transform;
      }
      .cursor-dot {
        width: 6px;
        height: 6px;
        margin: -3px 0 0 -3px;
        background: #fff;
        transition: opacity 0.3s;
      }
      .cursor-ring {
        width: 38px;
        height: 38px;
        margin: -19px 0 0 -19px;
        border: 1px solid rgba(255, 255, 255, 0.7);
        transition:
          width 0.28s var(--ease-out-quart),
          height 0.28s var(--ease-out-quart),
          margin 0.28s var(--ease-out-quart),
          background 0.28s,
          border-color 0.28s,
          opacity 0.3s;
      }
      body.cursor-ready .cursor-dot,
      body.cursor-ready .cursor-ring { opacity: 1; }
      .cursor-ring.hover {
        width: 66px;
        height: 66px;
        margin: -33px 0 0 -33px;
        background: rgba(255, 255, 255, 0.10);
        border-color: transparent;
      }
      .cursor-ring.down { border-color: rgba(255, 255, 255, 1); }
      .cursor-dot.hide,
      .cursor-ring.hide { opacity: 0 !important; }
      body.cursor-on { cursor: none; }
      body.cursor-on a,
      body.cursor-on button,
      body.cursor-on [role="button"],
      body.cursor-on label,
      body.cursor-on .portfolio-item { cursor: none; }
      body.cursor-on input,
      body.cursor-on textarea,
      body.cursor-on select { cursor: text; }
      .cursor-label {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 9991;
        pointer-events: none;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #fff;
        mix-blend-mode: difference;
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
        transition: opacity 0.25s, transform 0.25s var(--ease-out-quart);
        will-change: transform;
      }
      .cursor-label.show { opacity: 1; transform: translate(-50%, -50%) scale(1); }

      /* ── Velocity-reactive skew utility ────────────────────────────── */
      .sv-skew { transform: skewY(var(--sv-skew, 0deg)); will-change: transform; }

      /* ── Extra reveal variants ─────────────────────────────────────── */
      .reveal-blur {
        opacity: 0;
        transform: translateY(42px) scale(0.985);
        filter: blur(16px);
        will-change: opacity, transform, filter;
        transition:
          opacity 0.95s var(--ease-out-expo),
          transform 1.05s var(--ease-out-expo),
          filter 0.75s var(--ease-out-quart);
        transition-delay: calc(var(--rd, 0) * 0.08s);
      }
      .reveal-blur.visible { opacity: 1; transform: none; filter: blur(0); }
      .reveal-clip {
        clip-path: inset(0 0 100% 0);
        opacity: 0.001;
        transition:
          clip-path 1.05s var(--ease-out-expo),
          opacity 0.2s;
        transition-delay: calc(var(--rd, 0) * 0.08s);
        will-change: clip-path;
      }
      .reveal-clip.visible { clip-path: inset(0 0 0 0); opacity: 1; }

      /* ─── Reduced motion ─────────────────────────────────────────────── */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        .reveal,
        .reveal-up,
        .reveal-left,
        .reveal-right,
        .reveal-scale,
        .reveal-fade {
          opacity: 1 !important;
          transform: none !important;
        }
        #preloader { display: none !important; }
        .cursor-dot, .cursor-ring, .cursor-label { display: none !important; }
        body.cursor-on { cursor: auto !important; }
        .reveal-blur, .reveal-clip {
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
          clip-path: none !important;
        }
        .sv-skew { transform: none !important; }
      }
    </style>
  </head>

  <body>
    <!-- Cinematic intro preloader (home only, session-gated) -->
    <div id="preloader" aria-hidden="true">
      <div class="pre-inner">
        <img src="/logo-a.png" alt="" class="pre-mark" />
        <span class="pre-track"><span class="pre-fill" id="pre-fill"></span></span>
      </div>
      <span class="pre-count" id="pre-count">00</span>
    </div>

    <!-- Custom cursor -->
    <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>
    <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>
    <span class="cursor-label" id="cursor-label" aria-hidden="true"></span>

    <!-- Scroll progress bar -->
    <div id="scroll-progress" aria-hidden="true"></div>

    <slot />

    <!-- Back to top -->
    <button id="back-to-top" aria-label="Volver arriba" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
      </svg>
    </button>

    <!-- Toast container -->
    <div id="toast-container" aria-live="polite"></div>

    <script>
      // ─── Reveal on scroll ────────────────────────────────────────────
      const revealSelectors = [
        '.reveal',
        '.reveal-up',
        '.reveal-left',
        '.reveal-right',
        '.reveal-scale',
        '.reveal-fade',
        '.reveal-blur',
        '.reveal-clip',
      ].join(',');

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll(revealSelectors).forEach((el) => revealObserver.observe(el));

        // Mark loaded images
        document.querySelectorAll<HTMLImageElement>('img').forEach((img) => {
          if (img.complete && img.naturalWidth > 0) {
            img.classList.add('loaded');
          } else {
            img.addEventListener('load', () => img.classList.add('loaded'), { once: true });
            img.addEventListener('error', () => img.classList.add('loaded'), { once: true });
          }
        });
      });

      // ─── Scroll progress bar ─────────────────────────────────────────
      const progressBar = document.getElementById('scroll-progress')!;
      function updateProgress() {
        const h = document.documentElement;
        const scrollTop = h.scrollTop || document.body.scrollTop;
        const max = (h.scrollHeight - h.clientHeight) || 1;
        progressBar.style.width = `${(scrollTop / max) * 100}%`;
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      // ─── Back to top ─────────────────────────────────────────────────
      const backToTop = document.getElementById('back-to-top')!;
      function updateBackToTop() {
        if (window.scrollY > 600) backToTop.classList.add('visible');
        else backToTop.classList.remove('visible');
      }
      window.addEventListener('scroll', updateBackToTop, { passive: true });
      backToTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      updateBackToTop();

      // ─── Toast system (global) ───────────────────────────────────────
      const toastContainer = document.getElementById('toast-container')!;
      (window as any).showToast = function showToast(msg: string, duration = 2400) {
        const t = document.createElement('div');
        t.className = 'toast';
        t.textContent = msg;
        toastContainer.appendChild(t);
        requestAnimationFrame(() => t.classList.add('show'));
        setTimeout(() => {
          t.classList.remove('show');
          setTimeout(() => t.remove(), 320);
        }, duration);
      };

      // ─── Magnetic buttons ────────────────────────────────────────────
      const mediaQuery = window.matchMedia('(hover: hover) and (pointer: fine)');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (mediaQuery.matches && !reducedMotion) {
        document.querySelectorAll<HTMLElement>('.magnetic').forEach((el) => {
          const strength = Number(el.dataset.magnetic || 0.25);
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const x = (e.clientX - rect.left - rect.width / 2) * strength;
            const y = (e.clientY - rect.top - rect.height / 2) * strength;
            el.style.transform = `translate(${x}px, ${y}px)`;
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = 'translate(0, 0)';
          });
        });
      }
    </script>

    <!-- ═══ Enhanced motion engine: preloader · velocity · cursor ═══ -->
    <script>
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const root = document.documentElement;
        (window as any).__sv = 0;

        /* ── Intro preloader ─────────────────────────────────────────── */
        const pre = document.getElementById('preloader');
        function finishIntro() {
          if (root.classList.contains('intro-done')) return;
          root.classList.add('intro-done');
          try { sessionStorage.setItem('am_intro', '1'); } catch (e) {}
          document.body.style.overflow = '';
        }
        if (pre && !root.classList.contains('intro-done') && !reduce) {
          document.body.style.overflow = 'hidden';
          const fill = document.getElementById('pre-fill');
          const count = document.getElementById('pre-count');
          const startT = performance.now();
          const DUR = 1050;
          let lifted = false;
          function lift() {
            if (lifted) return;
            lifted = true;
            pre!.classList.add('lift');
            const done = () => { finishIntro(); pre!.remove(); };
            pre!.addEventListener('transitionend', done, { once: true });
            setTimeout(done, 1100); // safety in case transitionend never fires
          }
          function tick(now: number) {
            const t = Math.min((now - startT) / DUR, 1);
            const e = 1 - Math.pow(1 - t, 3);
            const pct = Math.round(e * 100);
            if (fill) fill.style.width = pct + '%';
            if (count) count.textContent = String(pct).padStart(2, '0');
            if (t < 1) requestAnimationFrame(tick);
            else setTimeout(lift, 140);
          }
          requestAnimationFrame(tick);
          const skip = () => lift();
          window.addEventListener('wheel', skip, { once: true, passive: true });
          window.addEventListener('touchstart', skip, { once: true, passive: true });
          window.addEventListener('keydown', skip, { once: true });
          pre.addEventListener('click', skip);
          setTimeout(lift, 2600); // hard safety
        } else if (pre) {
          pre.remove();
          finishIntro();
        }

        /* ── Scroll velocity engine (drives marquee + skews) ─────────── */
        let lastY = window.scrollY, vel = 0, running = false;
        function svLoop() {
          const y = window.scrollY;
          const dy = y - lastY;
          lastY = y;
          vel += (dy - vel) * 0.18;
          (window as any).__sv = vel;
          const skew = Math.max(-3.2, Math.min(3.2, vel * 0.09));
          root.style.setProperty('--sv-skew', skew.toFixed(2) + 'deg');
          if (Math.abs(vel) > 0.06) {
            requestAnimationFrame(svLoop);
          } else {
            running = false;
            vel = 0;
            (window as any).__sv = 0;
            root.style.setProperty('--sv-skew', '0deg');
          }
        }
        if (!reduce) {
          window.addEventListener('scroll', () => {
            if (!running) { running = true; lastY = window.scrollY; requestAnimationFrame(svLoop); }
          }, { passive: true });
        }

        /* ── Custom cursor ───────────────────────────────────────────── */
        const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        const ring = document.getElementById('cursor-ring');
        const dot = document.getElementById('cursor-dot');
        const label = document.getElementById('cursor-label');
        if (fine && !reduce && ring && dot) {
          document.body.classList.add('cursor-on');
          let mx = window.innerWidth / 2, my = window.innerHeight / 2;
          let rx = mx, ry = my;
          let ready = false;

          window.addEventListener('mousemove', (e) => {
            mx = e.clientX; my = e.clientY;
            dot.style.transform = `translate(${mx}px, ${my}px)`;
            if (label) { label.style.left = mx + 'px'; label.style.top = (my + 30) + 'px'; }
            if (!ready) { ready = true; document.body.classList.add('cursor-ready'); }
          }, { passive: true });

          (function loop() {
            rx += (mx - rx) * 0.18;
            ry += (my - ry) * 0.18;
            ring.style.transform = `translate(${rx}px, ${ry}px)`;
            requestAnimationFrame(loop);
          })();

          window.addEventListener('mousedown', () => ring.classList.add('down'));
          window.addEventListener('mouseup', () => ring.classList.remove('down'));
          document.addEventListener('mouseleave', () => { ring.classList.add('hide'); dot.classList.add('hide'); });
          document.addEventListener('mouseenter', () => { ring.classList.remove('hide'); dot.classList.remove('hide'); });

          const hoverSel = 'a, button, [role="button"], .portfolio-item, input, select, textarea, label, .magnetic';
          document.querySelectorAll<HTMLElement>(hoverSel).forEach((el) => {
            el.addEventListener('mouseenter', () => {
              ring.classList.add('hover');
              const txt = el.getAttribute('data-cursor');
              if (txt && label) { label.textContent = txt; label.classList.add('show'); }
            });
            el.addEventListener('mouseleave', () => {
              ring.classList.remove('hover');
              if (label) label.classList.remove('show');
            });
          });
        }
      })();
    </script>
  </body>
</html>
